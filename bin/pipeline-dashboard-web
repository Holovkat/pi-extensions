#!/usr/bin/env node
// Pipeline Control Center — Web Server with SSE dashboard + Agent Steering
// Usage: pipeline-dashboard-web [project-dir] [--port PORT]

import http from "node:http";
import net from "node:net";
import fs from "node:fs";
import path from "node:path";

const args = process.argv.slice(2);
let projectDir = process.cwd();
let port = 3141;
let controlPort = 3142;

for (let i = 0; i < args.length; i++) {
	if (args[i] === "--port" && args[i + 1]) { port = parseInt(args[i + 1], 10); i++; }
	else if (args[i] === "--control-port" && args[i + 1]) { controlPort = parseInt(args[i + 1], 10); i++; }
	else if (!args[i].startsWith("-")) projectDir = args[i];
}

const stateFile = path.join(projectDir, ".pi", "pipeline-logs", "pipeline-state.json");
const steerFile = path.join(projectDir, ".pi", "pipeline-logs", "pipeline-steer.json");

function readState() {
	try { return JSON.parse(fs.readFileSync(stateFile, "utf-8")); }
	catch { return null; }
}

// ── SSE Clients ──
const sseClients = new Set();
function broadcastState() {
	const state = readState();
	if (!state) return;
	const msg = `data: ${JSON.stringify(state)}\n\n`;
	for (const res of sseClients) {
		try { res.write(msg); } catch { sseClients.delete(res); }
	}
}

// ── Steer Log SSE ──
const steerLogClients = new Set();
const steerLog = [];
function logSteer(entry) {
	const ts = new Date().toISOString().slice(11, 19);
	const line = { ts, ...entry };
	steerLog.push(line);
	if (steerLog.length > 200) steerLog.shift();
	const msg = `data: ${JSON.stringify(line)}\n\n`;
	for (const res of steerLogClients) {
		try { res.write(msg); } catch { steerLogClients.delete(res); }
	}
}

// ── Control Socket (TCP JSON-RPC for agent steering) ──
// Agents register via: {"type":"register","agentId":"...","sessionKey":"..."}
// Steer commands:      {"type":"steer","agentId":"...","message":"..."}
// Follow-up:           {"type":"follow_up","agentId":"...","message":"..."}
// Abort:               {"type":"abort","agentId":"..."}
// List agents:         {"type":"list_agents"}

const registeredAgents = new Map(); // agentId -> { sessionKey, socket, info }

const controlServer = net.createServer((socket) => {
	let buf = "";
	socket.setEncoding("utf-8");
	socket.on("data", (chunk) => {
		buf += chunk;
		let nl;
		while ((nl = buf.indexOf("\n")) !== -1) {
			const line = buf.slice(0, nl).trim();
			buf = buf.slice(nl + 1);
			if (!line) continue;
			try {
				const cmd = JSON.parse(line);
				handleControlCommand(cmd, socket);
			} catch (e) {
				socket.write(JSON.stringify({ success: false, error: "parse error: " + e.message }) + "\n");
			}
		}
	});
	socket.on("error", () => {});
	socket.on("close", () => {
		// Unregister any agents owned by this socket
		for (const [id, agent] of registeredAgents) {
			if (agent.socket === socket) {
				registeredAgents.delete(id);
				logSteer({ type: "unregister", agentId: id, reason: "disconnect" });
			}
		}
	});
});

function handleControlCommand(cmd, socket) {
	switch (cmd.type) {
		case "register": {
			registeredAgents.set(cmd.agentId, {
				sessionKey: cmd.sessionKey || cmd.agentId,
				socket,
				stdin: null, // will be set if agent provides a pipe
				info: cmd.info || {},
				registeredAt: Date.now(),
			});
			logSteer({ type: "register", agentId: cmd.agentId, info: cmd.info });
			socket.write(JSON.stringify({ success: true, command: "register" }) + "\n");
			break;
		}
		case "steer":
		case "follow_up":
		case "abort": {
			const agentId = cmd.agentId;
			const agent = registeredAgents.get(agentId);
			if (!agent) {
				socket.write(JSON.stringify({ success: false, error: "agent not found: " + agentId }) + "\n");
				logSteer({ type: cmd.type, agentId, status: "error", error: "agent not found" });
				return;
			}
			// Forward RPC command to agent's registered socket
			const rpcCmd = cmd.type === "abort"
				? { type: "abort" }
				: { type: cmd.type, message: cmd.message || "" };
			try {
				agent.socket.write(JSON.stringify({ forward: true, ...rpcCmd }) + "\n");
				logSteer({ type: cmd.type, agentId, message: cmd.message, status: "sent" });
				socket.write(JSON.stringify({ success: true, command: cmd.type }) + "\n");
			} catch (e) {
				socket.write(JSON.stringify({ success: false, error: "failed to forward: " + e.message }) + "\n");
				logSteer({ type: cmd.type, agentId, status: "error", error: e.message });
			}
			break;
		}
		case "list_agents": {
			const agents = [];
			for (const [id, agent] of registeredAgents) {
				agents.push({ agentId: id, sessionKey: agent.sessionKey, info: agent.info, registeredAt: agent.registeredAt });
			}
			socket.write(JSON.stringify({ success: true, command: "list_agents", agents }) + "\n");
			break;
		}
		default:
			socket.write(JSON.stringify({ success: false, error: "unknown command: " + cmd.type }) + "\n");
	}
}

// Also write steer commands to a file so the pipeline extension can poll it
function writeSteerFile(cmd) {
	try {
		const dir = path.dirname(steerFile);
		if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
		fs.writeFileSync(steerFile, JSON.stringify({ ...cmd, ts: Date.now() }));
	} catch {}
}

// ── File Watcher ──
let lastMtime = 0;
setInterval(() => {
	try {
		const stat = fs.statSync(stateFile);
		if (stat.mtimeMs !== lastMtime) {
			lastMtime = stat.mtimeMs;
			broadcastState();
		}
	} catch {}
}, 500);

// ── HTTP Server ──
const server = http.createServer((req, res) => {
	// API
	if (req.url === "/api/state") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		const state = readState();
		res.end(state ? JSON.stringify(state) : "null");
		return;
	}
	if (req.url === "/api/agents") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		const agents = [];
		for (const [id, agent] of registeredAgents) {
			agents.push({ agentId: id, sessionKey: agent.sessionKey, info: agent.info });
		}
		// Also include agents from pipeline state
		const state = readState();
		if (state && state.activeAgents) {
			for (const a of state.activeAgents) {
				if (!agents.find(x => x.sessionKey === a.name)) {
					agents.push({ agentId: a.name, sessionKey: a.name, info: { model: a.model, hint: a.hint } });
				}
			}
		}
		res.end(JSON.stringify({ agents }));
		return;
	}
	if (req.url === "/api/steer-log") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		res.end(JSON.stringify({ log: steerLog }));
		return;
	}
	// Steer command via HTTP POST
	if (req.url === "/api/steer" && req.method === "POST") {
		let body = "";
		req.on("data", c => body += c);
		req.on("end", () => {
			res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
			try {
				const cmd = JSON.parse(body);
				writeSteerFile(cmd);
				logSteer({ type: cmd.type || "steer", agentId: cmd.agentId || "pipeline", message: cmd.message, status: "queued-via-http" });
				// Forward to control socket if agent registered
				if (cmd.agentId && registeredAgents.has(cmd.agentId)) {
					const agent = registeredAgents.get(cmd.agentId);
					const rpcCmd = cmd.type === "abort" ? { type: "abort" } : { type: cmd.type || "steer", message: cmd.message };
					agent.socket.write(JSON.stringify({ forward: true, ...rpcCmd }) + "\n");
					logSteer({ type: cmd.type || "steer", agentId: cmd.agentId, message: cmd.message, status: "forwarded" });
				}
				res.end(JSON.stringify({ success: true }));
			} catch (e) {
				res.end(JSON.stringify({ success: false, error: e.message }));
			}
		});
		return;
	}
	// SSE
	if (req.url === "/events") {
		res.writeHead(200, { "Content-Type": "text/event-stream", "Cache-Control": "no-cache", "Connection": "keep-alive", "Access-Control-Allow-Origin": "*" });
		res.write("\n");
		sseClients.add(res);
		const state = readState();
		if (state) res.write(`data: ${JSON.stringify(state)}\n\n`);
		req.on("close", () => sseClients.delete(res));
		return;
	}
	if (req.url === "/steer-events") {
		res.writeHead(200, { "Content-Type": "text/event-stream", "Cache-Control": "no-cache", "Connection": "keep-alive", "Access-Control-Allow-Origin": "*" });
		res.write("\n");
		steerLogClients.add(res);
		// Send history
		for (const entry of steerLog) {
			res.write(`data: ${JSON.stringify(entry)}\n\n`);
		}
		req.on("close", () => steerLogClients.delete(res));
		return;
	}
	// Pages
	if (req.url === "/dashboard") {
		res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
		res.end(DASHBOARD_HTML);
		return;
	}
	if (req.url === "/steer") {
		res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
		res.end(STEER_HTML);
		return;
	}
	// Home
	res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
	res.end(HOME_HTML);
});

server.listen(port, () => {
	console.log(`Pipeline Control Center: http://localhost:${port}`);
	console.log(`  Dashboard: http://localhost:${port}/dashboard`);
	console.log(`  Steer:     http://localhost:${port}/steer`);
	console.log(`  Control:   tcp://localhost:${controlPort}`);
	console.log(`  Watching:  ${stateFile}`);
	console.log(`  Press Ctrl+C to stop\n`);
});

controlServer.listen(controlPort, () => {
	console.log(`Control socket listening on port ${controlPort}`);
});

