<script>${THEME_JS}
var selectedAgent=null;
function refreshAgents(){
fetch('/api/agents').then(function(r){return r.json()}).then(function(d){
var el=document.getElementById('agent-list');
if(!d.agents||d.agents.length===0){el.innerHTML='<div class="no-agents">No agents detected</div>';return}
var html='';
for(var i=0;i<d.agents.length;i++){var a=d.agents[i];
var sel=selectedAgent===a.agentId?' selected':'';
html+='<div class="agent-item'+sel+'" onclick="selectAgent(\\''+esc(a.agentId)+'\\')">';
html+='<span class="dot"></span>';
html+='<span class="name">'+esc(a.agentId)+'</span>';
var info=a.info||{};
html+='<span class="model">'+esc(info.model||a.sessionKey||'')+'</span>';
html+='</div>'}
el.innerHTML=html;
if(!selectedAgent&&d.agents.length>0)selectAgent(d.agents[0].agentId);
})}
function selectAgent(id){selectedAgent=id;refreshAgents()}
function sendCmd(type){
var msg=document.getElementById('steer-msg').value;
if(type!=='abort'&&!msg.trim()){document.getElementById('send-status').textContent='Message required';return}
var body={type:type,agentId:selectedAgent||'pipeline',message:msg};
fetch('/api/steer',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(function(r){return r.json()}).then(function(d){
document.getElementById('send-status').textContent=d.success?type+' sent to '+(selectedAgent||'pipeline'):'Error: '+(d.error||'unknown');
if(d.success&&type!=='abort')document.getElementById('steer-msg').value='';
}).catch(function(e){document.getElementById('send-status').textContent='Error: '+e.message})
}
// SSE for steer log
var steerEvt=new EventSource('/steer-events');
steerEvt.onmessage=function(e){
var entry=JSON.parse(e.data);
var el=document.getElementById('steer-log');
var div=document.createElement('div');div.className='steer-log-entry';
div.innerHTML='<span class="time">'+esc(entry.ts)+'</span><span class="tag '+(entry.type||'')+'">'+esc(entry.type||'?')+'</span><span class="msg">'+esc(entry.agentId||'')+' '+(entry.message?esc(entry.message):'')+' '+(entry.status?'['+esc(entry.status)+']':'')+'</span>';
el.appendChild(div);el.scrollTop=el.scrollHeight;
};
function esc(s){if(!s)return '';var d=document.createElement('div');d.textContent=String(s);return d.innerHTML}
refreshAgents();
setInterval(refreshAgents,3000);
document.getElementById('steer-msg').addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendCmd('steer')}});
</script></body></html>`;
