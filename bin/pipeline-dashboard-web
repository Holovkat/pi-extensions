<script>${THEME_JS}
var state=null,evtSource;
function connect(){evtSource=new EventSource('/events');evtSource.onmessage=function(e){state=JSON.parse(e.data);render()};evtSource.onerror=function(){evtSource.close();setTimeout(connect,2000)}}
connect();
function statusIcon(s){switch(s){case 'passed':return '<span style="color:var(--green)">&#10003;</span>';case 'building':return '<span style="color:var(--primary)" class="agent-spinner">&#9684;</span>';case 'scoring':return '<span style="color:var(--cyan)" class="agent-spinner">&#9684;</span>';case 'failed':return '<span style="color:var(--destructive)">&#10007;</span>';default:return '<span style="color:var(--muted-foreground)">&#9675;</span>'}}
function gateClass(g){if(g.includes('build')||g.includes('fix'))return 'build';if(g.includes('compliance')||g.includes('review'))return 'compliance';if(g==='done')return 'done';if(g==='error')return 'error';return 'build'}
function elapsed(ms){if(!ms)return '';var s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60);if(h>0)return h+'h '+m%60+'m '+s%60+'s';if(m>0)return m+'m '+s%60+'s';return s+'s'}
function scoreClass(s){return s>=95?'high':s>=80?'med':'low'}
function logClass(e){if(e.includes('PASSED')||e.includes('fixed at')||e.includes('done'))return 'pass';if(e.includes('FAILED')||e.includes('could not reach')||e.includes('error'))return 'fail';if(e.startsWith('===')||e.includes('Phase complete')||e.includes('Epic'))return 'phase-start';return ''}
function render(){if(!state){document.getElementById('app').innerHTML='<div class="no-data">Waiting...</div>';return}
var d=state,age=Math.round((Date.now()-d.ts)/1000),html='<div class="status-bar"><span class="status-dot '+(d.running?'running':'idle')+'"></span><strong>'+(d.running?'RUNNING':'IDLE')+'</strong>';
if(d.branch)html+='<span class="badge">'+esc(d.branch)+'</span>';html+='</div>';
var total=d.phases.reduce(function(a,p){return a+p.total},0),done=d.phases.reduce(function(a,p){return a+p.tasks.filter(function(t){return t.status==='passed'}).length},0),pct=total?Math.round(done/total*100):0;
html+='<div class="progress-bar"><div class="progress-fill" style="width:'+pct+'%"></div></div><div style="font-size:.7rem;color:var(--muted-foreground);margin-top:4px">'+done+'/'+total+' tasks ('+pct+'%)</div>';
html+='<div class="phases">';
for(var i=0;i<d.phases.length;i++){var p=d.phases[i],cls=p.allDone?'done':p.isCurrent?'current':'',icon=p.allDone?'<span style="color:var(--green)">&#10003;</span>':p.isCurrent&&d.running?'<span class="agent-spinner" style="color:var(--primary)">&#9684;</span>':'<span style="color:var(--muted-foreground)">&#9675;</span>',pc=p.tasks.filter(function(t){return t.status==='passed'}).length;
html+='<div class="phase '+cls+'"><div class="phase-header"><span class="phase-icon">'+icon+'</span><span class="phase-name">'+esc(p.name)+'</span><span class="phase-meta">'+pc+'/'+p.total;
if(p.gate&&p.gate!=='idle'&&p.gate!=='done')html+=' <span class="gate-badge '+gateClass(p.gate)+'">'+esc(p.gate)+(p.gateAttempts>0?' x'+p.gateAttempts:'')+'</span>';
if(p.elapsed>0)html+=' '+elapsed(p.elapsed);html+='</span></div>';
if(p.isCurrent||p.allDone){html+='<div class="tasks">';for(var j=0;j<p.tasks.length;j++){var t=p.tasks[j];var tid=esc(t.id);var hasIssue=t.issueNum&&t.issueNum>0;var detailId='issue-detail-'+tid.replace(/\./g,'-');var chevronId='chevron-'+tid.replace(/\./g,'-');html+='<div class="task">';html+='<div class="task-row" data-detail="'+detailId+'" data-chevron="'+chevronId+'" data-issue="'+(hasIssue?t.issueNum:'')+'" onclick="toggleIssue(this.dataset.detail,this.dataset.chevron,this.dataset.issue||null)">';html+='<span class="task-chevron" id="'+chevronId+'">&#9654;</span>';html+='<span class="task-icon">'+statusIcon(t.status)+'</span><span class="task-id">'+tid+'</span><span class="task-title">'+esc(t.title)+'</span>';if(hasIssue)html+='<span class="task-issue-num">#'+t.issueNum+'</span>';if(t.complianceScore>0)html+='<span class="task-score '+scoreClass(t.complianceScore)+'">'+t.complianceScore+'%</span>';if(t.attempts>1)html+='<span class="task-attempts">x'+t.attempts+'</span>';html+='</div>';html+='<div class="issue-detail" id="'+detailId+'"></div>';html+='</div>'}html+='</div>'}html+='</div>'}html+='</div>';
var agents=d.activeAgents||(d.activeAgent?[d.activeAgent]:[]);if(agents.length>0){html+='<div class="agents-section"><h2>Active Agents</h2>';for(var k=0;k<agents.length;k++){var a=agents[k];html+='<div class="agent"><span class="agent-spinner" style="color:var(--primary)">&#9684;</span><span class="agent-name">'+esc(a.name)+'</span><span class="agent-model">'+esc(a.model)+'</span></div>'}html+='</div>'}
if(d.log&&d.log.length>0){var show=d.log.slice(-15);html+='<div class="log-section"><h2>Recent Activity</h2>';for(var m=0;m<show.length;m++)html+='<div class="log-entry '+logClass(show[m])+'">'+esc(show[m])+'</div>';html+='</div>'}
document.getElementById('app').innerHTML=html;document.getElementById('updated').textContent=age<5?'live':'updated '+age+'s ago';
for(var eid in expandedIssues){var eEl=document.getElementById(eid);var cid=eid.replace('issue-detail-','chevron-');var cEl=document.getElementById(cid);if(eEl&&cEl){eEl.classList.add('open');cEl.classList.add('open');var eData=expandedIssues[eid];if(eData.issueNum&&issueCache[eData.issueNum])renderIssueDetail(eEl,issueCache[eData.issueNum]);else if(eData.issueNum)eEl.innerHTML='<div class="issue-loading">Loading...</div>';else eEl.innerHTML='<div class="issue-loading">No GitHub issue linked</div>'}}}
function esc(s){if(!s)return '';var d=document.createElement('div');d.textContent=s;return d.innerHTML}
var issueCache={};
var expandedIssues={};
function toggleIssue(detailId,chevronId,issueNum){
issueNum=issueNum?parseInt(issueNum,10):null;
var el=document.getElementById(detailId);var ch=document.getElementById(chevronId);
if(!el||!ch)return;
if(el.classList.contains('open')){el.classList.remove('open');ch.classList.remove('open');delete expandedIssues[detailId];return}
el.classList.add('open');ch.classList.add('open');expandedIssues[detailId]={issueNum:issueNum};
if(!issueNum){el.innerHTML='<div class="issue-loading">No GitHub issue linked to this task</div>';return}
if(issueCache[issueNum]){renderIssueDetail(el,issueCache[issueNum]);return}
el.innerHTML='<div class="issue-loading">Loading issue #'+issueNum+'...</div>';
fetch('/api/issue/'+issueNum).then(function(r){return r.json()}).then(function(data){
if(data.error){el.innerHTML='<div class="issue-loading">'+esc(data.error)+'</div>';return}
issueCache[issueNum]=data;renderIssueDetail(el,data);
}).catch(function(e){el.innerHTML='<div class="issue-loading">Error: '+esc(e.message)+'</div>'})
}
${ISSUE_DETAIL_JS}
function renderIssueDetail(el,data){
var html='';
html+='<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">';
html+='<strong>#'+data.number+': '+esc(data.title)+'</strong>';
html+='<span class="issue-state '+(data.state==='OPEN'||data.state==='open'?'open':'closed')+'">'+(data.state||'').toUpperCase()+'</span>';
html+='</div>';
if(data.labels&&data.labels.length>0){html+='<div class="issue-labels">';for(var i=0;i<data.labels.length;i++)html+='<span class="issue-label">'+esc(data.labels[i])+'</span>';html+='</div>'}
html+='<div class="issue-body">'+renderMd(data.body)+'</div>';
if(data.comments&&data.comments.length>0){
html+='<div class="issue-comments"><strong style="font-size:.75rem">Comments ('+data.comments.length+')</strong>';
for(var c=0;c<data.comments.length;c++){var cm=data.comments[c];
html+='<div class="issue-comment"><div class="issue-comment-header"><span class="issue-comment-author">'+esc(cm.author)+'</span>';
if(cm.createdAt)html+='<span>'+new Date(cm.createdAt).toLocaleString()+'</span>';
html+='</div><div class="issue-comment-body">'+renderMd(cm.body)+'</div></div>'}
html+='</div>'}
if(data.subIssueRefs&&data.subIssueRefs.length>0){
html+='<div class="issue-sub-refs"><strong style="font-size:.75rem">Referenced Issues</strong><br>';
for(var r=0;r<data.subIssueRefs.length;r++){var n=data.subIssueRefs[r];html+='<a class="issue-sub-ref" onclick="drillIssue('+n+',event)">#'+n+'</a>'}
html+='</div>'}
el.innerHTML=html;
}
function drillIssue(num,evt){
if(evt)evt.stopPropagation();
var containerId='drill-issue-'+num;
var existing=document.getElementById(containerId);
if(existing){existing.remove();return}
var panel=document.createElement('div');panel.id=containerId;panel.className='issue-detail open';panel.style.marginLeft='12px';panel.style.marginTop='6px';
panel.innerHTML='<div class="issue-loading">Loading issue #'+num+'...</div>';
var target=evt?evt.target:null;if(target)target.parentNode.insertBefore(panel,target.nextSibling);else document.body.appendChild(panel);
if(issueCache[num]){renderIssueDetail(panel,issueCache[num]);return}
fetch('/api/issue/'+num).then(function(r){return r.json()}).then(function(data){
if(data.error){panel.innerHTML='<div class="issue-loading">'+esc(data.error)+'</div>';return}
issueCache[num]=data;renderIssueDetail(panel,data);
}).catch(function(e){panel.innerHTML='<div class="issue-loading">Error: '+esc(e.message)+'</div>'})
}
setInterval(function(){if(state)render()},1000);
</script></body></html>`;

