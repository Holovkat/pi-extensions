<script>${THEME_JS}
var allSessions=[];
var currentSession=null;

function formatSize(b){if(b<1024)return b+'B';if(b<1048576)return (b/1024).toFixed(1)+'KB';return (b/1048576).toFixed(1)+'MB'}
function formatTime(ts){if(!ts)return '';try{var d=new Date(ts);return d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'})}catch(e){return ''}}
function formatDate(ts){if(!ts)return '';try{var d=new Date(ts);return d.toLocaleDateString([],{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'})}catch(e){return ''}}

function roleFromName(n){
if(n.startsWith('fast-build'))return 'build';
if(n.startsWith('fast-eval'))return 'eval';
if(n.startsWith('fast-fix'))return 'fix';
if(n.startsWith('fast-reeval'))return 'reeval';
if(n.startsWith('fast-analyst'))return 'analyst';
if(n.startsWith('fast-uat'))return 'uat';
return 'agent';
}
function roleBadgeColor(r){
switch(r){case 'build':return 'var(--primary)';case 'eval':return 'var(--cyan)';case 'fix':return 'var(--yellow)';case 'reeval':return 'var(--cyan)';case 'analyst':return 'oklch(0.7 0.15 310)';case 'uat':return 'var(--green)';default:return 'var(--muted-foreground)'}
}

function loadSessions(){
fetch('/api/sessions').then(function(r){return r.json()}).then(function(d){
allSessions=d.sessions||[];
allSessions.reverse();
renderSessionList(allSessions);
// Auto-select from URL hash
var hash=window.location.hash.slice(1);
if(hash){
var found=allSessions.find(function(s){return s.name===hash});
if(found)loadSession(found.name);
}
})}

function filterSessions(){
var q=document.getElementById('filter').value.toLowerCase();
var filtered=allSessions.filter(function(s){return s.name.toLowerCase().includes(q)||s.model.toLowerCase().includes(q)});
renderSessionList(filtered);
}

function renderSessionList(sessions){
var el=document.getElementById('session-list');
if(sessions.length===0){el.innerHTML='<div style="padding:20px;text-align:center;color:var(--muted-foreground);font-size:.8rem">No sessions found</div>';return}
var html='';
for(var i=0;i<sessions.length;i++){
var s=sessions[i];
var role=roleFromName(s.name);
var active=currentSession===s.name?' active':'';
html+='<div class="session-item'+active+'" onclick="loadSession(\\''+esc(s.name)+'\\')"><div class="name">'+esc(s.name)+'</div><div class="meta">';
html+='<span style="color:'+roleBadgeColor(role)+'">'+role+'</span>';
if(s.model)html+='<span class="model-tag">'+esc(s.model)+'</span>';
if(s.meta&&s.meta.elapsed)html+='<span>'+Math.round(s.meta.elapsed/1000)+'s</span>';
if(s.meta&&s.meta.yielded)html+='<span style="color:var(--yellow)">Y</span>';
html+='<span class="size-tag">'+formatSize(s.size)+'</span>';
if(s.mtime)html+='<span>'+formatDate(s.mtime)+'</span>';
html+='</div></div>';
}
el.innerHTML=html;
}

function loadSession(name){
currentSession=name;
window.location.hash=name;
renderSessionList(allSessions.filter(function(s){
var q=document.getElementById('filter').value.toLowerCase();
return !q||s.name.toLowerCase().includes(q)||s.model.toLowerCase().includes(q);
}));
var main=document.getElementById('session-main');
main.innerHTML='<div class="chat-empty">Loading '+esc(name)+'...</div>';
fetch('/api/session/'+encodeURIComponent(name)).then(function(r){return r.json()}).then(function(d){
if(d.error){main.innerHTML='<div class="chat-empty">Error: '+esc(d.error)+'</div>';return}
renderChat(d,name);
}).catch(function(e){main.innerHTML='<div class="chat-empty">Error: '+esc(e.message)+'</div>'});
}

function renderMarkdown(raw){
if(!raw)return '';
// Work on raw text, escape only non-markdown content
// 1. Extract code blocks first to protect them
var codeBlocks=[];
var s=raw.replace(/\`\`\`(\\w*)?\\n([\\s\\S]*?)\`\`\`/g,function(m,lang,code){
var idx=codeBlocks.length;
codeBlocks.push('<pre><code class="language-'+(lang||'plaintext')+'">'+esc(code)+'</code></pre>');
return '\\x00CB'+idx+'\\x00';
});
// 2. Extract inline code
var inlineCode=[];
s=s.replace(/\`([^\`]+)\`/g,function(m,code){
var idx=inlineCode.length;
inlineCode.push('<code>'+esc(code)+'</code>');
return '\\x00IC'+idx+'\\x00';
});
// 3. Now escape HTML in remaining text
s=esc(s);
// 4. Tables: detect lines starting with |
s=s.replace(/(^\\|.+\\|$\\n?)+/gm,function(tableBlock){
var rows=tableBlock.trim().split('\\n');
var html='<table>';
for(var r=0;r<rows.length;r++){
var row=rows[r].trim();
if(!row)continue;
// Skip separator rows (|---|---|)
if(/^[\\s|\\-:]+$/.test(row))continue;
var cells=row.split('|').filter(function(c,i,a){return i>0&&i<a.length-1});
var tag=r===0?'th':'td';
html+='<tr>';
for(var c=0;c<cells.length;c++){
var cell=cells[c].trim();
// Render bold/italic within cells
cell=cell.replace(/\\*\\*(.+?)\\*\\*/g,'<strong>$1</strong>');
cell=cell.replace(/\\*(.+?)\\*/g,'<em>$1</em>');
html+='<'+tag+'>'+cell+'</'+tag+'>';
}
html+='</tr>';
}
return html+'</table>';
});
// 5. Headers
s=s.replace(/^### (.+)$/gm,'<h3>$1</h3>');
s=s.replace(/^## (.+)$/gm,'<h2>$1</h2>');
s=s.replace(/^# (.+)$/gm,'<h1>$1</h1>');
// 6. Bold and italic
s=s.replace(/\\*\\*(.+?)\\*\\*/g,'<strong>$1</strong>');
s=s.replace(/\\*(.+?)\\*/g,'<em>$1</em>');
// 7. Horizontal rule
s=s.replace(/^---$/gm,'<hr>');
// 8. Blockquote
s=s.replace(/^&gt; (.+)$/gm,'<blockquote>$1</blockquote>');
// 9. List items
s=s.replace(/^[\\-\\*] (.+)$/gm,'<li>$1</li>');
s=s.replace(/^\\d+\\. (.+)$/gm,'<li>$1</li>');
s=s.replace(/((?:<li>.*<\\/li>\\n?)+)/g,'<ul>$1</ul>');
// 10. Line breaks
s=s.replace(/\\n/g,'<br>');
s=s.replace(/<\\/(h[123]|pre|ul|ol|table|blockquote|hr|li)><br>/g,'</$1>');
s=s.replace(/<br><(h[123]|pre|ul|ol|table|blockquote|li)/g,'<$1');
s=s.replace(/<br><\\/(ul|ol)>/g,'</$1>');
// 11. Restore code blocks and inline code
for(var i=0;i<codeBlocks.length;i++)s=s.replace('\\x00CB'+i+'\\x00',codeBlocks[i]);
for(var i=0;i<inlineCode.length;i++)s=s.replace('\\x00IC'+i+'\\x00',inlineCode[i]);
return s;
}

var toggleCounter=0;
function renderChat(data,name){
var main=document.getElementById('session-main');
var events=data.events||[];
var role=roleFromName(name);
var html='<div class="chat-container">';
html+='<div class="chat-header"><span class="session-title">'+esc(name)+'</span>';
html+='<span class="badge" style="border-color:'+roleBadgeColor(role)+';color:'+roleBadgeColor(role)+'">'+role+'</span>';
if(data.format)html+='<span class="badge">'+esc(data.format)+'</span>';
if(data.session&&data.session.timestamp)html+='<span class="badge">'+formatDate(data.session.timestamp)+'</span>';
if(data.meta){
var m=data.meta;
if(m.elapsed)html+='<span class="badge">'+Math.round(m.elapsed/1000)+'s</span>';
if(m.yielded)html+='<span class="badge" style="border-color:var(--yellow);color:var(--yellow)">YIELDED</span>';
if(m.exitCode!==undefined&&m.exitCode!==0)html+='<span class="badge" style="border-color:var(--destructive);color:var(--destructive)">exit '+m.exitCode+'</span>';
}
if(data.exportUrl)html+='<a href="'+esc(data.exportUrl)+'" target="_blank" class="badge" style="border-color:var(--primary);color:var(--primary);cursor:pointer;text-decoration:none">Export HTML</a>';
html+='</div>';
if(data.meta&&data.meta.watchdog&&data.meta.watchdog.length>0){
html+='<div style="padding:8px 12px;margin-bottom:12px;background:var(--muted);border:1px solid var(--border);border-radius:var(--radius);font-size:.72rem">';
html+='<strong style="color:var(--yellow)">Watchdog Events:</strong> ';
for(var w=0;w<data.meta.watchdog.length;w++){
html+=esc(data.meta.watchdog[w].event);
if(w<data.meta.watchdog.length-1)html+=', ';
}
html+='</div>';
}

for(var i=0;i<events.length;i++){
var ev=events[i];

if(ev.type==='header'){
html+='<div style="padding:8px 0;font-size:.72rem;color:var(--muted-foreground);font-family:monospace">'+esc(ev.role)+' | '+esc(ev.session)+' | '+esc(ev.timestamp)+'</div>';
continue;
}

if(ev.type==='user'){
html+='<div class="chat-msg user-msg"><div class="chat-avatar">U</div><div class="chat-bubble"><div class="sender">User Prompt <span class="timestamp">'+formatTime(ev.timestamp)+'</span></div><div class="content">'+renderMarkdown(ev.text)+'</div></div></div>';
continue;
}

if(ev.type==='thinking'){
var tid='think'+toggleCounter++;
html+='<div class="thinking-block"><button class="thinking-toggle" onclick="toggleBlock(\\''+tid+'\\')" id="btn-'+tid+'"><span class="arrow">&#9654;</span> Thinking'+(ev.model?' <span style="color:var(--muted-foreground);font-weight:400">('+esc(ev.model)+')</span>':'')+'</button><div class="thinking-content" id="'+tid+'">'+esc(ev.text)+'</div></div>';
continue;
}

if(ev.type==='assistant'){
html+='<div class="chat-msg assistant-msg"><div class="chat-avatar">A</div><div class="chat-bubble"><div class="sender">Agent'+(ev.model?' <span class="timestamp">'+esc(ev.model)+'</span>':'')+(ev.provider?' <span class="timestamp">via '+esc(ev.provider)+'</span>':'')+'</div><div class="content">'+renderMarkdown(ev.text)+'</div></div></div>';
continue;
}

if(ev.type==='tool_start'){
var toolId='tool'+toggleCounter++;
// Find matching tool_end
var endEv=null;
for(var j=i+1;j<events.length;j++){if(events[j].type==='tool_end'&&events[j].toolCallId===ev.toolCallId){endEv=events[j];events[j]={type:'_consumed'};break}}
var argSummary='';
if(ev.args){
if(ev.toolName==='read'||ev.toolName==='write'||ev.toolName==='edit')argSummary=ev.args.path||ev.args.file_path||'';
else if(ev.toolName==='bash'||ev.toolName==='shell')argSummary=(ev.args.command||'').slice(0,80);
else{var ak=Object.keys(ev.args);argSummary=ak.slice(0,2).map(function(k){return k+':'+JSON.stringify(ev.args[k]).slice(0,30)}).join(', ')}
}
var statusCls=endEv?(endEv.isError?'err':'ok'):'';
var statusIcon=endEv?(endEv.isError?'&#10007;':'&#10003;'):'...';
html+='<div class="tool-block" id="wrap-'+toolId+'"><button class="tool-header" onclick="toggleTool(\\''+toolId+'\\')"><span class="arrow">&#9654;</span><span class="tool-name">'+esc(ev.toolName)+'</span><span class="tool-args">'+esc(argSummary)+'</span><span class="tool-status '+statusCls+'">'+statusIcon+'</span></button><div class="tool-body" id="'+toolId+'">';
html+='<div style="padding:8px 12px;font-size:.68rem;color:var(--muted-foreground);border-bottom:1px solid var(--border)"><strong>Arguments:</strong></div>';
html+='<pre><code class="language-json">'+esc(JSON.stringify(ev.args,null,2))+'</code></pre>';
if(endEv){
var resultText=endEv.result||'(empty)';
if(resultText.length>5000)resultText=resultText.slice(0,5000)+'\\n... (truncated)';
html+='<div style="padding:8px 12px;font-size:.68rem;color:var(--muted-foreground);border-bottom:1px solid var(--border)"><strong>Result:</strong></div>';
html+='<pre><code class="language-plaintext">'+esc(resultText)+'</code></pre>';
}
html+='</div></div>';
continue;
}
if(ev.type==='tool_end'||ev.type==='_consumed'){continue;}

if(ev.type==='usage'){
if(ev.usage){
var u=ev.usage;
html+='<div class="usage-block">';
if(u.input)html+='in:'+u.input+' ';
if(u.output)html+='out:'+u.output+' ';
if(u.cacheRead)html+='cache:'+u.cacheRead+' ';
if(u.cost&&u.cost.total)html+='$'+u.cost.total.toFixed(4)+' ';
html+='</div>';
}
continue;
}

if(ev.type==='agent_end'){
html+='<div class="agent-end-block"><span class="label">Session Complete</span>';
if(ev.model)html+='<span class="stat">Model: '+esc(ev.model)+'</span>';
if(ev.stopReason)html+='<span class="stat">Stop: '+esc(ev.stopReason)+'</span>';
if(ev.usage){
var u=ev.usage;
if(u.input)html+='<span class="stat">In: '+u.input.toLocaleString()+'</span>';
if(u.output)html+='<span class="stat">Out: '+u.output.toLocaleString()+'</span>';
if(u.cost&&u.cost.total>0)html+='<span class="stat">Cost: $'+u.cost.total.toFixed(4)+'</span>';
}
if(ev.timestamp)html+='<span class="stat">'+formatTime(ev.timestamp)+'</span>';
html+='</div>';
continue;
}
}

html+='</div>';
main.innerHTML=html;

// Run highlight.js on all code blocks
setTimeout(function(){
main.querySelectorAll('pre code').forEach(function(block){try{hljs.highlightElement(block)}catch(e){}});
},50);
main.scrollTop=0;
}

function toggleBlock(id){
var el=document.getElementById(id);
var btn=document.getElementById('btn-'+id);
if(el.classList.contains('open')){el.classList.remove('open');btn.classList.remove('open')}
else{el.classList.add('open');btn.classList.add('open')}
}
function toggleTool(id){
var el=document.getElementById(id);
var wrap=document.getElementById('wrap-'+id);
var btn=wrap.querySelector('.tool-header');
if(el.classList.contains('open')){el.classList.remove('open');btn.classList.remove('open')}
else{el.classList.add('open');btn.classList.add('open');
// Highlight any code blocks inside
el.querySelectorAll('pre code').forEach(function(b){try{hljs.highlightElement(b)}catch(e){}});
}
}

function esc(s){if(!s)return '';var d=document.createElement('div');d.textContent=String(s);return d.innerHTML}

loadSessions();
</script></body></html>`;
