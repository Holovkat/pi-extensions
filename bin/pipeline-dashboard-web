<script>${THEME_JS}
var state=null,evtSource;
function connect(){evtSource=new EventSource('/events');evtSource.onmessage=function(e){state=JSON.parse(e.data);render()};evtSource.onerror=function(){evtSource.close();setTimeout(connect,2000)}}
connect();
function statusIcon(s){switch(s){case 'passed':return '<span style="color:var(--green)">&#10003;</span>';case 'building':return '<span style="color:var(--primary)" class="agent-spinner">&#9684;</span>';case 'scoring':return '<span style="color:var(--cyan)" class="agent-spinner">&#9684;</span>';case 'failed':return '<span style="color:var(--destructive)">&#10007;</span>';default:return '<span style="color:var(--muted-foreground)">&#9675;</span>'}}
function gateClass(g){if(g.includes('build')||g.includes('fix'))return 'build';if(g.includes('compliance')||g.includes('review'))return 'compliance';if(g==='done')return 'done';if(g==='error')return 'error';return 'build'}
function elapsed(ms){if(!ms)return '';var s=Math.floor(ms/1000),m=Math.floor(s/60),h=Math.floor(m/60);if(h>0)return h+'h '+m%60+'m '+s%60+'s';if(m>0)return m+'m '+s%60+'s';return s+'s'}
function scoreClass(s){return s>=95?'high':s>=80?'med':'low'}
function logClass(e){if(e.includes('PASSED')||e.includes('fixed at')||e.includes('done'))return 'pass';if(e.includes('FAILED')||e.includes('could not reach')||e.includes('error'))return 'fail';if(e.startsWith('===')||e.includes('Phase complete')||e.includes('Epic'))return 'phase-start';return ''}
function render(){if(!state){document.getElementById('app').innerHTML='<div class="no-data">Waiting...</div>';return}
var d=state,age=Math.round((Date.now()-d.ts)/1000),html='<div class="status-bar"><span class="status-dot '+(d.running?'running':'idle')+'"></span><strong>'+(d.running?'RUNNING':'IDLE')+'</strong>';
if(d.branch)html+='<span class="badge">'+esc(d.branch)+'</span>';html+='</div>';
var total=d.phases.reduce(function(a,p){return a+p.total},0),done=d.phases.reduce(function(a,p){return a+p.tasks.filter(function(t){return t.status==='passed'}).length},0),pct=total?Math.round(done/total*100):0;
html+='<div class="progress-bar"><div class="progress-fill" style="width:'+pct+'%"></div></div><div style="font-size:.7rem;color:var(--muted-foreground);margin-top:4px">'+done+'/'+total+' tasks ('+pct+'%)</div>';
html+='<div class="phases">';
for(var i=0;i<d.phases.length;i++){var p=d.phases[i],cls=p.allDone?'done':p.isCurrent?'current':'',icon=p.allDone?'<span style="color:var(--green)">&#10003;</span>':p.isCurrent&&d.running?'<span class="agent-spinner" style="color:var(--primary)">&#9684;</span>':'<span style="color:var(--muted-foreground)">&#9675;</span>',pc=p.tasks.filter(function(t){return t.status==='passed'}).length;
html+='<div class="phase '+cls+'"><div class="phase-header"><span class="phase-icon">'+icon+'</span><span class="phase-name">'+esc(p.name)+'</span><span class="phase-meta">'+pc+'/'+p.total;
if(p.gate&&p.gate!=='idle'&&p.gate!=='done')html+=' <span class="gate-badge '+gateClass(p.gate)+'">'+esc(p.gate)+(p.gateAttempts>0?' x'+p.gateAttempts:'')+'</span>';
if(p.elapsed>0)html+=' '+elapsed(p.elapsed);html+='</span></div>';
if(p.isCurrent||p.allDone){html+='<div class="tasks">';for(var j=0;j<p.tasks.length;j++){var t=p.tasks[j];html+='<div class="task"><span class="task-icon">'+statusIcon(t.status)+'</span><span class="task-id">'+esc(t.id)+'</span><span class="task-title">'+esc(t.title)+'</span>';if(t.complianceScore>0)html+='<span class="task-score '+scoreClass(t.complianceScore)+'">'+t.complianceScore+'%</span>';if(t.attempts>1)html+='<span class="task-attempts">x'+t.attempts+'</span>';html+='</div>'}html+='</div>'}html+='</div>'}html+='</div>';
var agents=d.activeAgents||(d.activeAgent?[d.activeAgent]:[]);if(agents.length>0){html+='<div class="agents-section"><h2>Active Agents</h2>';for(var k=0;k<agents.length;k++){var a=agents[k];html+='<div class="agent"><span class="agent-spinner" style="color:var(--primary)">&#9684;</span><span class="agent-name">'+esc(a.name)+'</span><span class="agent-model">'+esc(a.model)+'</span></div>'}html+='</div>'}
if(d.log&&d.log.length>0){var show=d.log.slice(-15);html+='<div class="log-section"><h2>Recent Activity</h2>';for(var m=0;m<show.length;m++)html+='<div class="log-entry '+logClass(show[m])+'">'+esc(show[m])+'</div>';html+='</div>'}
document.getElementById('app').innerHTML=html;document.getElementById('updated').textContent=age<5?'live':'updated '+age+'s ago'}
function esc(s){if(!s)return '';var d=document.createElement('div');d.textContent=s;return d.innerHTML}
setInterval(function(){if(state)render()},1000);
</script></body></html>`;

