#!/usr/bin/env node
// Pipeline Control Center — Web Server with SSE dashboard + Agent Steering
// Usage: pipeline-dashboard-web [project-dir] [--port PORT]

import http from "node:http";
import net from "node:net";
import fs from "node:fs";
import path from "node:path";
import { execSync as execSyncImport } from "node:child_process";

const args = process.argv.slice(2);
let projectDir = process.cwd();
let port = 3141;
let controlPort = 3142;

for (let i = 0; i < args.length; i++) {
	if (args[i] === "--port" && args[i + 1]) { port = parseInt(args[i + 1], 10); i++; }
	else if (args[i] === "--control-port" && args[i + 1]) { controlPort = parseInt(args[i + 1], 10); i++; }
	else if (!args[i].startsWith("-")) projectDir = args[i];
}

const stateFile = path.join(projectDir, ".pi", "pipeline-logs", "pipeline-state.json");
const steerFile = path.join(projectDir, ".pi", "pipeline-logs", "pipeline-steer.json");

function readState() {
	try { return JSON.parse(fs.readFileSync(stateFile, "utf-8")); }
	catch { return null; }
}

// ── SSE Clients ──
const sseClients = new Set();
function broadcastState() {
	const state = readState();
	if (!state) return;
	const msg = `data: ${JSON.stringify(state)}\n\n`;
	for (const res of sseClients) {
		try { res.write(msg); } catch { sseClients.delete(res); }
	}
}

// ── Steer Log SSE ──
const steerLogClients = new Set();
const steerLog = [];
function logSteer(entry) {
	const ts = new Date().toISOString().slice(11, 19);
	const line = { ts, ...entry };
	steerLog.push(line);
	if (steerLog.length > 200) steerLog.shift();
	const msg = `data: ${JSON.stringify(line)}\n\n`;
	for (const res of steerLogClients) {
		try { res.write(msg); } catch { steerLogClients.delete(res); }
	}
}

// ── Control Socket (TCP JSON-RPC for agent steering) ──
// Agents register via: {"type":"register","agentId":"...","sessionKey":"..."}
// Steer commands:      {"type":"steer","agentId":"...","message":"..."}
// Follow-up:           {"type":"follow_up","agentId":"...","message":"..."}
// Abort:               {"type":"abort","agentId":"..."}
// List agents:         {"type":"list_agents"}

const registeredAgents = new Map(); // agentId -> { sessionKey, socket, info }

const controlServer = net.createServer((socket) => {
	let buf = "";
	socket.setEncoding("utf-8");
	socket.on("data", (chunk) => {
		buf += chunk;
		let nl;
		while ((nl = buf.indexOf("\n")) !== -1) {
			const line = buf.slice(0, nl).trim();
			buf = buf.slice(nl + 1);
			if (!line) continue;
			try {
				const cmd = JSON.parse(line);
				handleControlCommand(cmd, socket);
			} catch (e) {
				socket.write(JSON.stringify({ success: false, error: "parse error: " + e.message }) + "\n");
			}
		}
	});
	socket.on("error", () => {});
	socket.on("close", () => {
		// Unregister any agents owned by this socket
		for (const [id, agent] of registeredAgents) {
			if (agent.socket === socket) {
				registeredAgents.delete(id);
				logSteer({ type: "unregister", agentId: id, reason: "disconnect" });
			}
		}
	});
});

function handleControlCommand(cmd, socket) {
	switch (cmd.type) {
		case "register": {
			registeredAgents.set(cmd.agentId, {
				sessionKey: cmd.sessionKey || cmd.agentId,
				socket,
				stdin: null, // will be set if agent provides a pipe
				info: cmd.info || {},
				registeredAt: Date.now(),
			});
			logSteer({ type: "register", agentId: cmd.agentId, info: cmd.info });
			socket.write(JSON.stringify({ success: true, command: "register" }) + "\n");
			break;
		}
		case "steer":
		case "follow_up":
		case "abort": {
			const agentId = cmd.agentId;
			const agent = registeredAgents.get(agentId);
			if (!agent) {
				socket.write(JSON.stringify({ success: false, error: "agent not found: " + agentId }) + "\n");
				logSteer({ type: cmd.type, agentId, status: "error", error: "agent not found" });
				return;
			}
			// Forward RPC command to agent's registered socket
			const rpcCmd = cmd.type === "abort"
				? { type: "abort" }
				: { type: cmd.type, message: cmd.message || "" };
			try {
				agent.socket.write(JSON.stringify({ forward: true, ...rpcCmd }) + "\n");
				logSteer({ type: cmd.type, agentId, message: cmd.message, status: "sent" });
				socket.write(JSON.stringify({ success: true, command: cmd.type }) + "\n");
			} catch (e) {
				socket.write(JSON.stringify({ success: false, error: "failed to forward: " + e.message }) + "\n");
				logSteer({ type: cmd.type, agentId, status: "error", error: e.message });
			}
			break;
		}
		case "unregister": {
			const id = cmd.agentId;
			if (registeredAgents.has(id)) {
				registeredAgents.delete(id);
				logSteer({ type: "unregister", agentId: id, reason: cmd.reason || "completed" });
			}
			socket.write(JSON.stringify({ success: true, command: "unregister" }) + "\n");
			break;
		}
		case "list_agents": {
			const agents = [];
			for (const [id, agent] of registeredAgents) {
				agents.push({ agentId: id, sessionKey: agent.sessionKey, info: agent.info, registeredAt: agent.registeredAt });
			}
			socket.write(JSON.stringify({ success: true, command: "list_agents", agents }) + "\n");
			break;
		}
		default:
			socket.write(JSON.stringify({ success: false, error: "unknown command: " + cmd.type }) + "\n");
	}
}

// Also write steer commands to a file so the pipeline extension can poll it
function writeSteerFile(cmd) {
	try {
		const dir = path.dirname(steerFile);
		if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
		fs.writeFileSync(steerFile, JSON.stringify({ ...cmd, ts: Date.now() }));
	} catch {}
}

// ── File Watcher ──
let lastMtime = 0;
setInterval(() => {
	try {
		const stat = fs.statSync(stateFile);
		if (stat.mtimeMs !== lastMtime) {
			lastMtime = stat.mtimeMs;
			broadcastState();
		}
	} catch {}
}, 500);

// ── HTTP Server ──
const server = http.createServer((req, res) => {
	// API
	if (req.url === "/api/state") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		const state = readState();
		res.end(state ? JSON.stringify(state) : "null");
		return;
	}
	if (req.url === "/api/agents") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		const agents = [];
		for (const [id, agent] of registeredAgents) {
			agents.push({ agentId: id, sessionKey: agent.sessionKey, info: agent.info });
		}
		// Also include agents from pipeline state
		const state = readState();
		if (state && state.activeAgents) {
			for (const a of state.activeAgents) {
				if (!agents.find(x => x.sessionKey === a.name)) {
					agents.push({ agentId: a.name, sessionKey: a.name, info: { model: a.model, hint: a.hint } });
				}
			}
		}
		res.end(JSON.stringify({ agents }));
		return;
	}
	if (req.url === "/api/steer-log") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		res.end(JSON.stringify({ log: steerLog }));
		return;
	}
	// Steer command via HTTP POST
	if (req.url === "/api/steer" && req.method === "POST") {
		let body = "";
		req.on("data", c => body += c);
		req.on("end", () => {
			res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
			try {
				const cmd = JSON.parse(body);
				writeSteerFile(cmd);
				logSteer({ type: cmd.type || "steer", agentId: cmd.agentId || "pipeline", message: cmd.message, status: "queued-via-http" });
				// Forward to control socket if agent registered
				if (cmd.agentId && registeredAgents.has(cmd.agentId)) {
					const agent = registeredAgents.get(cmd.agentId);
					const rpcCmd = cmd.type === "abort" ? { type: "abort" } : { type: cmd.type || "steer", message: cmd.message };
					agent.socket.write(JSON.stringify({ forward: true, ...rpcCmd }) + "\n");
					logSteer({ type: cmd.type || "steer", agentId: cmd.agentId, message: cmd.message, status: "forwarded" });
				}
				res.end(JSON.stringify({ success: true }));
			} catch (e) {
				res.end(JSON.stringify({ success: false, error: e.message }));
			}
		});
		return;
	}
	// SSE
	if (req.url === "/events") {
		res.writeHead(200, { "Content-Type": "text/event-stream", "Cache-Control": "no-cache", "Connection": "keep-alive", "Access-Control-Allow-Origin": "*" });
		res.write("\n");
		sseClients.add(res);
		const state = readState();
		if (state) res.write(`data: ${JSON.stringify(state)}\n\n`);
		req.on("close", () => sseClients.delete(res));
		return;
	}
	if (req.url === "/steer-events") {
		res.writeHead(200, { "Content-Type": "text/event-stream", "Cache-Control": "no-cache", "Connection": "keep-alive", "Access-Control-Allow-Origin": "*" });
		res.write("\n");
		steerLogClients.add(res);
		// Send history
		for (const entry of steerLog) {
			res.write(`data: ${JSON.stringify(entry)}\n\n`);
		}
		req.on("close", () => steerLogClients.delete(res));
		return;
	}
	// GitHub Issue API — fetch issue details via gh CLI
	const issueMatch = req.url.match(/^\/api\/issue\/(\d+)$/);
	if (issueMatch) {
		const issueNum = issueMatch[1];
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		try {
			const issueJson = execSyncImport(
				`gh issue view ${issueNum} --json number,title,body,state,labels,comments,assignees`,
				{ encoding: "utf-8", cwd: projectDir, timeout: 15000 },
			).trim();
			const issue = JSON.parse(issueJson);
			// Extract sub-issue references from body (e.g., #123, Part of #45)
			const subIssueRefs = [];
			const bodyText = issue.body || "";
			const refMatches = bodyText.matchAll(/#(\d+)/g);
			for (const m of refMatches) {
				const num = parseInt(m[1], 10);
				if (num !== parseInt(issueNum, 10) && !subIssueRefs.includes(num)) subIssueRefs.push(num);
			}
			// Also scan comments for issue refs
			for (const c of (issue.comments || [])) {
				const cMatches = (c.body || "").matchAll(/#(\d+)/g);
				for (const m of cMatches) {
					const num = parseInt(m[1], 10);
					if (num !== parseInt(issueNum, 10) && !subIssueRefs.includes(num)) subIssueRefs.push(num);
				}
			}
			res.end(JSON.stringify({
				number: issue.number,
				title: issue.title,
				body: issue.body || "",
				state: issue.state,
				labels: (issue.labels || []).map(l => l.name || l),
				assignees: (issue.assignees || []).map(a => a.login || a),
				comments: (issue.comments || []).map(c => ({
					author: c.author?.login || c.author || "",
					body: c.body || "",
					createdAt: c.createdAt || "",
				})),
				subIssueRefs,
			}));
		} catch (e) {
			res.end(JSON.stringify({ error: "Failed to fetch issue: " + e.message }));
		}
		return;
	}

	// Sessions API — list session files (.jsonl pi sessions + legacy .log)
	if (req.url === "/api/sessions") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		const logDir = path.join(projectDir, ".pi", "pipeline-logs");
		try {
			const files = fs.readdirSync(logDir).filter(f => f.endsWith(".jsonl") || f.endsWith(".log")).sort();
			// Deduplicate: if both .jsonl and .log exist for same name, prefer .jsonl
			const seen = new Set();
			const deduped = [];
			for (const f of files) {
				const name = f.replace(/\.(jsonl|log)$/, "");
				if (seen.has(name)) continue;
				seen.add(name);
				deduped.push(f);
			}
			const sessions = deduped.map(f => {
				const stat = fs.statSync(path.join(logDir, f));
				const name = f.replace(/\.(jsonl|log)$/, "");
				const format = f.endsWith(".jsonl") ? "pi-session" : "legacy";
				let model = "", startTs = "";
				// Read metadata from first lines
				try {
					const fd = fs.openSync(path.join(logDir, f), "r");
					const buf = Buffer.alloc(4096);
					const bytesRead = fs.readSync(fd, buf, 0, 4096, 0);
					fs.closeSync(fd);
					const head = buf.slice(0, bytesRead).toString("utf-8");
					for (const line of head.split("\n")) {
						if (!line.startsWith("{")) continue;
						try {
							const j = JSON.parse(line);
							if (j.type === "session") startTs = j.timestamp || "";
							if (j.type === "model_change") model = j.modelId || "";
							// Legacy RPC format
							if (j.type === "message_start" && j.message?.role === "assistant") {
								model = model || j.message.model || "";
							}
							// Pi session format
							if (j.type === "message" && j.message?.role === "assistant") {
								model = model || j.message.model || "";
							}
							if (model && startTs) break;
						} catch {}
					}
				} catch {}
				// Check for meta sidecar
				let meta = null;
				const metaPath = path.join(logDir, name + ".meta.json");
				try { if (fs.existsSync(metaPath)) meta = JSON.parse(fs.readFileSync(metaPath, "utf-8")); } catch {}
				return { name, file: f, format, size: stat.size, mtime: stat.mtimeMs, model, startTs, meta };
			});
			res.end(JSON.stringify({ sessions }));
		} catch (e) {
			res.end(JSON.stringify({ sessions: [], error: e.message }));
		}
		return;
	}
	// Export session as HTML via pi --export
	if (req.url.startsWith("/api/export/")) {
		const name = decodeURIComponent(req.url.slice("/api/export/".length));
		const logDir = path.join(projectDir, ".pi", "pipeline-logs");
		// Find the session file (.jsonl preferred)
		let sessionPath = path.join(logDir, name + ".jsonl");
		if (!fs.existsSync(sessionPath)) sessionPath = path.join(logDir, name + ".log");
		if (!fs.existsSync(sessionPath)) {
			res.writeHead(404, { "Content-Type": "application/json" });
			res.end(JSON.stringify({ error: "not found" }));
			return;
		}
		const tmpHtml = path.join(logDir, name + ".export.html");
		try {
			execSyncImport(`pi --export "${sessionPath}" "${tmpHtml}"`, { timeout: 15000, stdio: "ignore" });
			const html = fs.readFileSync(tmpHtml, "utf-8");
			res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
			res.end(html);
			try { fs.unlinkSync(tmpHtml); } catch {}
		} catch (e) {
			res.writeHead(500, { "Content-Type": "application/json" });
			res.end(JSON.stringify({ error: "export failed: " + e.message }));
		}
		return;
	}
	// Session detail API — parse session into chat events
	if (req.url.startsWith("/api/session/")) {
		const name = decodeURIComponent(req.url.slice("/api/session/".length));
		const logDir = path.join(projectDir, ".pi", "pipeline-logs");
		// Find session file (.jsonl preferred, fallback to .log)
		let logFile = path.join(logDir, name + ".jsonl");
		if (!fs.existsSync(logFile)) logFile = path.join(logDir, name + ".log");
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		if (!fs.existsSync(logFile)) { res.end(JSON.stringify({ error: "not found" })); return; }
		// Load meta sidecar if exists
		let meta = null;
		try { const mp = path.join(logDir, name + ".meta.json"); if (fs.existsSync(mp)) meta = JSON.parse(fs.readFileSync(mp, "utf-8")); } catch {}
		try {
			const raw = fs.readFileSync(logFile, "utf-8");
			const lines = raw.split("\n");

			// Detect format: pi-session (.jsonl), legacy RPC, or plain text
			let format = "plaintext"; // default
			for (const line of lines) {
				const trimmed = line.trim();
				if (!trimmed || trimmed.startsWith("──")) continue;
				if (trimmed.startsWith("{")) {
					try {
						const j = JSON.parse(trimmed);
						// Pi session format has type:"session" then type:"message"
						// RPC format has type:"session" then type:"agent_start" / type:"message_start"
						if (j.type === "session") {
							format = "detect-next"; continue;
						}
						if (j.type === "model_change" || j.type === "thinking_level_change") { format = "pi-session"; break; }
						if (j.type === "message" && j.message) { format = "pi-session"; break; }
						if (j.type === "agent_start" || j.type === "message_start") { format = "rpc"; break; }
						format = "rpc"; // fallback for json
					} catch { format = "rpc"; }
				}
				break;
			}
			if (format === "detect-next") format = "pi-session"; // session line only, assume pi format

			const events = [];
			let sessionMeta = null;

			if (format === "pi-session") {
				// ── Pi native session format (.jsonl) ──
				for (const line of lines) {
					if (!line.trim() || !line.startsWith("{")) continue;
					let j;
					try { j = JSON.parse(line); } catch { continue; }

					if (j.type === "session") {
						sessionMeta = { id: j.id, cwd: j.cwd, timestamp: j.timestamp, version: j.version };
						continue;
					}
					if (j.type === "model_change") {
						// Track model for context
						continue;
					}
					if (j.type === "message" && j.message) {
						const msg = j.message;
						if (msg.role === "user") {
							let text = "";
							for (const c of (msg.content || [])) {
								if (c.type === "text") text += c.text;
							}
							if (text) events.push({ type: "user", text, timestamp: msg.timestamp || j.timestamp });
						} else if (msg.role === "assistant") {
							// Extract thinking + text + tool calls
							for (const c of (msg.content || [])) {
								if (c.type === "thinking" && c.thinking) {
									events.push({ type: "thinking", text: c.thinking, model: msg.model });
								}
								if (c.type === "text" && c.text) {
									events.push({ type: "assistant", text: c.text, model: msg.model, provider: msg.provider });
								}
								if (c.type === "toolCall") {
									events.push({ type: "tool_start", toolName: c.name, toolCallId: c.id, args: typeof c.arguments === "string" ? JSON.parse(c.arguments || "{}") : (c.arguments || {}) });
								}
							}
							if (msg.usage) {
								events.push({ type: "usage", usage: msg.usage, model: msg.model, timestamp: msg.timestamp || j.timestamp });
							}
						} else if (msg.role === "toolResult") {
							let resultText = "";
							for (const c of (msg.content || [])) {
								if (c.type === "text") resultText += c.text;
							}
							events.push({ type: "tool_end", toolName: msg.toolName, toolCallId: msg.toolCallId, result: resultText, isError: msg.isError });
						}
						continue;
					}
				}
			} else if (format === "plaintext") {
				// ── Plain text log parser ──
				let headerParsed = false;
				let currentText = "";
				let inTool = false;
				let toolName = "";
				let toolContent = "";

				for (const line of lines) {
					// Header line
					if (!headerParsed && line.includes("──") && line.includes("|")) {
						const parts = line.replace(/[─]/g, "").trim().split("|").map(s => s.trim());
						if (parts.length >= 3) {
							events.push({ type: "header", role: parts[0], session: parts[1], timestamp: parts[2] });
							sessionMeta = { timestamp: parts[2] };
						}
						headerParsed = true;
						continue;
					}
					// Tool blocks: [TOOL] name ... [/TOOL]
					if (line.trim().startsWith("[TOOL]")) {
						// Flush current text
						if (currentText.trim()) {
							events.push({ type: "assistant", text: currentText.trim() });
							currentText = "";
						}
						toolName = line.trim().replace(/^\[TOOL\]\s*/, "").trim();
						inTool = true;
						toolContent = "";
						continue;
					}
					if (line.trim() === "[/TOOL]") {
						events.push({ type: "tool_start", toolName: toolName || "tool", toolCallId: "pt-" + events.length, args: {} });
						if (toolContent.trim()) {
							events.push({ type: "tool_end", toolName: toolName || "tool", toolCallId: "pt-" + (events.length - 1), result: toolContent.trim(), isError: false });
						} else {
							events.push({ type: "tool_end", toolName: toolName || "tool", toolCallId: "pt-" + (events.length - 1), result: "(output omitted)", isError: false });
						}
						inTool = false;
						toolName = "";
						toolContent = "";
						continue;
					}
					if (inTool) {
						toolContent += line + "\n";
						continue;
					}
					currentText += line + "\n";
				}
				// Flush remaining
				if (currentText.trim()) {
					events.push({ type: "assistant", text: currentText.trim() });
				}
			} else {
				// ── JSON-RPC log parser ──
				let currentThinking = "";
				let currentText = "";
				let currentModel = "";
				let currentProvider = "";
				let agentEndData = null;

				for (const line of lines) {
					if (!line.startsWith("{")) {
						if (line.includes("──") && line.includes("|")) {
							const parts = line.replace(/[─]/g, "").trim().split("|").map(s => s.trim());
							if (parts.length >= 3) {
								events.push({ type: "header", role: parts[0], session: parts[1], timestamp: parts[2] });
							}
						}
						continue;
					}
					let j;
					try { j = JSON.parse(line); } catch { continue; }

					if (j.type === "session") {
						sessionMeta = { id: j.id, cwd: j.cwd, timestamp: j.timestamp, version: j.version };
						continue;
					}
					if (j.type === "message_start") {
						const msg = j.message;
						if (msg?.role === "user" && msg.content?.[0]?.text) {
							events.push({ type: "user", text: msg.content[0].text, timestamp: msg.timestamp });
						}
						if (msg?.role === "assistant") {
							currentModel = msg.model || "";
							currentProvider = msg.provider || "";
							currentThinking = "";
							currentText = "";
						}
						continue;
					}
					if (j.type === "message_update") {
						const ev = j.assistantMessageEvent;
						if (!ev) continue;
						if (ev.type === "thinking_delta") {
							currentThinking += ev.delta || "";
						} else if (ev.type === "text_delta") {
							currentText += ev.delta || "";
						} else if (ev.type === "thinking_end") {
							if (currentThinking) {
								events.push({ type: "thinking", text: currentThinking, model: currentModel });
								currentThinking = "";
							}
						} else if (ev.type === "text_end") {
							if (currentText) {
								events.push({ type: "assistant", text: currentText, model: currentModel, provider: currentProvider });
								currentText = "";
							}
						}
						continue;
					}
					if (j.type === "tool_execution_start") {
						events.push({ type: "tool_start", toolName: j.toolName, toolCallId: j.toolCallId, args: j.args });
						continue;
					}
					if (j.type === "tool_execution_end") {
						let resultText = "";
						if (j.result?.content?.[0]?.text) resultText = j.result.content[0].text;
						events.push({ type: "tool_end", toolName: j.toolName, toolCallId: j.toolCallId, result: resultText, isError: j.isError });
						continue;
					}
					if (j.type === "message_end") {
						if (currentThinking) {
							events.push({ type: "thinking", text: currentThinking, model: currentModel });
							currentThinking = "";
						}
						if (currentText) {
							events.push({ type: "assistant", text: currentText, model: currentModel, provider: currentProvider });
							currentText = "";
						}
						const msg = j.message;
						if (msg?.role === "assistant" && msg.usage) {
							events.push({ type: "usage", usage: msg.usage, model: msg.model, timestamp: msg.timestamp });
						}
						continue;
					}
					if (j.type === "agent_end") {
						const lastMsg = j.messages?.[j.messages.length - 1];
						agentEndData = {
							type: "agent_end",
							usage: lastMsg?.usage,
							model: lastMsg?.model,
							stopReason: lastMsg?.stopReason,
							timestamp: lastMsg?.timestamp,
						};
						continue;
					}
				}
				if (agentEndData) events.push(agentEndData);
			}
			res.end(JSON.stringify({ session: sessionMeta, events, meta, format, exportUrl: "/api/export/" + encodeURIComponent(name) }));
		} catch (e) {
			res.end(JSON.stringify({ error: e.message }));
		}
		return;
	}
	// Pages
	if (req.url === "/dashboard") {
		res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
		res.end(DASHBOARD_HTML);
		return;
	}
	if (req.url === "/steer") {
		res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
		res.end(STEER_HTML);
		return;
	}
	if (req.url === "/sessions" || req.url.startsWith("/sessions?")) {
		res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
		res.end(SESSIONS_HTML);
		return;
	}
	// Home
	res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
	res.end(HOME_HTML);
});

server.listen(port, () => {
	console.log(`Pipeline Control Center: http://localhost:${port}`);
	console.log(`  Dashboard: http://localhost:${port}/dashboard`);
	console.log(`  Steer:     http://localhost:${port}/steer`);
	console.log(`  Sessions:  http://localhost:${port}/sessions`);
	console.log(`  Control:   tcp://localhost:${controlPort}`);
	console.log(`  Watching:  ${stateFile}`);
	console.log(`  Press Ctrl+C to stop\n`);
});

controlServer.listen(controlPort, () => {
	console.log(`Control socket listening on port ${controlPort}`);
});

