#!/usr/bin/env node
// Pipeline Dashboard — Web Server with WebSocket live updates
// Usage: pipeline-dashboard-web [project-dir] [--port PORT]

import http from "node:http";
import crypto from "node:crypto";
import fs from "node:fs";
import path from "node:path";

const args = process.argv.slice(2);
let projectDir = process.cwd();
let port = 3141;

for (let i = 0; i < args.length; i++) {
	if (args[i] === "--port" && args[i + 1]) { port = parseInt(args[i + 1], 10); i++; }
	else if (!args[i].startsWith("-")) projectDir = args[i];
}

const stateFile = path.join(projectDir, ".pi", "pipeline-logs", "pipeline-state.json");

function readState() {
	try { return JSON.parse(fs.readFileSync(stateFile, "utf-8")); }
	catch { return null; }
}

// ── WebSocket ──
const wsClients = new Set();

function broadcastState() {
	const state = readState();
	if (!state) return;
	const msg = JSON.stringify(state);
	for (const ws of wsClients) {
		try { wsSend(ws, msg); } catch { wsClients.delete(ws); }
	}
}

function wsSend(socket, data) {
	const buf = Buffer.from(data);
	let frame;
	if (buf.length < 126) {
		frame = Buffer.alloc(2 + buf.length);
		frame[0] = 0x81;
		frame[1] = buf.length;
		buf.copy(frame, 2);
	} else if (buf.length < 65536) {
		frame = Buffer.alloc(4 + buf.length);
		frame[0] = 0x81;
		frame[1] = 126;
		frame.writeUInt16BE(buf.length, 2);
		buf.copy(frame, 4);
	} else {
		frame = Buffer.alloc(10 + buf.length);
		frame[0] = 0x81;
		frame[1] = 127;
		frame.writeBigUInt64BE(BigInt(buf.length), 2);
		buf.copy(frame, 10);
	}
	socket.write(frame);
}

function wsParseFrame(buf) {
	if (buf.length < 2) return null;
	const masked = (buf[1] & 0x80) !== 0;
	let len = buf[1] & 0x7f;
	let offset = 2;
	if (len === 126) { len = buf.readUInt16BE(2); offset = 4; }
	else if (len === 127) { len = Number(buf.readBigUInt64BE(2)); offset = 10; }
	if (masked) {
		const mask = buf.slice(offset, offset + 4);
		offset += 4;
		const payload = buf.slice(offset, offset + len);
		for (let i = 0; i < payload.length; i++) payload[i] ^= mask[i % 4];
		return { opcode: buf[0] & 0x0f, payload };
	}
	return { opcode: buf[0] & 0x0f, payload: buf.slice(offset, offset + len) };
}

// ── File Watcher ──
let lastMtime = 0;
setInterval(() => {
	try {
		const stat = fs.statSync(stateFile);
		if (stat.mtimeMs !== lastMtime) {
			lastMtime = stat.mtimeMs;
			broadcastState();
		}
	} catch {}
}, 500);

// ── HTTP Server ──
const server = http.createServer((req, res) => {
	if (req.url === "/api/state") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
		const state = readState();
		res.end(state ? JSON.stringify(state) : "null");
		return;
	}
	res.writeHead(200, { "Content-Type": "text/html; charset=utf-8" });
	res.end(HTML);
});

server.on("upgrade", (req, socket) => {
	if (req.url !== "/ws") { socket.destroy(); return; }
	const key = req.headers["sec-websocket-key"];
	const accept = crypto.createHash("sha1").update(key + "258EAFA5-E914-47DA-95CA-5AB9CF11F85B").digest("base64");
	socket.write(
		"HTTP/1.1 101 Switching Protocols\r\n" +
		"Upgrade: websocket\r\n" +
		"Connection: Upgrade\r\n" +
		`Sec-WebSocket-Accept: ${accept}\r\n\r\n`
	);
	wsClients.add(socket);
	// Send initial state
	const state = readState();
	if (state) wsSend(socket, JSON.stringify(state));

	socket.on("data", (buf) => {
		const frame = wsParseFrame(buf);
		if (!frame) return;
		if (frame.opcode === 0x08) { wsClients.delete(socket); socket.end(); }
		if (frame.opcode === 0x09) { // ping
			const pong = Buffer.alloc(2); pong[0] = 0x8a; pong[1] = 0;
			socket.write(pong);
		}
	});
	socket.on("close", () => wsClients.delete(socket));
	socket.on("error", () => wsClients.delete(socket));
});

server.listen(port, () => {
	console.log(`Pipeline Dashboard: http://localhost:${port}`);
	console.log(`Watching: ${stateFile}`);
	console.log(`Press Ctrl+C to stop\n`);
});

// ── HTML Dashboard ──
const HTML = `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Pipeline Dashboard</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
--bg:#0d1117;--surface:#161b22;--border:#30363d;--text:#e6edf3;
--dim:#7d8590;--accent:#58a6ff;--green:#3fb950;--red:#f85149;
--yellow:#d29922;--cyan:#39d2c0;--blue:#58a6ff;
}
body{font-family:'SF Mono','Fira Code',monospace;background:var(--bg);color:var(--text);min-height:100vh;padding:0}
.container{max-width:1200px;margin:0 auto;padding:16px}
header{text-align:center;padding:24px 0 16px;border-bottom:1px solid var(--border)}
header h1{font-size:1.4rem;letter-spacing:2px;color:var(--accent)}
.status-bar{display:flex;align-items:center;gap:16px;padding:12px 0;flex-wrap:wrap}
.status-dot{width:10px;height:10px;border-radius:50%;display:inline-block}
.status-dot.running{background:var(--green);box-shadow:0 0 8px var(--green);animation:pulse 1.5s infinite}
.status-dot.idle{background:var(--dim)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.badge{padding:2px 8px;border-radius:4px;font-size:.75rem;background:var(--surface);border:1px solid var(--border)}
.phases{margin-top:16px}
.phase{background:var(--surface);border:1px solid var(--border);border-radius:8px;margin-bottom:8px;overflow:hidden}
.phase-header{padding:12px 16px;display:flex;align-items:center;gap:10px;cursor:pointer}
.phase-header:hover{background:#1c2128}
.phase-icon{font-size:1rem;width:20px;text-align:center}
.phase-name{flex:1;font-weight:600;font-size:.9rem}
.phase-meta{font-size:.75rem;color:var(--dim);display:flex;gap:8px;align-items:center}
.phase.current .phase-header{border-left:3px solid var(--accent)}
.phase.done .phase-header{border-left:3px solid var(--green)}
.phase.done .phase-name{color:var(--green)}
.tasks{padding:0 16px 12px 42px}
.task{display:flex;align-items:center;gap:8px;padding:4px 0;font-size:.8rem}
.task-icon{width:16px;text-align:center}
.task-id{color:var(--dim);min-width:30px}
.task-title{flex:1}
.task-score{font-weight:600;min-width:40px;text-align:right}
.task-score.high{color:var(--green)}
.task-score.med{color:var(--yellow)}
.task-score.low{color:var(--red)}
.task-attempts{color:var(--dim);font-size:.7rem;min-width:24px}
.log-section{margin-top:16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px}
.log-section h2{font-size:.85rem;color:var(--accent);margin-bottom:12px}
.log-entry{font-size:.75rem;padding:2px 0;color:var(--dim);word-break:break-all}
.log-entry.highlight{color:var(--text)}
.log-entry.pass{color:var(--green)}
.log-entry.fail{color:var(--red)}
.log-entry.phase-start{color:var(--accent);font-weight:600}
.agents-section{margin-top:16px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px}
.agents-section h2{font-size:.85rem;color:var(--accent);margin-bottom:12px}
.agent{display:flex;align-items:center;gap:10px;padding:6px 0;font-size:.8rem}
.agent-spinner{color:var(--blue);animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.agent-name{font-weight:600;min-width:120px;text-transform:uppercase}
.agent-model{color:var(--dim);font-size:.75rem}
.progress-bar{height:4px;background:var(--border);border-radius:2px;margin-top:4px;overflow:hidden}
.progress-fill{height:100%;background:var(--green);border-radius:2px;transition:width .3s}
.gate-badge{font-size:.65rem;padding:1px 6px;border-radius:3px;font-weight:600}
.gate-badge.build{background:#2d1b00;color:var(--yellow);border:1px solid var(--yellow)}
.gate-badge.fix{background:#2d1b00;color:var(--yellow);border:1px solid var(--yellow)}
.gate-badge.compliance{background:#0a2a2a;color:var(--cyan);border:1px solid var(--cyan)}
.gate-badge.done{background:#0a2a0a;color:var(--green);border:1px solid var(--green)}
.gate-badge.error{background:#2a0a0a;color:var(--red);border:1px solid var(--red)}
.no-data{text-align:center;padding:48px;color:var(--dim);font-size:.9rem}
.updated{font-size:.7rem;color:var(--dim);text-align:right;padding:8px 0}
@media(max-width:600px){
.container{padding:8px}
.phase-header{padding:8px 12px}
.tasks{padding:0 12px 8px 32px}
.status-bar{flex-direction:column;align-items:flex-start;gap:8px}
}
</style>
</head>
<body>
<div class="container">
<header><h1>⬡ PIPELINE DASHBOARD</h1></header>
<div id="app"><div class="no-data">Connecting...</div></div>
<div class="updated" id="updated"></div>
</div>
<script>
let state = null;
let ws;

function connect() {
const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
ws = new WebSocket(proto + '//' + location.host + '/ws');
ws.onmessage = (e) => { state = JSON.parse(e.data); render(); };
ws.onclose = () => setTimeout(connect, 2000);
ws.onerror = () => ws.close();
}
connect();

function statusIcon(s) {
switch(s) {
case 'passed': return '<span style="color:var(--green)">✓</span>';
case 'building': return '<span style="color:var(--blue)" class="agent-spinner">◐</span>';
case 'scoring': return '<span style="color:var(--cyan)" class="agent-spinner">◐</span>';
case 'failed': return '<span style="color:var(--red)">✗</span>';
default: return '<span style="color:var(--dim)">○</span>';
}
}

function gateClass(g) {
if (g.includes('build') || g.includes('fix')) return 'build';
if (g.includes('compliance') || g.includes('review')) return 'compliance';
if (g === 'done') return 'done';
if (g === 'error') return 'error';
return 'build';
}

function elapsed(ms) {
if (!ms) return '';
const s = Math.floor(ms/1000), m = Math.floor(s/60), h = Math.floor(m/60);
if (h > 0) return h+'h '+m%60+'m '+s%60+'s';
if (m > 0) return m+'m '+s%60+'s';
return s+'s';
}

function scoreClass(s) { return s >= 95 ? 'high' : s >= 80 ? 'med' : 'low'; }

function logClass(entry) {
if (entry.includes('PASSED') || entry.includes('fixed at') || entry.includes('done')) return 'pass';
if (entry.includes('FAILED') || entry.includes('could not reach') || entry.includes('error')) return 'fail';
if (entry.startsWith('===') || entry.includes('Phase complete') || entry.includes('Epic')) return 'phase-start';
return '';
}

function render() {
if (!state) { document.getElementById('app').innerHTML = '<div class="no-data">Waiting for pipeline state...</div>'; return; }
const d = state;
const age = Math.round((Date.now() - d.ts) / 1000);

let html = '<div class="status-bar">';
html += '<span class="status-dot '+(d.running?'running':'idle')+'"></span>';
html += '<strong>'+(d.running?'RUNNING':'IDLE')+'</strong>';
if (d.branch) html += '<span class="badge">'+esc(d.branch)+'</span>';
html += '</div>';

// Progress bar
const total = d.phases.reduce((a,p) => a+p.total, 0);
const done = d.phases.reduce((a,p) => a+p.tasks.filter(t=>t.status==='passed').length, 0);
const pct = total ? Math.round(done/total*100) : 0;
html += '<div class="progress-bar"><div class="progress-fill" style="width:'+pct+'%"></div></div>';
html += '<div style="font-size:.7rem;color:var(--dim);margin-top:4px">'+done+'/'+total+' tasks ('+pct+'%)</div>';

// Phases
html += '<div class="phases">';
for (const p of d.phases) {
const cls = p.allDone ? 'done' : p.isCurrent ? 'current' : '';
const icon = p.allDone ? '<span style="color:var(--green)">✓</span>' : p.isCurrent && d.running ? '<span class="agent-spinner" style="color:var(--blue)">◐</span>' : '<span style="color:var(--dim)">○</span>';
const passedCount = p.tasks.filter(t=>t.status==='passed').length;

html += '<div class="phase '+cls+'">';
html += '<div class="phase-header">';
html += '<span class="phase-icon">'+icon+'</span>';
html += '<span class="phase-name">'+esc(p.name)+'</span>';
html += '<span class="phase-meta">';
html += passedCount+'/'+p.total;
if (p.gate && p.gate !== 'idle' && p.gate !== 'done') html += ' <span class="gate-badge '+gateClass(p.gate)+'">'+esc(p.gate)+(p.gateAttempts>0?' x'+p.gateAttempts:'')+'</span>';
if (p.elapsed > 0) html += ' '+elapsed(p.elapsed);
html += '</span></div>';

if (p.isCurrent || p.allDone) {
html += '<div class="tasks">';
for (const t of p.tasks) {
html += '<div class="task">';
html += '<span class="task-icon">'+statusIcon(t.status)+'</span>';
html += '<span class="task-id">'+esc(t.id)+'</span>';
html += '<span class="task-title">'+esc(t.title)+'</span>';
if (t.complianceScore > 0) html += '<span class="task-score '+scoreClass(t.complianceScore)+'">'+t.complianceScore+'%</span>';
if (t.attempts > 1) html += '<span class="task-attempts">x'+t.attempts+'</span>';
html += '</div>';
}
html += '</div>';
}
html += '</div>';
}
html += '</div>';

// Active agents
const agents = d.activeAgents || (d.activeAgent ? [d.activeAgent] : []);
if (agents.length > 0) {
html += '<div class="agents-section"><h2>Active Agents</h2>';
for (const a of agents) {
html += '<div class="agent">';
html += '<span class="agent-spinner" style="color:var(--blue)">◐</span>';
html += '<span class="agent-name">'+esc(a.name)+'</span>';
html += '<span class="agent-model">'+esc(a.model)+'</span>';
html += '</div>';
}
html += '</div>';
}

// Log
if (d.log && d.log.length > 0) {
const show = d.log.slice(-15);
html += '<div class="log-section"><h2>Recent Activity</h2>';
for (const entry of show) {
html += '<div class="log-entry '+logClass(entry)+'">'+esc(entry)+'</div>';
}
html += '</div>';
}

document.getElementById('app').innerHTML = html;
document.getElementById('updated').textContent = age < 5 ? 'live' : 'updated '+age+'s ago';
}

function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

setInterval(() => { if (state) render(); }, 1000);
</script>
</body>
</html>`;
