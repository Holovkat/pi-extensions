<script>
(() => {
	const PROJECT_DIR = ${JSON.stringify(projectDir)};
	const PROJECT_NAME = ${JSON.stringify(projectName)};
	const STATE_FILE = ${JSON.stringify(stateFile)};
	const CONTROL_PORT = ${JSON.stringify(controlPort)};
	const FILTERS = [
		{ id: 'all', label: 'All', tone: 'info' },
		{ id: 'user', label: 'User', tone: 'info' },
		{ id: 'assistant', label: 'Assistant', tone: 'success' },
		{ id: 'tool', label: 'Tool', tone: 'warning' },
	];
	const USEFUL_COMMANDS = [
		'/blueprint-details',
		'/blueprint-check-alignment',
		'/blueprint-search-history scope',
		'/blueprint-sync-assets',
		'/blueprint-revise [reason]',
	];
	const el = (id) => document.getElementById(id);
	const transcriptDrawer = el('transcriptDrawer');
	const transcriptToggle = el('transcriptToggle');
	const transcriptToggleGlyph = el('transcriptToggleGlyph');
	const transcriptInfoButton = el('transcriptInfoButton');
	const transcriptSummary = el('transcriptSummary');
	const transcriptCountPill = el('transcriptCountPill');
	const transcriptCommandList = el('transcriptCommandList');
	const sessionDrawer = el('sessionDrawer');
	const sessionDrawerScrim = el('sessionDrawerScrim');
	const sessionDrawerClose = el('sessionDrawerClose');
	const sessionContextPanel = el('sessionContextPanel');
	const chat = el('chat');
	const detailOverlay = el('detailOverlay');
	const specialistGrid = el('specialistGrid');
	const scoreCard = el('scoreCard');
	const alignmentCard = el('alignmentCard');
	const assetCard = el('assetCard');
	const artifactCard = el('artifactCard');
	const widgetFooter = el('widgetFooter');
	const activityFeed = el('activityFeed');
	const projectBadge = el('projectBadge');
	const connectionPill = el('connectionPill');
	const projectPill = el('projectPill');
	const boundPill = el('boundPill');
	const sessionPill = el('sessionPill');
	const statusDot = el('statusDot');
	const statusLine = el('statusLine');
	const heroTitle = el('heroTitle');
	const heroCopy = el('heroCopy');
	const actionButtons = el('actionButtons');
	const actionNote = el('actionNote');
	const transcriptFilters = el('transcriptFilters');
	const chatForm = el('chatForm');
	const chatInput = el('chatInput');
	const chatSendButton = el('chatSendButton');
	const chatStatus = el('chatStatus');
	const specialistSubtitle = el('specialistSubtitle');
	let currentState = null;
	let cumulativeChatHistory = [];
	let shouldStickChatToBottom = true;
	let transcriptFilter = localStorage.getItem('pi-blueprint-filter') || 'all';
	let transcriptDrawerOpen = localStorage.getItem('pi-blueprint-transcript-open') === 'true';
	let expandedMessages = new Set();
	let dashboardConnection = 'connecting';
	let chatFeedback = '';
	let chatFeedbackTone = 'info';
	let chatSending = false;
	let sessionDrawerOpen = false;

	function toggleTheme() {
		document.body.classList.toggle('light');
		const light = document.body.classList.contains('light');
		el('theme-btn').textContent = light ? 'Dark' : 'Light';
		localStorage.setItem('pi-blueprint-theme', light ? 'light' : 'dark');
	}
	(function initTheme() {
		const saved = localStorage.getItem('pi-blueprint-theme');
		if (saved === 'light') {
			document.body.classList.add('light');
			el('theme-btn').textContent = 'Dark';
		}
	})();
	el('theme-btn').addEventListener('click', toggleTheme);

	function esc(value) {
		return String(value ?? '')
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	}

	function renderMarkdown(text) {
		return esc(String(text || '')).replace(/\n/g, '<br>');
	}

	function renderQaContent(text) {
		const value = String(text || '');
		if (!/\bQ:\b/.test(value) || !/\bA:\b/.test(value)) return null;
		return '<div class="overlay-value">' + renderMarkdown(value) + '</div>';
	}

	function renderConsultationSections(source) {
		const text = String(source || '');
		if (!/\(iteration \d+\)/.test(text) || !/\bQ:\b/.test(text)) return null;
		return '<div class="overlay-value">' + renderMarkdown(text) + '</div>';
	}

	function compactEmbeddedConsultationHistory(source) {
		const text = String(source || '');
		const marker = '## Previous Specialist Consultations';
		const idx = text.indexOf(marker);
		if (idx === -1) return text;
		const before = text.slice(0, idx).trimEnd();
		const after = text.slice(idx + marker.length).trimStart();
		if (!/(?:###\s*)?[^\n]+\(iteration \d+\)\n(?:\*\*Q:\*\*|Q:)/.test(after)) return text;
		return [before, marker, 'Formatted consultation entries are shown separately in this chat view.'].filter(Boolean).join('\n\n');
	}

	function renderMessageContent(text) {
		const compacted = compactEmbeddedConsultationHistory(text);
		const consultationSections = renderConsultationSections(compacted);
		if (consultationSections) return consultationSections;
		const qa = renderQaContent(compacted);
		if (qa) return qa;
		return renderMarkdown(compacted);
	}

	function toneClass(tone) {
		if (tone === 'success') return 'tone-success';
		if (tone === 'warning') return 'tone-warning';
		if (tone === 'error') return 'tone-error';
		return 'tone-info';
	}

	function phaseTone(phase) {
		if (phase === 'done') return 'success';
		if (phase === 'review' || phase === 'consulting' || phase === 'interview' || phase === 'finalizing') return 'warning';
		if (phase === 'idle') return 'info';
		return 'info';
	}

	function humanizePhase(phase) {
		if (phase === 'idle') return 'Idle';
		if (phase === 'interview') return 'Interview';
		if (phase === 'consulting') return 'Consulting';
		if (phase === 'review') return 'Review';
		if (phase === 'finalizing') return 'Finalizing';
		if (phase === 'done') return 'Done';
		return String(phase || 'Unknown');
	}

	function titleize(value) {
		return String(value || '')
			.split(/[-_\s]+/)
			.filter(Boolean)
			.map((part) => part.charAt(0).toUpperCase() + part.slice(1))
			.join(' ');
	}

	function formatTimestamp(value) {
		const date = new Date(value || Date.now());
		if (Number.isNaN(date.getTime())) return 'unknown';
		return date.toLocaleString();
	}

	function relativeTime(value) {
		const date = new Date(value || Date.now());
		const ms = Date.now() - date.getTime();
		if (Number.isNaN(date.getTime())) return 'unknown';
		const minutes = Math.round(ms / 60000);
		if (minutes <= 1) return 'just now';
		if (minutes < 60) return minutes + 'm ago';
		const hours = Math.round(minutes / 60);
		if (hours < 24) return hours + 'h ago';
		const days = Math.round(hours / 24);
		return days + 'd ago';
	}

	function shortenPath(value) {
		const parts = String(value || '').split(/[\\/]+/).filter(Boolean);
		if (parts.length <= 3) return String(value || '');
		return '…/' + parts.slice(-3).join('/');
	}

	function extractSummaryCandidate(text) {
		let value = String(text || '').replace(/\r/g, '').trim();
		if (!value) return '';
		const answerMatch = value.match(/\bA:\s*([\s\S]*)$/);
		if (answerMatch) value = answerMatch[1];
		const codeFence = String.fromCharCode(96).repeat(3);
		value = value.replace(new RegExp(codeFence + '[\\s\\S]*?' + codeFence, 'g'), ' ');
		value = value.replace(/\n{3,}/g, '\n\n');
		value = value.replace(/\s+/g, ' ').trim();
		value = value.replace(/^Done\s+[—-]\s+/i, '');
		value = value.replace(/^Tool:\s*[^\n]+/i, '');
		return value;
	}

	function summarizeText(text, fallback) {
		const value = extractSummaryCandidate(text);
		if (!value) return fallback || 'No summary available.';
		if (value.length <= 190) return value;
		const trimmed = value.slice(0, 187).replace(/\s+\S*$/, '').trimEnd();
		return (trimmed || value.slice(0, 187)).replace(/[,:;.\-–—\s]+$/, '') + '…';
	}

	function shouldCollapseMessage(item) {
		return item.role === 'tool' || String(item.content || '').length > 520;
	}

	function collapsedMessageText(item) {
		const source = String(item.content || '');
		if (source.length <= 520) return source;
		return source.slice(0, 520).replace(/\s+\S*$/, '').trimEnd() + '\n\n[…truncated — expand to inspect the full output]';
	}

	function buildPhaseBody(state) {
		if (state.rebuildProgress?.active) return 'Blueprint changes are being published back into GitHub issues.';
		if (state.phase === 'idle') return 'No live discovery turn is active yet. Start or resume the planning conversation to populate this cockpit.';
		if (state.phase === 'interview') return 'Discovery questions are still shaping the plan and constraints.';
		if (state.phase === 'consulting') return 'A specialist lane is actively reviewing the blueprint.';
		if (state.phase === 'review') return 'The blueprint is ready for human feedback, revision, or alignment checks.';
		if (state.phase === 'finalizing') return 'Artifacts are being generated for implementation handoff.';
		if (state.phase === 'done') return 'Planning is complete and ready for downstream execution.';
		return 'Blueprint state updated.';
	}

	function mergeChatHistory(items) {
		const seen = new Set(cumulativeChatHistory.map((item) => item._key));
		for (const item of items || []) {
			const key = String(item.timestamp || '') + '|' + String(item.role || '') + '|' + String(item.title || '') + '|' + String(item.content || '');
			if (seen.has(key)) continue;
			cumulativeChatHistory.push({ ...item, _key: key });
			seen.add(key);
		}
		cumulativeChatHistory.sort((a, b) => String(a.timestamp).localeCompare(String(b.timestamp)));
		if (cumulativeChatHistory.length > 100) cumulativeChatHistory = cumulativeChatHistory.slice(-100);
	}

	function filteredChatHistory() {
		return cumulativeChatHistory
			.filter((item) => transcriptFilter === 'all' || item.role === transcriptFilter)
			.slice(-80);
	}

	function activeFilterLabel() {
		return FILTERS.find((filter) => filter.id === transcriptFilter)?.label || 'All';
	}

	function transcriptEntryCountLabel() {
		const count = filteredChatHistory().length;
		return count + (count === 1 ? ' entry' : ' entries');
	}

	function buildTranscriptSummaryText() {
		if (!currentState) return 'Expand from the bottom to inspect the live transcript and controls.';
		const visible = filteredChatHistory().length;
		const total = cumulativeChatHistory.length;
		const liveLabel = currentState.dashboardMeta?.liveSessionConnected ? 'Live session attached' : 'Waiting for live session';
		if (transcriptDrawerOpen) return activeFilterLabel() + ' view • ' + transcriptEntryCountLabel() + ' • ' + liveLabel;
		const countLabel = transcriptFilter === 'all' || visible === total
			? total + ' transcript ' + (total === 1 ? 'entry' : 'entries')
			: visible + ' of ' + total + ' entries';
		return countLabel + ' • ' + activeFilterLabel() + ' • ' + liveLabel;
	}

	function syncTranscriptDrawerChrome() {
		transcriptDrawer.classList.toggle('open', transcriptDrawerOpen);
		transcriptToggle.setAttribute('aria-expanded', String(transcriptDrawerOpen));
		transcriptToggle.setAttribute('aria-label', transcriptDrawerOpen ? 'Collapse transcript drawer' : 'Expand transcript drawer');
		transcriptToggleGlyph.textContent = transcriptDrawerOpen ? '⌄' : '⌃';
		transcriptCountPill.textContent = transcriptEntryCountLabel();
		transcriptSummary.textContent = buildTranscriptSummaryText();
	}

	function setTranscriptDrawerOpen(open) {
		transcriptDrawerOpen = !!open;
		localStorage.setItem('pi-blueprint-transcript-open', transcriptDrawerOpen ? 'true' : 'false');
		syncTranscriptDrawerChrome();
		if (transcriptDrawerOpen) {
			requestAnimationFrame(() => {
				shouldStickChatToBottom = true;
				chat.scrollTop = chat.scrollHeight;
			});
		}
	}

	function openSessionDrawer() {
		sessionDrawerOpen = true;
		sessionDrawer.classList.add('open');
		sessionDrawer.setAttribute('aria-hidden', 'false');
		sessionDrawerScrim.hidden = false;
		requestAnimationFrame(() => sessionDrawerScrim.classList.add('open'));
	}

	function closeSessionDrawer() {
		sessionDrawerOpen = false;
		sessionDrawer.classList.remove('open');
		sessionDrawer.setAttribute('aria-hidden', 'true');
		sessionDrawerScrim.classList.remove('open');
		setTimeout(() => {
			if (!sessionDrawerOpen) sessionDrawerScrim.hidden = true;
		}, 200);
	}

	function buildSuggestedAction(state) {
		const coverageMissing = Array.isArray(state.reviewScore?.coverageMissing)
			? state.reviewScore.coverageMissing.map(titleize)
			: [];
		if (state.rebuildProgress?.active) {
			return {
				title: 'Publishing the current blueprint',
				reason: state.rebuildProgress.detail || 'GitHub issues are being rebuilt from the latest blueprint state.',
				buttons: [
					{ label: 'Open details', command: '/blueprint-details', variant: 'secondary' },
				],
				note: 'Publishing is in progress. Use details to inspect the live rebuild lane.',
			};
		}
		if (state.phase === 'idle' && (state.consultationCount || 0) === 0) {
			return {
				title: 'Start the discovery conversation',
				reason: 'This worktree is ready, but no blueprint interview has run yet. Kick off discovery from the browser or CLI.',
				buttons: [
					{ label: 'Start discovery', command: 'I am ready to start blueprint discovery. Ask me the first planning question.', variant: 'primary' },
				],
				note: 'Action buttons inject messages into the live blueprint session.',
			};
		}
		if (state.pendingRevisionPrompt) {
			return {
				title: 'Resolve the revision request',
				reason: state.pendingRevisionPrompt.message || 'A revision cycle is required before the review gate can pass.',
				buttons: [
					{ label: 'Revise blueprint', command: '/blueprint-revise Need to address the current review gaps.', variant: 'primary' },
					{ label: 'Dismiss revision', command: '/blueprint-dismiss-revision', variant: 'ghost' },
				],
				note: 'Use revision actions to reopen or explicitly defer the manual review cycle.',
			};
		}
		if (coverageMissing.length > 0) {
			return {
				title: 'Continue specialist review',
				reason: 'Still missing coverage from ' + coverageMissing.join(', ') + ' before the review gate can close cleanly.',
				buttons: [
					{ label: 'Continue review', command: 'Please continue the blueprint review and consult ' + coverageMissing.join(', ') + ' before we finalize.', variant: 'primary' },
					{ label: 'Open details', command: '/blueprint-details', variant: 'secondary' },
				],
				note: 'The primary action sends a follow-up prompt into the live blueprint session.',
			};
		}
		if (!state.lastAlignmentCheck || state.lastAlignmentCheck.status !== 'pass') {
			return {
				title: 'Run transcript alignment',
				reason: state.lastAlignmentCheck?.summary || 'Verify that the current blueprint still matches the transcript-backed decisions.',
				buttons: [
					{ label: 'Run alignment', command: '/blueprint-check-alignment', variant: 'primary' },
					{ label: 'Open details', command: '/blueprint-details', variant: 'secondary' },
				],
				note: 'Alignment is the next high-signal check once specialist coverage is complete.',
			};
		}
		if (!state.prdPath || !state.checklistPath) {
			return {
				title: 'Populate the planning artifacts',
				reason: 'The review is healthy, but the PRD and checklist are not both present yet.',
				buttons: [
					{ label: 'Open details', command: '/blueprint-details', variant: 'primary' },
				],
				note: 'Use details to inspect artifacts and the next operator step.',
			};
		}
		return {
			title: 'Ready for human sign-off',
			reason: 'Specialist coverage and alignment look good. Use chat to approve the blueprint or request one final change.',
			buttons: [
				{ label: 'Ask for final summary', command: 'The blueprint looks good. Please give me the final review summary and next operator steps.', variant: 'primary' },
				{ label: 'Open details', command: '/blueprint-details', variant: 'secondary' },
			],
			note: 'At this stage the browser should help you decide whether to approve or tweak the plan.',
		};
	}

	function buildActivityFeed(state) {
		const items = [];
		items.push({
			tone: phaseTone(state.phase),
			tag: 'Phase',
			title: state.widgetMirror?.phaseLabel || humanizePhase(state.phase),
			body: buildPhaseBody(state),
			meta: state.iteration ? 'Iteration ' + state.iteration : 'Latest browser state',
		});
		if (state.reviewScore) {
			items.push({
				tone: state.reviewScore.ready ? 'success' : (state.reviewScore.score >= 85 ? 'warning' : 'error'),
				tag: 'Review gate',
				title: String(state.reviewScore.score || 0) + '/100',
				body: (state.widgetMirror?.scoreCard?.gateLabel || 'Review in progress') + '. ' + (state.widgetMirror?.scoreCard?.effortLabel || ''),
				meta: state.reviewScore.label || 'Review readiness',
			});
		}
		if (state.pendingRevisionPrompt) {
			items.push({
				tone: 'warning',
				tag: 'Revision',
				title: 'Revision requested',
				body: state.pendingRevisionPrompt.message,
				meta: 'Manual review reopened',
			});
		}
		if (state.lastAlignmentCheck) {
			items.push({
				tone: state.lastAlignmentCheck.status === 'pass' ? 'success' : (state.lastAlignmentCheck.status === 'error' ? 'error' : 'warning'),
				tag: 'Alignment',
				title: state.widgetMirror?.alignmentCard?.statusText || 'Alignment review',
				body: state.widgetMirror?.alignmentCard?.summary || state.lastAlignmentCheck.summary || 'Run alignment to verify transcript-backed decisions.',
				meta: state.widgetMirror?.alignmentCard?.evidence || 'No transcript evidence pinned yet.',
			});
		} else {
			items.push({
				tone: 'warning',
				tag: 'Alignment',
				title: 'Alignment has not been run',
				body: 'Transcript-backed decisions have not been verified yet.',
				meta: 'Recommended action: /blueprint-check-alignment',
			});
		}
		if (state.localAssetSync) {
			items.push({
				tone: state.localAssetSync.status === 'ready' ? 'success' : (state.localAssetSync.status === 'partial' ? 'warning' : 'error'),
				tag: 'Assets',
				title: state.widgetMirror?.assetCard?.stateText || 'Project assets status',
				body: state.widgetMirror?.assetCard?.warning || 'No local changes needed.',
				meta: (state.localAssetSync.present || 0) + '/' + (state.localAssetSync.required || 0) + ' synced',
			});
		}
		const specialists = (state.widgetMirror?.specialists || [])
			.filter((card) => card.isActive || card.iteration != null)
			.sort((a, b) => {
				if (a.isActive && !b.isActive) return -1;
				if (!a.isActive && b.isActive) return 1;
				return String(b.timestamp || '').localeCompare(String(a.timestamp || ''));
			});
		for (const card of specialists.slice(0, 3)) {
			items.push({
				tone: card.statusTone === 'done' ? 'success' : (card.statusTone === 'active' ? 'warning' : 'info'),
				tag: card.label,
				title: card.statusText,
				body: summarizeText(card.response || card.detail, card.isActive ? 'Consultation in progress.' : 'No summary available.'),
				meta: card.timestamp ? 'Updated ' + relativeTime(card.timestamp) : (card.iteration != null ? 'Iteration ' + card.iteration : 'Waiting for first consultation'),
			});
		}
		items.push({
			tone: state.prdPath && state.checklistPath ? 'success' : 'warning',
			tag: 'Artifacts',
			title: state.prdPath && state.checklistPath ? 'PRD and checklist are present' : 'Planning artifacts are incomplete',
			body: 'PRD: ' + (state.prdPath ? 'ready' : 'missing') + ' · Checklist: ' + (state.checklistPath ? 'ready' : 'missing'),
			meta: 'These artifacts become the handoff surface for implementation.',
		});
		return items.slice(0, 8);
	}

	function renderConnectionPill() {
		let text = 'Dashboard connecting…';
		let tone = 'info';
		if (dashboardConnection === 'connected') {
			text = 'Dashboard live';
			tone = 'success';
		} else if (dashboardConnection === 'reconnecting') {
			text = 'Reconnecting…';
			tone = 'warning';
		} else if (dashboardConnection === 'offline') {
			text = 'Dashboard offline';
			tone = 'error';
		}
		connectionPill.textContent = text;
		connectionPill.className = 'pill ' + tone;
	}

	function renderActionButtons(action, enabled) {
		actionButtons.innerHTML = (action.buttons || []).map((button) => {
			const variant = button.variant === 'primary' ? 'primary' : button.variant === 'ghost' ? 'ghost' : 'secondary';
			return '<button class="btn ' + variant + ' action-btn" type="button" data-command="' + esc(button.command) + '"' + (enabled ? '' : ' disabled') + '>' + esc(button.label) + '</button>';
		}).join('');
		actionNote.textContent = enabled ? action.note : 'Connect or reopen the live blueprint session to enable browser actions.';
	}

	function renderFilters() {
		transcriptFilters.innerHTML = FILTERS.map((filter) => {
			const active = transcriptFilter === filter.id ? ' active' : '';
			return '<button class="filter-pill ' + esc(filter.tone) + active + '" type="button" data-filter="' + esc(filter.id) + '">' + esc(filter.label) + '</button>';
		}).join('');
	}

	function renderUsefulCommands(enabled) {
		transcriptCommandList.innerHTML = USEFUL_COMMANDS.map((command) =>
			'<button class="mini-btn command-chip" type="button" data-command="' + esc(command) + '"' + (enabled ? '' : ' disabled') + '>' + esc(command) + '</button>'
		).join('');
	}

	function renderActivity(items) {
		if (!items.length) {
			activityFeed.innerHTML = '<div class="empty-state">No blueprint activity yet.</div>';
			return;
		}
		activityFeed.innerHTML = items.map((item) => [
			'<div class="activity-item">',
			'<span class="activity-tag ' + toneClass(item.tone) + '">' + esc(item.tag) + '</span>',
			'<div class="activity-title">' + esc(item.title) + '</div>',
			'<div class="activity-body">' + esc(item.body) + '</div>',
			(item.meta ? '<div class="activity-meta">' + esc(item.meta) + '</div>' : ''),
			'</div>',
		].join('')).join('');
	}

	function renderSpecialistWidget(card) {
		const chip = card.statusTone === 'done' ? 'done' : card.statusTone === 'active' ? 'active' : 'idle';
		const tone = card.statusTone === 'done' ? 'success' : card.statusTone === 'active' ? 'warning' : 'error';
		const summary = summarizeText(card.response || card.detail, card.isActive ? 'Consultation in progress.' : 'No consultation yet.');
		const meta = [];
		meta.push(card.statusText || 'standby');
		if (card.iteration != null) meta.push('Iteration ' + card.iteration);
		if (card.timestamp) meta.push('Updated ' + relativeTime(card.timestamp));
		return [
			'<div class="widget-card specialist-card tone-' + esc(tone) + '">',
			'<div class="widget-title"><span>' + esc(card.label) + '</span><span class="status-chip ' + chip + '"><span>' + esc(card.statusIcon) + '</span>' + esc(card.statusText) + '</span></div>',
			'<div class="widget-detail">' + esc(summary) + '</div>',
			'<div class="specialist-meta"><span>' + esc(meta.join(' · ')) + '</span></div>',
			'<div class="specialist-actions"><button class="mini-btn specialist-info" type="button" data-specialist-id="' + esc(card.id) + '">Summary</button><button class="mini-btn specialist-search" type="button" data-specialist-id="' + esc(card.id) + '">' + esc(card.response ? 'Full response' : 'Details') + '</button></div>',
			'</div>',
		].join('');
	}

	function closeSpecialistOverlay() {
		detailOverlay.classList.remove('open');
		detailOverlay.setAttribute('aria-hidden', 'true');
	}

	function openSpecialistSummaryOverlay(id) {
		const card = currentState?.widgetMirror?.specialists?.find((item) => item.id === id);
		if (!card) return;
		el('overlayTitle').textContent = card.label + ' Summary';
		el('overlayMeta').textContent = [card.statusText || '', card.iteration != null ? ('iteration ' + card.iteration) : '', card.timestamp ? formatTimestamp(card.timestamp) : ''].filter(Boolean).join(' · ');
		const sections = [
			'<div class="overlay-section"><div class="overlay-label">Latest finding</div><div class="overlay-value">' + renderMarkdown(summarizeText(card.response || card.detail, 'No summary available.')) + '</div></div>',
		];
		if (card.question) sections.push('<div class="overlay-section"><div class="overlay-label">Question</div><div class="overlay-value">' + renderMarkdown(card.question) + '</div></div>');
		el('overlayBody').innerHTML = sections.join('');
		detailOverlay.classList.add('open');
		detailOverlay.setAttribute('aria-hidden', 'false');
	}

	function openSpecialistOverlay(id) {
		const card = currentState?.widgetMirror?.specialists?.find((item) => item.id === id);
		if (!card) return;
		el('overlayTitle').textContent = card.label;
		el('overlayMeta').textContent = [card.statusText || '', card.iteration != null ? ('iteration ' + card.iteration) : '', card.timestamp ? formatTimestamp(card.timestamp) : ''].filter(Boolean).join(' · ');
		const sections = [];
		if (card.question) sections.push('<div class="overlay-section"><div class="overlay-label">Question</div><div class="overlay-value">' + renderMarkdown(card.question) + '</div></div>');
		if (card.response) sections.push('<div class="overlay-section"><div class="overlay-label">Response</div><div class="overlay-value">' + renderMessageContent(String(card.label || '') + ' (detail)\nQ: ' + card.question + '\nA: ' + card.response) + '</div></div>');
		if (!sections.length) sections.push('<div class="overlay-section"><div class="overlay-label">Detail</div><div class="overlay-value">' + renderMarkdown(card.detail || 'No detail available.') + '</div></div>');
		el('overlayBody').innerHTML = sections.join('');
		detailOverlay.classList.add('open');
		detailOverlay.setAttribute('aria-hidden', 'false');
	}

	function renderScoreWidget(card) {
		if (!card) return '<div class="widget-title">Review Gate</div><div class="empty-state">No review score yet.</div>';
		const revisionSummary = card.revisionRequired && card.revisionSummary ? '<div class="widget-detail">' + esc(card.revisionSummary) + '</div>' : '';
		return [
			'<div class="widget-title">Review Gate</div>',
			'<div class="widget-subtitle">Coverage, readiness, and the next planning step.</div>',
			'<div class="metric-value ' + toneClass(card.tone) + '">' + esc(String(card.score)) + '/100</div>',
			'<div class="widget-state">' + esc(card.gateLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.coverageLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.alignmentLabel) + '</div>',
			'<div class="widget-detail">' + esc(card.effortLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.revisionLabel) + '</div>',
			revisionSummary,
		].join('');
	}

	function renderInfoWidget(card) {
