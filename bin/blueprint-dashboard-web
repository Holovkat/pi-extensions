body.light .btn{background:#fff;color:#111;border-color:rgba(0,0,0,.12)}
.decisions{display:flex;flex-direction:column;gap:8px}.decision-item{padding:10px 12px;border-radius:10px;background:rgba(255,255,255,.04);font-size:13px;white-space:pre-wrap;word-break:break-word}
body.light .decision-item{background:#f7f7f8}
.icon-btn{appearance:none;background:transparent;border:1px solid rgba(255,255,255,.12);color:inherit;border-radius:999px;padding:2px 8px;cursor:pointer;font-size:12px}
body.light .icon-btn{border-color:rgba(0,0,0,.12)}
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);display:none;align-items:center;justify-content:center;padding:24px;z-index:20}.overlay.open{display:flex}
.overlay-card{max-width:960px;width:min(960px,100%);max-height:80vh;overflow:auto;background:#16181b;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:18px}
body.light .overlay-card{background:#fff;border-color:rgba(0,0,0,.12)}
.overlay-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:14px}.overlay-title{font-size:22px;font-weight:700}.overlay-meta{font-size:12px;opacity:.7;margin-top:4px}.overlay-section{margin-top:14px}.overlay-label{font-size:12px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;opacity:.7;margin-bottom:8px}.overlay-value{white-space:pre-wrap;word-break:break-word}
@media (max-width: 1100px){.hero,.layout,.cards,.specialist-grid{grid-template-columns:1fr}}
`;

const DASHBOARD_HTML = String.raw`<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Blueprint Dashboard</title>
<style>${DASHBOARD_CSS}</style>
</head>
<body>
<div class="container">
	<div class="nav">
		<div class="nav-brand">PI BLUEPRINT</div>
		<button id="theme-btn" class="theme-toggle" type="button">Light</button>
		<div class="nav-meta" id="updated">waiting…</div>
	</div>

	<div class="hero">
		<div class="card">
			<div class="status-row">
				<span id="statusDot" class="status-dot idle"></span>
				<div class="big" id="statusLine">idle</div>
			</div>
			<div class="widget-meta" id="activityLine">Waiting for state...</div>
			<div class="widget-meta">Web: <span id="urlLine">-</span></div>
		</div>
		<div class="card">
			<div class="widget-title">Recent Decisions</div>
			<div id="decisionList" class="decisions"><div class="muted">No transcript segments yet.</div></div>
		</div>
	</div>

	<div class="cards">
		<div id="scoreCard" class="widget-card"></div>
		<div id="alignmentCard" class="widget-card"></div>
		<div id="assetCard" class="widget-card"></div>
		<div class="widget-card">
			<div class="widget-title">Commands</div>
			<div class="widget-meta"><code>/blueprint-details</code></div>
			<div class="widget-meta"><code>/blueprint-check-alignment</code></div>
			<div class="widget-meta"><code>/blueprint-search-history &lt;query&gt;</code></div>
			<div class="widget-meta"><code>/blueprint-sync-assets</code></div>
		</div>
	</div>

	<div class="panel" style="margin-top:16px">
		<div class="widget-title">Specialists</div>
		<div id="specialistGrid" class="specialist-grid"></div>
		<div id="widgetFooter" class="footer-line"></div>
	</div>

	<div class="layout">
		<div class="panel">
			<div class="widget-title">Transcript</div>
			<div id="chat" class="chat"></div>
			<form id="chatForm" class="chat-form">
				<input id="chatInput" class="chat-input" placeholder="Send a message into the live blueprint session" />
				<button class="btn" type="submit">Send</button>
			</form>
		</div>
		<div class="panel">
			<div class="widget-title">State Snapshot</div>
			<div class="widget-meta">Project: <code>${projectDir}</code></div>
			<div class="widget-meta">State file: <code>${stateFile}</code></div>
			<div class="widget-meta">Control port: <code>${controlPort}</code></div>
			<div class="widget-meta">Widget bar data and transcript stream update live from <code>blueprint-state.json</code>.</div>
		</div>
	</div>
</div>

<div id="detailOverlay" class="overlay" aria-hidden="true">
	<div class="overlay-card">
		<div class="overlay-head">
			<div>
				<div id="overlayTitle" class="overlay-title">Specialist</div>
				<div id="overlayMeta" class="overlay-meta"></div>
			</div>
			<button id="overlayClose" class="btn" type="button">Close</button>
		</div>
		<div id="overlayBody"></div>
	</div>
</div>

<script>
(() => {
	const el = (id) => document.getElementById(id);
	const chat = el('chat');
	const detailOverlay = el('detailOverlay');
	const specialistGrid = el('specialistGrid');
	const scoreCard = el('scoreCard');
	const alignmentCard = el('alignmentCard');
	const assetCard = el('assetCard');
	const widgetFooter = el('widgetFooter');
	const decisionList = el('decisionList');
	let currentState = null;
	let cumulativeChatHistory = [];
	let shouldStickChatToBottom = true;

	function toggleTheme() {
		document.body.classList.toggle('light');
		const light = document.body.classList.contains('light');
		el('theme-btn').textContent = light ? 'Dark' : 'Light';
		localStorage.setItem('pi-blueprint-theme', light ? 'light' : 'dark');
	}
	(function initTheme() {
		const saved = localStorage.getItem('pi-blueprint-theme');
		if (saved === 'light') {
			document.body.classList.add('light');
			el('theme-btn').textContent = 'Dark';
		}
	})();
	el('theme-btn').addEventListener('click', toggleTheme);

	function esc(value) {
		return String(value ?? '')
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	}

	function renderMarkdown(text) {
		return esc(String(text || '')).replace(/\n/g, '<br>');
	}

	function renderQaContent(text) {
		const value = String(text || '');
		if (!/\bQ:\b/.test(value) || !/\bA:\b/.test(value)) return null;
		return '<div class="overlay-value">' + renderMarkdown(value) + '</div>';
	}

	function renderConsultationSections(source) {
		const text = String(source || '');
		if (!/\(iteration \d+\)/.test(text) || !/\bQ:\b/.test(text)) return null;
		return '<div class="overlay-value">' + renderMarkdown(text) + '</div>';
	}

	function compactEmbeddedConsultationHistory(source) {
		const text = String(source || '');
		const marker = '## Previous Specialist Consultations';
		const idx = text.indexOf(marker);
		if (idx === -1) return text;
		const before = text.slice(0, idx).trimEnd();
		const after = text.slice(idx + marker.length).trimStart();
		if (!/(?:###\s*)?[^\n]+\(iteration \d+\)\n(?:\*\*Q:\*\*|Q:)/.test(after)) return text;
		return [before, marker, 'Formatted consultation entries are shown separately in this chat view.'].filter(Boolean).join('\n\n');
	}

	function renderMessageContent(text) {
		const compacted = compactEmbeddedConsultationHistory(text);
		const consultationSections = renderConsultationSections(compacted);
		if (consultationSections) return consultationSections;
		const qa = renderQaContent(compacted);
		if (qa) return qa;
		return renderMarkdown(compacted);
	}

	function toneClass(tone) {
		return tone === 'success' ? 'tone-success' : tone === 'warning' ? 'tone-warning' : 'tone-error';
	}

	function mergeChatHistory(items) {
		const seen = new Set(cumulativeChatHistory.map((item) => item._key));
		for (const item of items || []) {
			const key = String(item.timestamp || '') + '|' + String(item.role || '') + '|' + String(item.title || '') + '|' + String(item.content || '');
			if (seen.has(key)) continue;
			cumulativeChatHistory.push({ ...item, _key: key });
			seen.add(key);
		}
		cumulativeChatHistory.sort((a, b) => String(a.timestamp).localeCompare(String(b.timestamp)));
		if (cumulativeChatHistory.length > 80) cumulativeChatHistory = cumulativeChatHistory.slice(-80);
	}

	function renderSpecialistWidget(card) {
		const chip = card.statusTone === 'done' ? 'done' : card.statusTone === 'active' ? 'active' : 'idle';
		return [
			'<div class="widget-card tone-' + esc(card.statusTone === 'done' ? 'success' : card.statusTone === 'active' ? 'warning' : 'error') + '">',
			'<div class="widget-title"><span class="widget-title-text">' + esc(card.label) + '</span><span><button class="icon-btn specialist-info" data-specialist-id="' + esc(card.id) + '">i</button> <button class="icon-btn specialist-search" data-specialist-id="' + esc(card.id) + '">⌕</button></span></div>',
			'<div class="status-chip ' + chip + '"><span>' + esc(card.statusIcon) + '</span>' + esc(card.statusText) + '</div>',
			(card.detail ? '<div class="widget-meta">' + esc(card.detail) + '</div>' : ''),
			'</div>',
		].join('');
	}

	function closeSpecialistOverlay() {
		detailOverlay.classList.remove('open');
		detailOverlay.setAttribute('aria-hidden', 'true');
	}

	function openSpecialistSummaryOverlay(id) {
		const card = currentState?.widgetMirror?.specialists?.find((item) => item.id === id);
		if (!card) return;
		el('overlayTitle').textContent = card.label + ' Summary';
		el('overlayMeta').textContent = [card.statusText || '', card.iteration != null ? ('iteration ' + card.iteration) : '', card.timestamp ? new Date(card.timestamp).toLocaleString() : ''].filter(Boolean).join(' · ');
		el('overlayBody').innerHTML = '<div class="overlay-section"><div class="overlay-label">Card Detail</div><div class="overlay-value">' + renderMarkdown(card.detail || 'No summary available.') + '</div></div>';
		detailOverlay.classList.add('open');
		detailOverlay.setAttribute('aria-hidden', 'false');
	}

	function openSpecialistOverlay(id) {
		const card = currentState?.widgetMirror?.specialists?.find((item) => item.id === id);
		if (!card) return;
		el('overlayTitle').textContent = card.label;
		el('overlayMeta').textContent = [card.statusText || '', card.iteration != null ? ('iteration ' + card.iteration) : '', card.timestamp ? new Date(card.timestamp).toLocaleString() : ''].filter(Boolean).join(' · ');
		const sections = [];
		if (card.question) sections.push('<div class="overlay-section"><div class="overlay-label">Question</div><div class="overlay-value">' + renderMarkdown(card.question) + '</div></div>');
		if (card.response) sections.push('<div class="overlay-section"><div class="overlay-label">Response</div><div class="overlay-value">' + renderMessageContent(String(card.label || '') + ' (detail)\nQ: ' + card.question + '\nA: ' + card.response) + '</div></div>');
		if (!sections.length) sections.push('<div class="overlay-section"><div class="overlay-label">Detail</div><div class="overlay-value">' + renderMarkdown(card.detail || 'No detail available.') + '</div></div>');
		el('overlayBody').innerHTML = sections.join('');
		detailOverlay.classList.add('open');
		detailOverlay.setAttribute('aria-hidden', 'false');
	}

	function renderScoreWidget(card) {
		if (!card) return '<div class="widget-title">Blueprint Score</div><div class="muted">No score yet.</div>';
		const actions = card.revisionRequired ? '<div class="widget-actions"><code>/blueprint-revise [reason]</code> · <code>/blueprint-dismiss-revision</code></div>' : '';
		const revisionSummary = card.revisionRequired && card.revisionSummary ? '<div class="widget-meta">' + esc(card.revisionSummary) + '</div>' : '';
		return [
			'<div class="widget-title">Blueprint Score</div>',
			'<div class="metric-value ' + toneClass(card.tone) + '">' + esc(String(card.score)) + '/100</div>',
			'<div class="widget-meta">' + esc(card.label) + '</div>',
			'<div class="widget-meta">' + (card.prdExists ? 'PRD ✓' : 'PRD ○') + ' · <code>/blueprint-prd</code></div>',
			'<div class="widget-meta">' + (card.checklistExists ? 'Checklist ✓' : 'Checklist ○') + ' · <code>/blueprint-checklist</code></div>',
			'<div class="widget-meta">' + esc(card.gateLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.coverageLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.alignmentLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.effortLabel) + '</div>',
			'<div class="widget-meta">' + esc(card.revisionLabel) + '</div>',
			'<div class="widget-meta">Open mode: ' + esc(card.openMode || 'browser') + '</div>',
			revisionSummary,
			actions,
		].join('');
	}

	function renderInfoWidget(card) {
		if (!card) return '<div class="widget-title">Alignment Review</div><div class="muted">No alignment review yet.</div>';
		return [
			'<div class="widget-title">' + esc(card.title) + '</div>',
			'<div class="widget-state ' + toneClass(card.tone) + '">' + esc(String(card.score)) + '/100 · ' + esc(card.statusText) + '</div>',
			'<div class="widget-detail">' + esc(card.summary) + '</div>',
			'<div class="widget-meta">Evidence: ' + esc(card.evidence) + '</div>',
			'<div class="widget-actions"><code>' + esc(card.commandLine).replace(/ · /g, '</code> · <code>') + '</code></div>',
		].join('');
	}

	function renderAssetWidget(card) {
		if (!card) return '<div class="widget-title">Local Assets</div><div class="muted">No asset sync data.</div>';
		return [
			'<div class="widget-title">' + esc(card.title) + '</div>',
			'<div class="widget-state ' + toneClass(card.tone) + '">' + esc(card.statusText) + '</div>',
			'<div class="widget-meta">' + esc(card.stateText) + '</div>',
			'<div class="widget-meta">' + esc(card.sourceLine) + '</div>',
			'<div class="widget-detail">' + esc(card.warning) + '</div>',
			'<div class="widget-actions"><code>' + esc(card.commandLine).replace(/ · /g, '</code> · <code>') + '</code></div>',
		].join('');
	}

	function renderState(state) {
		if (!state) return;
		currentState = state;
		const distanceFromBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight;
		const wasNearBottom = distanceFromBottom <= 40 || shouldStickChatToBottom;
		el('statusDot').className = 'status-dot ' + (state.phase === 'idle' ? 'idle' : 'running');
		el('statusLine').textContent = state.phase || 'connected';
		el('urlLine').textContent = state.webUrl || window.location.href;
		el('activityLine').textContent = state.widgetMirror?.phaseLabel || 'Waiting for state...';
		if (state.widgetMirror) {
			specialistGrid.innerHTML = (state.widgetMirror.specialists || []).map(renderSpecialistWidget).join('');
			scoreCard.innerHTML = renderScoreWidget(state.widgetMirror.scoreCard);
			alignmentCard.innerHTML = renderInfoWidget(state.widgetMirror.alignmentCard);
			assetCard.innerHTML = renderAssetWidget(state.widgetMirror.assetCard);
			widgetFooter.textContent = state.widgetMirror.consultationCount + ' consultation' + (state.widgetMirror.consultationCount === 1 ? '' : 's') + ' · ' + state.widgetMirror.specialistsCovered + '/' + state.widgetMirror.totalSpecialists + ' specialists consulted';
		}
		decisionList.innerHTML = '';
		const decisions = (state.chatHistory || []).slice(-6);
		if (!decisions.length) {
			decisionList.innerHTML = '<div class="muted">No transcript segments yet.</div>';
		} else {
			for (const item of decisions) {
				const row = document.createElement('div');
				row.className = 'decision-item';
				row.textContent = '[' + item.role + '] ' + String(item.content || '').slice(0, 180);
				decisionList.appendChild(row);
			}
		}
		mergeChatHistory(state.chatHistory || []);
		chat.innerHTML = '';
		const renderedChat = cumulativeChatHistory.slice(-60);
		for (const item of renderedChat) {
			const div = document.createElement('div');
			div.className = 'msg ' + item.role;
			div.innerHTML = '<div class="msg-title">' + esc(item.title || item.role || 'message') + '</div><div class="msg-body">' + renderMessageContent(item.content) + '</div>';
			chat.appendChild(div);
		}
		if (wasNearBottom) {
			chat.scrollTop = chat.scrollHeight;
			shouldStickChatToBottom = true;
		}
		el('updated').textContent = 'updated ' + new Date(state.updatedAt || Date.now()).toLocaleTimeString();
	}

	async function refresh() {
		try {
			const res = await fetch('/api/state');
			renderState(await res.json());
		} catch {}
	}

	new EventSource('/events').onmessage = (event) => {
		try { renderState(JSON.parse(event.data)); } catch {}
	};

	el('chatForm').addEventListener('submit', async (event) => {
		event.preventDefault();
		const input = el('chatInput');
		const message = input.value.trim();
		if (!message) return;
		await fetch('/api/chat', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ message }),
		});
		input.value = '';
	});

	chat.addEventListener('scroll', () => {
		const distanceFromBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight;
		shouldStickChatToBottom = distanceFromBottom <= 40;
	});

	document.addEventListener('click', (event) => {
		const target = event.target;
		if (target instanceof HTMLElement && target.classList.contains('specialist-info')) openSpecialistSummaryOverlay(target.dataset.specialistId);
		if (target instanceof HTMLElement && target.classList.contains('specialist-search')) openSpecialistOverlay(target.dataset.specialistId);
	});

	el('overlayClose').addEventListener('click', closeSpecialistOverlay);
	detailOverlay.addEventListener('click', (event) => { if (event.target === detailOverlay) closeSpecialistOverlay(); });
	document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && detailOverlay.classList.contains('open')) closeSpecialistOverlay(); });
	refresh();
})();
</script>
</body>
</html>`;

const server = http.createServer((req, res) => {
	if (!req.url) return sendText(res, 404, "not found");
	if (req.method === "OPTIONS") {
		res.writeHead(204, {
			"Access-Control-Allow-Origin": "*",
			"Access-Control-Allow-Methods": "GET,POST,OPTIONS",
			"Access-Control-Allow-Headers": "Content-Type",
		});
		res.end();
		return;
	}

	if (req.url === "/api/version") return sendJson(res, 200, { version: SCRIPT_VERSION });
	if (req.url === "/api/state") return sendJson(res, 200, readState());
	if (req.url === "/events") {
		res.writeHead(200, {
			"Content-Type": "text/event-stream",
			"Cache-Control": "no-cache, no-transform",
			Connection: "keep-alive",
			"Access-Control-Allow-Origin": "*",
		});
		res.write(`data: ${JSON.stringify(readState())}\n\n`);
		sseClients.add(res);
		req.on("close", () => sseClients.delete(res));
		return;
	}
	if (req.url === "/api/chat" && req.method === "POST") {
		let body = "";
		req.on("data", (chunk) => body += chunk);
		req.on("end", () => {
			try {
				const parsed = JSON.parse(body || "{}");
				const message = String(parsed.message || "").trim();
				if (!message) return sendJson(res, 400, { success: false, error: "message required" });
				const targets = registeredAgents.has("blueprint-main")
					? [["blueprint-main", registeredAgents.get("blueprint-main")]]
					: [...registeredAgents.entries()];
				for (const [, agent] of targets) {
					try {
						agent.socket.write(JSON.stringify({ forward: true, type: "chat", message }) + "\n");
					} catch {}
				}
				sendJson(res, 200, { success: true, delivered: targets.length });
			} catch (error) {
				sendJson(res, 400, { success: false, error: error.message });
			}
		});
		return;
	}
	if (req.url === "/" || req.url === "/dashboard") {
		return sendText(res, 200, DASHBOARD_HTML, "text/html; charset=utf-8");
	}
	return sendText(res, 404, "not found");
});

controlServer.listen(controlPort, "127.0.0.1", () => {
	console.log(`Blueprint control socket listening on 127.0.0.1:${controlPort}`);
});
server.listen(port, "127.0.0.1", () => {
	console.log(`Blueprint dashboard listening on http://127.0.0.1:${port}`);
	console.log(`State file: ${stateFile}`);
});
