const THEME_JS = `
function toggleTheme(){document.body.classList.toggle('dark');var d=document.body.classList.contains('dark');document.getElementById('theme-btn').textContent=d?'Light':'Dark';localStorage.setItem('pi-dash-theme',d?'dark':'light')}
(function(){var s=localStorage.getItem('pi-dash-theme');if(s==='light'){document.body.classList.remove('dark');document.getElementById('theme-btn').textContent='Dark'}})();
`;

function readState() {
	try { return mergeConsultationsIntoState(JSON.parse(fs.readFileSync(stateFile, "utf-8"))); }
	catch { return null; }
}

function broadcastState() {
	const state = readState();
	if (!state) return;
	const msg = `data: ${JSON.stringify(state)}\n\n`;
	for (const res of sseClients) {
		try { res.write(msg); } catch { sseClients.delete(res); }
	}
}

function logChat(entry) {
	chatLog.push({ ts: new Date().toISOString(), ...entry });
	if (chatLog.length > 200) chatLog.shift();
}

const controlServer = net.createServer((socket) => {
	let buffer = "";
	socket.setEncoding("utf-8");
	socket.on("data", (chunk) => {
		buffer += chunk;
		let nl;
		while ((nl = buffer.indexOf("\n")) !== -1) {
			const line = buffer.slice(0, nl).trim();
			buffer = buffer.slice(nl + 1);
			if (!line) continue;
			try {
				const cmd = JSON.parse(line);
				handleControlCommand(cmd, socket);
			} catch (err) {
				socket.write(JSON.stringify({ success: false, error: String(err?.message || err) }) + "\n");
			}
		}
	});
	socket.on("error", () => {});
	socket.on("close", () => {
		for (const [id, agent] of registeredAgents) {
			if (agent.socket === socket) registeredAgents.delete(id);
		}
	});
});

function handleControlCommand(cmd, socket) {
	switch (cmd.type) {
		case "register":
			registeredAgents.set(cmd.agentId, { socket, sessionKey: cmd.sessionKey || cmd.agentId, info: cmd.info || {} });
			socket.write(JSON.stringify({ success: true, command: "register" }) + "\n");
			break;
		case "unregister":
			registeredAgents.delete(cmd.agentId);
			socket.write(JSON.stringify({ success: true, command: "unregister" }) + "\n");
			break;
		case "list_agents":
			socket.write(JSON.stringify({
				success: true,
				command: "list_agents",
				agents: Array.from(registeredAgents.entries()).map(([agentId, entry]) => ({ agentId, sessionKey: entry.sessionKey, info: entry.info })),
			}) + "\n");
			break;
		case "chat":
		case "steer":
		case "follow_up": {
			const agentId = cmd.agentId || "blueprint-main";
			const agent = registeredAgents.get(agentId);
			if (!agent) {
				socket.write(JSON.stringify({ success: false, error: `agent not found: ${agentId}` }) + "\n");
				return;
			}
			agent.socket.write(JSON.stringify({ forward: true, type: cmd.type, message: cmd.message || "", agentId }) + "\n");
			socket.write(JSON.stringify({ success: true, command: cmd.type }) + "\n");
			break;
		}
		default:
			socket.write(JSON.stringify({ success: false, error: `unknown command: ${cmd.type}` }) + "\n");
	}
}

let lastMtime = 0;
setInterval(() => {
	try {
		const stat = fs.statSync(stateFile);
		if (stat.mtimeMs !== lastMtime) {
			lastMtime = stat.mtimeMs;
			broadcastState();
		}
	} catch {}
}, 500);

const server = http.createServer((req, res) => {
	if (req.url === "/api/state") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*", "Cache-Control": "no-store" });
		res.end(JSON.stringify(readState()));
		return;
	}
	if (req.url === "/api/version") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*", "Cache-Control": "no-store" });
		res.end(JSON.stringify({ version: SCRIPT_VERSION }));
		return;
	}
	if (req.url === "/api/chat-log") {
		res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*", "Cache-Control": "no-store" });
		res.end(JSON.stringify({ log: chatLog }));
		return;
	}
	if (req.url === "/events") {
		res.writeHead(200, { "Content-Type": "text/event-stream", "Cache-Control": "no-store", "Connection": "keep-alive", "Access-Control-Allow-Origin": "*" });
		res.write("\n");
		sseClients.add(res);
		const state = readState();
		if (state) res.write(`data: ${JSON.stringify(state)}\n\n`);
		req.on("close", () => sseClients.delete(res));
		return;
	}
	if (req.url === "/api/chat" && req.method === "POST") {
		let body = "";
		req.on("data", c => body += c);
		req.on("end", () => {
			res.writeHead(200, { "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" });
			try {
				const cmd = JSON.parse(body || "{}");
				const agent = registeredAgents.get("blueprint-main");
				if (!agent) {
					res.end(JSON.stringify({ success: false, error: "blueprint-main not connected" }));
					return;
				}
				const message = String(cmd.message || "").trim();
				if (!message) {
					res.end(JSON.stringify({ success: false, error: "message is required" }));
					return;
				}
				logChat({ type: "chat", message });
				agent.socket.write(JSON.stringify({ forward: true, type: "chat", message, agentId: "blueprint-main" }) + "\n");
				res.end(JSON.stringify({ success: true }));
			} catch (err) {
				res.end(JSON.stringify({ success: false, error: String(err?.message || err) }));
			}
		});
		return;
	}

	res.writeHead(200, { "Content-Type": "text/html; charset=utf-8", "Cache-Control": "no-store" });
	res.end(HTML);
});

controlServer.listen(controlPort, "127.0.0.1");
server.listen(port, "127.0.0.1", () => {
	console.log(`Blueprint Web Mirror: http://127.0.0.1:${port}`);
});

