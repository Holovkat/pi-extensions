				'<div class="widget-meta">Registered agents: <code>' + esc(agents) + '</code></div>' +
			'</div>',
			'<div class="widget-card">' +
				'<div class="widget-title">Transcript view</div>' +
				'<div class="widget-meta">Current filter: <code>' + esc(activeFilterLabel()) + '</code></div>' +
				'<div class="widget-meta">Visible messages: <code>' + esc(String(filteredChatHistory().length)) + '</code></div>' +
				'<div class="widget-meta">Stored messages: <code>' + esc(String(cumulativeChatHistory.length)) + '</code></div>' +
				'<div class="widget-detail">Live session: ' + esc(meta.liveSessionConnected ? 'connected' : 'waiting for agent') + '</div>' +
			'</div>',
		].join('');
	}

	function renderTranscript() {
		const distanceFromBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight;
		const wasNearBottom = distanceFromBottom <= 40 || shouldStickChatToBottom;
		const messages = filteredChatHistory();
		transcriptCountPill.textContent = messages.length + (messages.length === 1 ? ' entry' : ' entries');
		transcriptSummary.textContent = buildTranscriptSummaryText();
		chat.innerHTML = '';
		if (!messages.length) {
			chat.innerHTML = '<div class="empty-state">No transcript entries for this filter yet.</div>';
			syncTranscriptDrawerChrome();
			return;
		}
		for (const item of messages) {
			const collapsed = shouldCollapseMessage(item) && !expandedMessages.has(item._key);
			const body = collapsed ? collapsedMessageText(item) : String(item.content || '');
			const div = document.createElement('div');
			div.className = 'msg ' + item.role;
			div.innerHTML = [
				'<div class="msg-head">',
					'<div><div class="msg-role">' + esc(item.role) + '</div><div class="msg-title">' + esc(item.title || item.role || 'message') + '</div></div>',
					'<div class="msg-time">' + esc(formatTimestamp(item.timestamp)) + '</div>',
				'</div>',
				'<div class="msg-body">' + renderMessageContent(body) + '</div>',
				(shouldCollapseMessage(item)
					? '<div class="msg-actions"><button class="link-btn msg-toggle" type="button" data-msg-key="' + esc(item._key) + '">' + esc(collapsed ? 'Expand' : 'Collapse') + '</button></div>'
					: ''),
			].join('');
			chat.appendChild(div);
		}
		if (wasNearBottom) {
			chat.scrollTop = chat.scrollHeight;
			shouldStickChatToBottom = true;
		}
		syncTranscriptDrawerChrome();
	}

	function updateChatStatus() {
		const parts = [];
		if (dashboardConnection === 'connected') parts.push('Dashboard connected');
		else if (dashboardConnection === 'reconnecting') parts.push('Reconnecting to dashboard');
		else if (dashboardConnection === 'offline') parts.push('Dashboard offline');
		else parts.push('Connecting to dashboard');
		if (currentState?.dashboardMeta?.liveSessionConnected) parts.push('Live blueprint session attached');
		else if (currentState) parts.push('Waiting for a live blueprint session');
		if (chatSending) parts.push('Sending message…');
		else if (chatFeedback) parts.push(chatFeedback);
		chatStatus.textContent = parts.join(' • ');
		const tone = chatSending
			? 'info'
			: chatFeedback
				? chatFeedbackTone
				: (currentState?.dashboardMeta?.liveSessionConnected ? 'success' : (dashboardConnection === 'connected' ? 'warning' : 'info'));
		chatStatus.className = 'chat-status ' + toneClass(tone);
		chatSendButton.disabled = chatSending;
		chatSendButton.textContent = chatSending ? 'Sending…' : 'Send';
		renderUsefulCommands(!!currentState?.dashboardMeta?.liveSessionConnected);
		transcriptSummary.textContent = buildTranscriptSummaryText();
	}

	async function sendDashboardMessage(message) {
		const text = String(message || '').trim();
		if (!text) return;
		chatSending = true;
		chatFeedback = '';
		chatFeedbackTone = 'info';
		updateChatStatus();
		try {
			const res = await fetch('/api/chat', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ message: text }),
			});
			const payload = await res.json().catch(() => ({}));
			if (!res.ok || !payload.success) throw new Error(payload.error || 'Failed to send message.');
			chatFeedback = payload.delivered === 1 ? 'Delivered to the live blueprint session.' : 'Delivered to ' + payload.delivered + ' live sessions.';
			chatFeedbackTone = 'success';
		} catch (error) {
			chatFeedback = error?.message || 'Failed to send message.';
			chatFeedbackTone = 'error';
		} finally {
			chatSending = false;
			updateChatStatus();
		}
	}

	function renderState(state) {
		if (!state) return;
		currentState = state;
		const meta = state.dashboardMeta || {};
		const action = buildSuggestedAction(state);
		statusDot.className = 'status-dot ' + (state.phase === 'idle' ? 'idle' : 'running');
		statusLine.textContent = humanizePhase(state.phase || 'connected');
		heroTitle.textContent = action.title;
		heroCopy.textContent = action.reason;
		projectBadge.textContent = meta.projectName || PROJECT_NAME;
		projectBadge.title = meta.projectDir || PROJECT_DIR;
		projectPill.textContent = 'Project: ' + (meta.projectName || PROJECT_NAME);
		projectPill.title = meta.projectDir || PROJECT_DIR;
		boundPill.textContent = 'Bound to ' + shortenPath(meta.projectDir || PROJECT_DIR);
		boundPill.title = meta.projectDir || PROJECT_DIR;
		sessionPill.textContent = meta.liveSessionConnected ? 'Live session connected' : 'Waiting for live session';
		sessionPill.className = 'pill ' + (meta.liveSessionConnected ? 'success' : 'warning');
		renderConnectionPill();
		renderActionButtons(action, !!meta.liveSessionConnected);
		renderActivity(buildActivityFeed(state));
		if (state.widgetMirror) {
			specialistSubtitle.textContent = state.widgetMirror.specialistsCovered + '/' + state.widgetMirror.totalSpecialists + ' specialists consulted. Browser-first summaries replace raw question text in the main grid.';
			specialistGrid.innerHTML = (state.widgetMirror.specialists || []).map(renderSpecialistWidget).join('');
			scoreCard.innerHTML = renderScoreWidget(state.widgetMirror.scoreCard);
			alignmentCard.innerHTML = renderInfoWidget(state.widgetMirror.alignmentCard);
			assetCard.innerHTML = renderAssetWidget(state.widgetMirror.assetCard);
			artifactCard.innerHTML = renderArtifactWidget(state);
			widgetFooter.textContent = state.widgetMirror.consultationCount + ' consultation' + (state.widgetMirror.consultationCount === 1 ? '' : 's') + ' · ' + state.widgetMirror.specialistsCovered + '/' + state.widgetMirror.totalSpecialists + ' specialists consulted';
		}
		mergeChatHistory(state.chatHistory || []);
		renderTranscript();
		renderSessionContext(state);
		el('updated').textContent = 'updated ' + formatTimestamp(state.updatedAt || Date.now());
		updateChatStatus();
	}

	async function refresh() {
		try {
			const res = await fetch('/api/state');
			renderState(await res.json());
			dashboardConnection = 'connected';
			renderConnectionPill();
			updateChatStatus();
		} catch {
			dashboardConnection = 'offline';
			renderConnectionPill();
			updateChatStatus();
		}
	}

	const eventSource = new EventSource('/events');
	eventSource.onopen = () => {
		dashboardConnection = 'connected';
		renderConnectionPill();
		updateChatStatus();
	};
	eventSource.onmessage = (event) => {
		try {
			renderState(JSON.parse(event.data));
			dashboardConnection = 'connected';
			renderConnectionPill();
			updateChatStatus();
		} catch {}
	};
	eventSource.onerror = () => {
		dashboardConnection = 'reconnecting';
		renderConnectionPill();
		updateChatStatus();
	};

	chatForm.addEventListener('submit', async (event) => {
		event.preventDefault();
		const message = chatInput.value.trim();
		if (!message) return;
		await sendDashboardMessage(message);
		if (chatFeedbackTone === 'success') chatInput.value = '';
	});

	chat.addEventListener('scroll', () => {
		const distanceFromBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight;
		shouldStickChatToBottom = distanceFromBottom <= 40;
	});

	transcriptToggle.addEventListener('click', () => {
		setTranscriptDrawerOpen(!transcriptDrawerOpen);
	});

	transcriptInfoButton.addEventListener('click', () => {
		openSessionDrawer();
	});

	el('jumpLatest').addEventListener('click', () => {
		shouldStickChatToBottom = true;
		if (!transcriptDrawerOpen) setTranscriptDrawerOpen(true);
		chat.scrollTop = chat.scrollHeight;
	});

	sessionDrawerClose.addEventListener('click', closeSessionDrawer);
	sessionDrawerScrim.addEventListener('click', closeSessionDrawer);

	document.addEventListener('click', async (event) => {
		const target = event.target;
		if (!(target instanceof HTMLElement)) return;
		if (target.classList.contains('specialist-info')) openSpecialistSummaryOverlay(target.dataset.specialistId);
		if (target.classList.contains('specialist-search')) openSpecialistOverlay(target.dataset.specialistId);
		if (target.classList.contains('action-btn')) await sendDashboardMessage(target.dataset.command);
		if (target.classList.contains('command-chip')) await sendDashboardMessage(target.dataset.command);
		if (target.classList.contains('filter-pill')) {
			transcriptFilter = target.dataset.filter || 'all';
			localStorage.setItem('pi-blueprint-filter', transcriptFilter);
			renderFilters();
			renderTranscript();
		}
		if (target.classList.contains('msg-toggle')) {
			const key = target.dataset.msgKey;
			if (!key) return;
			if (expandedMessages.has(key)) expandedMessages.delete(key);
			else expandedMessages.add(key);
			renderTranscript();
		}
	});

	el('overlayClose').addEventListener('click', closeSpecialistOverlay);
	detailOverlay.addEventListener('click', (event) => { if (event.target === detailOverlay) closeSpecialistOverlay(); });
	document.addEventListener('keydown', (event) => {
		if (event.key !== 'Escape') return;
		if (detailOverlay.classList.contains('open')) return closeSpecialistOverlay();
		if (sessionDrawerOpen) return closeSessionDrawer();
		if (transcriptDrawerOpen) setTranscriptDrawerOpen(false);
	});
	renderFilters();
	renderUsefulCommands(false);
	syncTranscriptDrawerChrome();
	renderConnectionPill();
	updateChatStatus();
	refresh();
})();
</script>
</body>
</html>`;

const server = http.createServer((req, res) => {
	if (!req.url) return sendText(res, 404, "not found");
	if (req.method === "OPTIONS") {
		res.writeHead(204, {
			"Access-Control-Allow-Origin": "*",
			"Access-Control-Allow-Methods": "GET,POST,OPTIONS",
			"Access-Control-Allow-Headers": "Content-Type",
		});
		res.end();
		return;
	}
	if (req.url === "/favicon.ico") {
		res.writeHead(204, {
			"Access-Control-Allow-Origin": "*",
			"Cache-Control": "no-cache",
		});
		res.end();
		return;
	}

	if (req.url === "/api/version") return sendJson(res, 200, { version: SCRIPT_VERSION, projectDir, projectName });
	if (req.url === "/api/state") return sendJson(res, 200, readState());
	if (req.url === "/events") {
		res.writeHead(200, {
			"Content-Type": "text/event-stream",
			"Cache-Control": "no-cache, no-transform",
			Connection: "keep-alive",
			"Access-Control-Allow-Origin": "*",
		});
		res.write(`data: ${JSON.stringify(readState())}\n\n`);
		sseClients.add(res);
		req.on("close", () => sseClients.delete(res));
		return;
	}
	if (req.url === "/api/chat" && req.method === "POST") {
		let body = "";
		req.on("data", (chunk) => body += chunk);
		req.on("end", () => {
			try {
				const parsed = JSON.parse(body || "{}");
				const message = String(parsed.message || "").trim();
				if (!message) return sendJson(res, 400, { success: false, error: "message required" });
				const targets = registeredAgents.has("blueprint-main")
					? [["blueprint-main", registeredAgents.get("blueprint-main")]]
					: [...registeredAgents.entries()];
				if (targets.length === 0) return sendJson(res, 409, { success: false, error: "No live blueprint session is connected." });
				for (const [, agent] of targets) {
					try {
						agent.socket.write(JSON.stringify({ forward: true, type: "chat", message }) + "\n");
					} catch {}
				}
				sendJson(res, 200, { success: true, delivered: targets.length });
			} catch (error) {
				sendJson(res, 400, { success: false, error: error.message });
			}
		});
		return;
	}
	if (req.url === "/" || req.url === "/dashboard") {
		return sendText(res, 200, DASHBOARD_HTML, "text/html; charset=utf-8");
	}
	return sendText(res, 404, "not found");
});

controlServer.listen(controlPort, "127.0.0.1", () => {
	console.log(`Blueprint control socket listening on 127.0.0.1:${controlPort}`);
});
server.listen(port, "127.0.0.1", () => {
	console.log(`Blueprint dashboard listening on http://127.0.0.1:${port}`);
	console.log(`State file: ${stateFile}`);
});
