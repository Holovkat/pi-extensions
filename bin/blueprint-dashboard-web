@media(max-width:960px){.container{padding:10px}.layout,.summary-grid{grid-template-columns:1fr}.chat-panel{min-height:60vh;max-height:60vh}}
</style>
</head>
<body class="dark"><div class="container">
	<nav class="nav">
		<span class="nav-brand">BLUEPRINT CONTROL CENTER</span>
		<div class="nav-links">
			<a href="/" class="nav-link active">Blueprint</a>
		</div>
		<button class="theme-toggle" onclick="toggleTheme()" id="theme-btn">Light</button>
	</nav>
	<div class="status-bar">
		<span class="status-dot idle" id="statusDot"></span>
		<strong>LIVE</strong>
		<span class="badge" id="statusLine">Connecting...</span>
		<span class="muted" id="urlLine">http://127.0.0.1:${port}</span>
	</div>
	<div class="layout">
		<div>
			<div class="panel">
			<h2>Progress</h2>
			<div class="summary-grid">
				<div class="metric">
					<h3>Blueprint Score</h3>
					<div class="metric-value" id="scoreValue">--</div>
					<div class="metric-meta" id="scoreMeta">Waiting for state…</div>
				</div>
				<div class="metric">
					<h3>Alignment</h3>
					<div class="metric-value" id="alignValue">--</div>
					<div class="metric-meta" id="alignMeta">Waiting for state…</div>
				</div>
				<div class="metric">
					<h3>Phase</h3>
					<div class="metric-value" id="phaseValue">idle</div>
					<div class="metric-meta" id="phaseMeta">Iteration --</div>
				</div>
				<div class="metric">
					<h3>Rebuild</h3>
					<div class="metric-value" id="rebuildValue">idle</div>
					<div class="metric-meta" id="rebuildMeta">No active rebuild</div>
				</div>
			</div>
			</div>
			<div class="panel" style="margin-top:12px">
				<h3>Recent Decisions</h3>
				<div class="decision-list" id="decisionList"><div class="muted">No transcript segments yet.</div></div>
			</div>
		</div>
		<div class="panel chat-panel">
			<h2>Blueprint Chat</h2>
			<div class="chat-shell">
			<div class="msgs" id="chat"></div>
			<form id="chatForm" class="chat-form">
				<textarea id="chatInput" class="chat-input" placeholder="Discuss gaps, ask for revision, or pressure-test decisions..."></textarea>
				<button type="submit" class="btn">Send to Pi Blueprint</button>
			</form>
			</div>
		</div>
	</div>
	<div class="updated" id="updated">waiting for state...</div>
<script>${THEME_JS}
	const el = (id) => document.getElementById(id);
	const chat = el('chat');
	const decisionList = el('decisionList');
	let cumulativeChatHistory = [];
	let shouldStickChatToBottom = true;

	function scoreClass(score) {
		if (score > 95) return 'pass';
		if (score > 85) return 'warn';
		return 'fail';
	}

	function esc(value) {
		if (value == null) return '';
		return String(value)
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;')
			.replace(/"/g, '&quot;')
			.replace(/'/g, '&#39;');
	}

	function parseInlineMarkdown(text) {
		const tick = '\u0060';
		return esc(text)
			.replace(new RegExp(tick + '([^' + tick + ']+)' + tick, 'g'), '<code>$1</code>')
			.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
			.replace(/\*([^*]+)\*/g, '<em>$1</em>');
	}

	function isTableSeparator(line) {
		return /^\s*\|?[\s:-]+\|[\s|:-]*$/.test(line);
	}

	function parseMarkdownTable(lines, start) {
		if (start + 1 >= lines.length) return null;
		const header = lines[start];
		const separator = lines[start + 1];
		if (!header.includes('|') || !isTableSeparator(separator)) return null;
		const rows = [];
		let i = start;
		while (i < lines.length && lines[i].includes('|')) {
			rows.push(lines[i]);
			i++;
		}
			const splitRow = (row) => row.trim().replace(/^\|/, '').replace(/\|$/, '').split('|').map(cell => parseInlineMarkdown(cell.trim()));
		const head = splitRow(rows[0]);
		const body = rows.slice(2).map(splitRow);
		const html = [
			'<table><thead><tr>',
			head.map(cell => '<th>' + cell + '</th>').join(''),
			'</tr></thead><tbody>',
			body.map(row => '<tr>' + row.map(cell => '<td>' + cell + '</td>').join('') + '</tr>').join(''),
			'</tbody></table>',
		].join('');
		return { html, nextIndex: i };
	}

	function renderMarkdown(text) {
		const lines = String(text || '').split('\n');
		const parts = [];
		const fence = '\u0060\u0060\u0060';
		let i = 0;
		while (i < lines.length) {
			const line = lines[i];
			if (!line.trim()) { i++; continue; }
			if (line.startsWith(fence)) {
				const lang = line.slice(3).trim();
				const body = [];
				i++;
				while (i < lines.length && !lines[i].startsWith(fence)) {
					body.push(lines[i]);
					i++;
				}
				if (i < lines.length) i++;
				parts.push('<pre><code class="lang-' + esc(lang) + '">' + esc(body.join('\n')) + '</code></pre>');
				continue;
			}
			const table = parseMarkdownTable(lines, i);
			if (table) {
				parts.push(table.html);
				i = table.nextIndex;
				continue;
			}
				if (/^###\s+/.test(line)) { parts.push('<h3>' + parseInlineMarkdown(line.replace(/^###\s+/, '')) + '</h3>'); i++; continue; }
				if (/^##\s+/.test(line)) { parts.push('<h2>' + parseInlineMarkdown(line.replace(/^##\s+/, '')) + '</h2>'); i++; continue; }
				if (/^#\s+/.test(line)) { parts.push('<h1>' + parseInlineMarkdown(line.replace(/^#\s+/, '')) + '</h1>'); i++; continue; }
				if (/^>\s?/.test(line)) { parts.push('<blockquote>' + parseInlineMarkdown(line.replace(/^>\s?/, '')) + '</blockquote>'); i++; continue; }
				if (/^[-*]\s+/.test(line)) {
					const items = [];
					while (i < lines.length && /^[-*]\s+/.test(lines[i])) {
						items.push('<li>' + parseInlineMarkdown(lines[i].replace(/^[-*]\s+/, '')) + '</li>');
						i++;
					}
					parts.push('<ul>' + items.join('') + '</ul>');
					continue;
				}
				if (/^\d+\.\s+/.test(line)) {
					const items = [];
					while (i < lines.length && /^\d+\.\s+/.test(lines[i])) {
						items.push('<li>' + parseInlineMarkdown(lines[i].replace(/^\d+\.\s+/, '')) + '</li>');
						i++;
					}
					parts.push('<ol>' + items.join('') + '</ol>');
					continue;
				}
				const paragraph = [];
				while (i < lines.length && lines[i].trim() && !lines[i].startsWith(fence) && !/^#/.test(lines[i]) && !/^[-*]\s+/.test(lines[i]) && !/^\d+\.\s+/.test(lines[i]) && !/^>\s?/.test(lines[i])) {
					const maybeTable = parseMarkdownTable(lines, i);
				if (maybeTable) break;
				paragraph.push(lines[i]);
				i++;
			}
			parts.push('<p>' + parseInlineMarkdown(paragraph.join(' ')) + '</p>');
		}
		return parts.join('');
	}

	function tryParseJson(text) {
		const trimmed = String(text || '').trim();
		if (!trimmed) return null;
		if (!(trimmed.startsWith('{') || trimmed.startsWith('['))) return null;
		try { return JSON.parse(trimmed); } catch {}
		try {
			const repaired = trimmed
				.replace(/:\s*'([^'\\]*(?:\\.[^'\\]*)*)'(\s*[,}])/g, (_m, value, suffix) => {
					return ': ' + JSON.stringify(value) + suffix;
				})
				.replace(/,\s*([}\]])/g, '$1');
			return JSON.parse(repaired);
		} catch {
			return null;
		}
	}

	function renderJsonFallback(text) {
		return '<pre><code class="lang-json">' + esc(String(text || '').trim()) + '</code></pre>';
	}

	function renderJsonValue(value, depth = 0) {
		if (value == null) return '<div class="qa-json-primitive">' + esc(String(value)) + '</div>';
		if (typeof value === 'string') return '<div class="qa-json-primitive">' + renderMarkdown(value) + '</div>';
		if (typeof value === 'number' || typeof value === 'boolean') return '<div class="qa-json-primitive">' + esc(String(value)) + '</div>';
		if (Array.isArray(value)) {
			if (!value.length) return '<div class="qa-json-primitive">[]</div>';
			return '<div class="qa-json-array">' + value.map((item, index) =>
				'<div class="qa-json-kv"><div class="qa-json-index">Item ' + (index + 1) + '</div><div>' + renderJsonValue(item, depth + 1) + '</div></div>'
			).join('') + '</div>';
		}
		const entries = Object.entries(value);
		if (!entries.length) return '<div class="qa-json-primitive">{}</div>';
		return '<div class="' + (depth === 0 ? 'qa-json' : 'qa-json-children') + '">' + entries.map(([key, item]) =>
			'<div class="qa-json-kv"><div class="qa-json-key"><strong><em>' + esc(key) + ':</em></strong></div><div>' + renderJsonValue(item, depth + 1) + '</div></div>'
		).join('') + '</div>';
	}

	function renderQaContent(text) {
		const source = String(text || '');
		const rawJson = tryParseJson(source);
		if (rawJson != null) {
			return renderJsonValue(rawJson);
		}
		const qMatch = source.match(/(?:^|\n)Q:\s*/);
		const aMatch = source.match(/(?:^|\n)A:\s*/);
		if (!qMatch || !aMatch || aMatch.index <= qMatch.index) return null;
		const prefix = source.slice(0, qMatch.index).trim();
		const question = source.slice(qMatch.index + qMatch[0].length, aMatch.index).trim();
		const answer = source.slice(aMatch.index + aMatch[0].length).trim();
		const parsedAnswer = tryParseJson(answer);
		const parts = ['<div class="qa-block">'];
		if (prefix) {
			parts.push('<div class="qa-heading">' + esc(prefix) + '</div>');
		}
		if (question) {
			parts.push('<div class="qa-row"><div class="qa-label"><strong><em>Q:</em></strong></div><div>' + renderMarkdown(question) + '</div></div>');
		}
		if (answer) {
			parts.push('<div class="qa-row"><div class="qa-label"><strong><em>A:</em></strong></div><div>' + (parsedAnswer != null ? renderJsonValue(parsedAnswer) : tryParseJson(answer) === null && /^[\[{]/.test(answer.trim()) ? renderJsonFallback(answer) : renderMarkdown(answer)) + '</div></div>');
		}
		parts.push('</div>');
		return parts.join('');
	}

	function renderConsultationSections(text) {
		const source = String(text || '');
		const sectionRegex = /(^|\n)(?:###\s*)?([^\n]+\(iteration \d+\))\n(?:\*\*Q:\*\*|Q:)\s*([\s\S]*?)\n(?:\*\*A:\*\*|A:)\s*([\s\S]*?)(?=\n(?:###\s*)?[^\n]+\(iteration \d+\)\n(?:\*\*Q:\*\*|Q:)|\n*$)/g;
		let match;
		let lastIndex = 0;
		const pieces = [];
		while ((match = sectionRegex.exec(source)) !== null) {
			const start = match.index + (match[1] ? match[1].length : 0);
			if (start > lastIndex) {
				const before = source.slice(lastIndex, start).trim();
				if (before) pieces.push(renderMarkdown(before));
			}
			const title = match[2].trim();
			const question = match[3].trim();
			const answer = match[4].trim();
			const parsedAnswer = tryParseJson(answer);
			pieces.push([
				'<div class="qa-block">',
				'<div class="qa-heading">' + esc(title) + '</div>',
				question ? '<div class="qa-row"><div class="qa-label"><strong><em>Q:</em></strong></div><div>' + renderMarkdown(question) + '</div></div>' : '',
				answer ? '<div class="qa-row"><div class="qa-label"><strong><em>A:</em></strong></div><div>' + (parsedAnswer != null ? renderJsonValue(parsedAnswer) : /^[\[{]/.test(answer.trim()) ? renderJsonFallback(answer) : renderMarkdown(answer)) + '</div></div>' : '',
				'</div>',
			].join(''));
			lastIndex = sectionRegex.lastIndex;
		}
		if (!pieces.length) return null;
		const tail = source.slice(lastIndex).trim();
		if (tail) pieces.push(renderMarkdown(tail));
		return pieces.join('');
	}

	function compactEmbeddedConsultationHistory(text) {
		const source = String(text || '');
		const marker = '## Previous Specialist Consultations';
		const index = source.indexOf(marker);
		if (index === -1) return source;
		const before = source.slice(0, index).trimEnd();
		const after = source.slice(index);
		if (!/(?:###\s*)?[^\n]+\(iteration \d+\)\n(?:\*\*Q:\*\*|Q:)/.test(after)) return source;
		return [
			before,
			'## Previous Specialist Consultations',
			'Formatted consultation entries are shown separately in this chat view.',
		].filter(Boolean).join('\n\n');
	}

	function renderMessageContent(text) {
		const compacted = compactEmbeddedConsultationHistory(text);
		const consultationSections = renderConsultationSections(compacted);
		if (consultationSections) return consultationSections;
		const qa = renderQaContent(compacted);
		if (qa) return qa;
		return renderMarkdown(compacted);
	}

	function mergeChatHistory(items) {
		const seen = new Set(cumulativeChatHistory.map(item => item._key));
		for (const item of items || []) {
			const key = String(item.timestamp || '') + '|' + String(item.role || '') + '|' + String(item.title || '') + '|' + String(item.content || '');
			if (seen.has(key)) continue;
			cumulativeChatHistory.push({ ...item, _key: key });
			seen.add(key);
		}
		cumulativeChatHistory.sort((a, b) => String(a.timestamp).localeCompare(String(b.timestamp)));
	}

	function renderState(state) {
		if (!state) return;
		const distanceFromBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight;
		const wasNearBottom = distanceFromBottom <= 40 || shouldStickChatToBottom;
		el('statusDot').className = 'status-dot ' + (state.phase === 'idle' ? 'idle' : 'running');
		el('statusLine').textContent = state.phase || 'connected';
		el('urlLine').textContent = state.webUrl || window.location.href;
		el('scoreValue').textContent = state.reviewScore ? state.reviewScore.score + '/100' : '--';
		el('scoreValue').className = 'metric-value ' + scoreClass(state.reviewScore ? state.reviewScore.score : 0);
		el('scoreMeta').textContent = state.reviewScore
			? state.reviewScore.ready
				? 'Review gate clear'
				: state.reviewScore.effortTarget
			: 'Waiting for review data';
		el('alignValue').textContent = state.lastAlignmentCheck ? state.lastAlignmentCheck.score + '/100' : '--';
		el('alignValue').className = 'metric-value ' + scoreClass(state.lastAlignmentCheck ? state.lastAlignmentCheck.score : 0);
		el('alignMeta').textContent = state.lastAlignmentCheck ? (state.lastAlignmentCheck.status + ' · ' + state.lastAlignmentCheck.summary) : 'Not run';
		el('phaseValue').textContent = state.phase || 'idle';
		el('phaseMeta').textContent = 'Iteration ' + (state.iteration || 0) + ' · ' + (state.consultationCount || 0) + ' consultations';
		el('rebuildValue').textContent = state.rebuildProgress ? (state.rebuildProgress.stage + ' ' + state.rebuildProgress.current + '/' + state.rebuildProgress.total) : 'idle';
		el('rebuildMeta').textContent = state.rebuildProgress ? state.rebuildProgress.detail : 'No active rebuild';
		decisionList.innerHTML = '';
		const decisions = (state.chatHistory || []).slice(-6);
		if (!decisions.length) {
			decisionList.innerHTML = '<div class="muted">No transcript segments yet.</div>';
		} else {
			for (const item of decisions) {
				const row = document.createElement('div');
				row.className = 'decision-item';
				row.textContent = '[' + item.role + '] ' + item.content.slice(0, 180);
				decisionList.appendChild(row);
			}
		}
		mergeChatHistory(state.chatHistory || []);
		chat.innerHTML = '';
		for (const item of cumulativeChatHistory) {
			const div = document.createElement('div');
			div.className = 'msg ' + item.role;
			div.innerHTML = '<div class="msg-body markdown-body">' + renderMessageContent(item.content) + '</div>';
			chat.appendChild(div);
		}
		if (wasNearBottom) {
			chat.scrollTop = chat.scrollHeight;
			shouldStickChatToBottom = true;
		}
		el('updated').textContent = 'updated ' + new Date(state.updatedAt || Date.now()).toLocaleTimeString();
	}

	async function refresh() {
		try {
			const res = await fetch('/api/state');
			renderState(await res.json());
		} catch {}
	}

	new EventSource('/events').onmessage = (event) => {
		try { renderState(JSON.parse(event.data)); } catch {}
	};

	el('chatForm').addEventListener('submit', async (event) => {
		event.preventDefault();
		const input = el('chatInput');
		const message = input.value.trim();
		if (!message) return;
		await fetch('/api/chat', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ message }),
		});
		input.value = '';
	});

	chat.addEventListener('scroll', () => {
		const distanceFromBottom = chat.scrollHeight - chat.scrollTop - chat.clientHeight;
		shouldStickChatToBottom = distanceFromBottom <= 40;
	});

	refresh();
</script>
</div></body>
</html>`;
