.eyebrow{font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;opacity:.72}
.status-row{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-top:12px}
.status-dot{width:10px;height:10px;border-radius:50%;display:inline-block;background:#888}
.status-dot.running{background:#5ad66f;box-shadow:0 0 0 4px rgba(90,214,111,.14)}
