		return [
			'<div class="widget-title">' + esc(card.title) + '</div>',
			'<div class="widget-subtitle">Repo-sourced agents and skills needed for blueprint work.</div>',
			'<div class="widget-state ' + toneClass(card.tone) + '">' + esc(card.statusText) + '</div>',
			'<div class="widget-meta">' + esc(card.stateText) + '</div>',
			'<div class="widget-detail">' + esc(card.warning) + '</div>',
		].join('');
	}

	function renderArtifactWidget(state) {
		const meta = state.dashboardMeta || {};
		const tone = state.prdPath && state.checklistPath ? 'success' : 'warning';
		return [
			'<div class="widget-title">Artifacts</div>',
			'<div class="widget-subtitle">Project trust and artifact presence.</div>',
			'<div class="widget-state ' + toneClass(tone) + '">' + esc(state.prdPath && state.checklistPath ? 'Planning handoff is populated' : 'Artifact set is incomplete') + '</div>',
			'<div class="widget-meta">Project: ' + esc(meta.projectName || PROJECT_NAME) + '</div>',
			'<div class="widget-meta">PRD: ' + esc(state.prdPath ? 'ready' : 'missing') + '</div>',
			'<div class="widget-meta">Checklist: ' + esc(state.checklistPath ? 'ready' : 'missing') + '</div>',
			'<div class="widget-detail">Live session: ' + esc(meta.liveSessionConnected ? 'connected' : 'waiting for agent') + '</div>',
		].join('');
	}

	function renderSessionContext(state) {
		const meta = state.dashboardMeta || {};
		const agents = Array.isArray(meta.registeredAgents) && meta.registeredAgents.length > 0 ? meta.registeredAgents.join(', ') : 'none';
		sessionContextPanel.innerHTML = [
			'<div class="widget-card">' +
				'<div class="widget-title">Project binding</div>' +
				'<div class="widget-meta">Project: <code>' + esc(meta.projectDir || PROJECT_DIR) + '</code></div>' +
				'<div class="widget-meta">Project label: <code>' + esc(meta.projectName || PROJECT_NAME) + '</code></div>' +
				'<div class="widget-meta">Phase: <code>' + esc(humanizePhase(state.phase || 'idle')) + '</code></div>' +
				'<div class="widget-meta">Updated: <code>' + esc(formatTimestamp(state.updatedAt || Date.now())) + '</code></div>' +
			'</div>',
			'<div class="widget-card">' +
				'<div class="widget-title">Runtime context</div>' +
				'<div class="widget-meta">State file: <code>' + esc(meta.stateFile || STATE_FILE) + '</code></div>' +
				'<div class="widget-meta">Web URL: <code>' + esc(state.webUrl || window.location.href) + '</code></div>' +
