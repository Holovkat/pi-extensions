#!/usr/bin/env node
// Blueprint Web Mirror — HTTP/SSE dashboard + chat bridge for pi-blueprint
// Usage: blueprint-dashboard-web [project-dir] [--port PORT] [--control-port PORT]

const http = require("node:http");
const net = require("node:net");
const fs = require("node:fs");
const path = require("node:path");

const args = process.argv.slice(2);
let projectDir = process.cwd();
let port = 3151;
let controlPort = 3152;

for (let i = 0; i < args.length; i++) {
	if (args[i] === "--port" && args[i + 1]) {
		port = parseInt(args[i + 1], 10);
		i++;
	} else if (args[i] === "--control-port" && args[i + 1]) {
		controlPort = parseInt(args[i + 1], 10);
		i++;
	} else if (!String(args[i]).startsWith("-")) {
		projectDir = args[i];
	}
}

const stateFile = path.join(projectDir, ".pi", "pipeline-logs", "blueprint-state.json");
const sessionStateFile = path.join(projectDir, ".pi", "agent-sessions", "pi-blueprint-state.json");
const projectName = path.basename(projectDir) || projectDir;
const SCRIPT_VERSION = String(fs.statSync(__filename).mtimeMs);
const MAX_WEB_CHAT_ITEMS = 40;
const MAX_WEB_CHAT_ITEM_CHARS = 12000;
const MAX_WEB_CHAT_TOTAL_CHARS = 180000;
const SPECIALISTS = {
	"req-analyst": { label: "Requirements", color: "accent" },
	"tech-analyst": { label: "Technical", color: "success" },
	"ux-analyst": { label: "UX & Workflows", color: "warning" },
	"scenario-analyst": { label: "Scenarios", color: "error" },
};

const sseClients = new Set();
const registeredAgents = new Map();
const pendingWebChatItems = [];
const PENDING_WEB_CHAT_TTL_MS = 5 * 60 * 1000;
let lastMtime = 0;

function parseChatTimestampMs(value) {
	const numeric = Number(value);
	if (Number.isFinite(numeric) && String(value || "").trim() !== "") return numeric;
	const parsed = Date.parse(String(value || ""));
	return Number.isFinite(parsed) ? parsed : 0;
}

function normalizeChatText(value) {
	return String(value || "")
		.replace(/\r/g, "")
		.replace(/\s+/g, " ")
		.trim();
}

function createPendingWebChatItem(message) {
	return {
		role: "user",
		timestamp: String(Date.now()),
		title: "User Prompt",
		content: String(message || "").trim(),
		pending: true,
	};
}

function getPendingWebChatItems(actualItems) {
	const actualHistory = Array.isArray(actualItems) ? actualItems : [];
	const consumedActualIndexes = new Set();
	const nextPendingItems = [];
	const now = Date.now();
	for (const item of pendingWebChatItems) {
		const timestampMs = parseChatTimestampMs(item?.timestamp);
		if (!item?.content) continue;
		if (timestampMs > 0 && now - timestampMs > PENDING_WEB_CHAT_TTL_MS) continue;
		const matchIndex = actualHistory.findIndex((entry, index) => {
			if (consumedActualIndexes.has(index)) return false;
			if (String(entry?.role || "") !== String(item.role || "")) return false;
			if (String(entry?.title || "") !== String(item.title || "")) return false;
			if (normalizeChatText(entry?.content) !== normalizeChatText(item.content)) return false;
			const entryTimestampMs = parseChatTimestampMs(entry?.timestamp);
			return entryTimestampMs >= Math.max(0, timestampMs - 2000);
		});
		if (matchIndex !== -1) {
			consumedActualIndexes.add(matchIndex);
			continue;
		}
		nextPendingItems.push({ ...item, pending: true });
	}
	pendingWebChatItems.length = 0;
	pendingWebChatItems.push(...nextPendingItems);
	return nextPendingItems;
}

function mergePendingWebChatHistory(items) {
	const actualItems = Array.isArray(items) ? items : [];
	const pendingItems = getPendingWebChatItems(actualItems);
	return [...actualItems, ...pendingItems]
		.sort((a, b) => String(a.timestamp || "").localeCompare(String(b.timestamp || "")));
}

function titleizeSpecialist(name) {
	return String(name || "")
		.split(/[-_\s]+/)
		.filter(Boolean)
		.map((part) => part.charAt(0).toUpperCase() + part.slice(1))
		.join(" ");
}

function truncateWebChatContent(value, maxChars = MAX_WEB_CHAT_ITEM_CHARS) {
	const text = String(value || "");
	if (text.length <= maxChars) return text;
	const headChars = Math.max(2000, Math.floor(maxChars * 0.72));
	const tailChars = Math.max(800, Math.floor(maxChars * 0.18));
	const head = text.slice(0, headChars).trimEnd();
	const tail = text.slice(-tailChars).trimStart();
	const omitted = Math.max(0, text.length - head.length - tail.length);
	return `${head}\n\n...[${omitted} chars truncated for Blueprint web mirror]...\n\n${tail}`;
}

function capWebChatHistory(items) {
	if (!Array.isArray(items) || items.length === 0) return [];
	const recent = items.slice(-MAX_WEB_CHAT_ITEMS).map((item) => ({
		...item,
		content: truncateWebChatContent(item?.content),
	}));
	let totalChars = 0;
	const kept = [];
	for (const item of [...recent].reverse()) {
		const content = String(item?.content || "");
		if (kept.length > 0 && totalChars + content.length > MAX_WEB_CHAT_TOTAL_CHARS) break;
		totalChars += content.length;
		kept.push(item);
	}
	return kept.reverse();
}

function normalizeConsultationText(text) {
	return String(text || "")
		.replace(/\r/g, "")
		.replace(/\s+/g, " ")
		.replace(/\s*Q:\s*/g, " Q: ")
		.replace(/\s*A:\s*/g, " A: ")
		.trim();
}

function cleanSummaryText(text) {
	const value = String(text || "").trim();
	if (!value) return "—";
	if (value.length < 180) return value;
	const trimmed = value.replace(/\s+\S*$/, "").trimEnd();
	return (trimmed || value).replace(/[,:;.\-–—\s]+$/, "") + "...";
}

function consultationQuality(item) {
	const content = String(item?.content || "");
	let score = 0;
	if (/\n\nQ:\s*/.test(content)) score += 3;
	if (/\n\nA:\s*/.test(content)) score += 3;
	if (/^\w.+\(iteration \d+\)\n\nQ:/s.test(content)) score += 2;
	score += Math.min((content.match(/\n/g) || []).length, 10);
	return score;
}

function dedupeConsultationHistory(items) {
	const result = [];
	const byConsultation = new Map();
	for (const item of items || []) {
		const title = String(item?.title || "");
		const content = String(item?.content || "");
		if (/\(iteration \d+\)/.test(title) && /\bQ:\b/.test(content) && /\bA:\b/.test(content)) {
			const qMatch = content.match(/\bQ:\s*([\s\S]*?)\bA:\s*/);
			const questionKey = qMatch
				? normalizeConsultationText(qMatch[1]).slice(0, 400)
				: normalizeConsultationText(content).slice(0, 400);
			const key = `${title}|${questionKey}`;
			const existing = byConsultation.get(key);
			if (!existing || consultationQuality(item) > consultationQuality(existing.item)) {
				if (existing) result[existing.index] = item;
				else {
					byConsultation.set(key, { item, index: result.length });
					result.push(item);
				}
			}
			continue;
		}
		result.push(item);
	}
	return result;
}

function normalizeStateValue(value, fallback = "") {
	if (typeof value === "string") {
		const trimmed = value.trim();
		return trimmed && trimmed !== "[object Object]" ? trimmed : fallback;
	}
	if (typeof value === "number" || typeof value === "boolean") return String(value);
	if (Array.isArray(value)) {
		const parts = value.map((item) => normalizeStateValue(item)).filter(Boolean);
		return parts.length ? parts.join("; ") : fallback;
	}
	if (value && typeof value === "object") {
		const parts = [];
		for (const key of ["id", "title", "name", "summary", "description", "detail", "message", "reason", "requirement", "decision", "quote", "source", "path", "field", "status"]) {
			if (!(key in value)) continue;
			const normalized = normalizeStateValue(value[key]);
			if (!normalized) continue;
			if (["summary", "description", "detail", "message", "reason", "requirement", "decision", "quote"].includes(key)) parts.push(normalized);
			else parts.push(`${key}: ${normalized}`);
		}
		if (parts.length) return Array.from(new Set(parts)).join(" · ");
		try {
			const json = JSON.stringify(value);
			return json.length > 240 ? json.slice(0, 237) + "..." : json;
		} catch {
			return fallback;
		}
	}
	return fallback;
}

function normalizeStateList(value, fallbackPrefix) {
	if (!Array.isArray(value)) return [];
	return value.map((item, index) => normalizeStateValue(item, `${fallbackPrefix} ${index + 1}`)).filter(Boolean);
}

function onlyGenericFallbacks(items, fallbackPrefix) {
	return Array.isArray(items) && items.length > 0 && items.every((item) => new RegExp(`^${fallbackPrefix} \\d+$`).test(String(item || "")));
}

function sanitizeDashboardState(state) {
	if (!state || typeof state !== "object") return state;
	const alignmentSummary = normalizeStateValue(state.lastAlignmentCheck?.summary, "Run alignment to verify transcript-backed decisions.");
	let missingDecisions = normalizeStateList(state.lastAlignmentCheck?.missingDecisions, "Missing decision");
	let contradictions = normalizeStateList(state.lastAlignmentCheck?.contradictions, "Contradiction");
	let evidence = normalizeStateList(state.lastAlignmentCheck?.evidence, "Evidence").slice(0, 5);
	if (onlyGenericFallbacks(missingDecisions, "Missing decision")) missingDecisions = [];
	if (onlyGenericFallbacks(contradictions, "Contradiction")) contradictions = [];
	if (onlyGenericFallbacks(evidence, "Evidence")) evidence = alignmentSummary ? [alignmentSummary] : [];
	const normalizedAlignment = state.lastAlignmentCheck
		? {
			...state.lastAlignmentCheck,
			summary: alignmentSummary,
			missingDecisions,
			contradictions,
			evidence,
		}
		: null;
		let reviewMissing = normalizeStateList(state.reviewScore?.missing, "Review gap");
	if (onlyGenericFallbacks(reviewMissing, "Review gap")) reviewMissing = [];
	const normalizedReviewScore = state.reviewScore
		? {
			...state.reviewScore,
			missing: reviewMissing,
			effortTarget: normalizeStateValue(
				state.reviewScore.effortTarget,
				normalizedAlignment?.contradictions?.[0] || normalizedAlignment?.missingDecisions?.[0] || "Resolve artifact review gaps",
			),
		}
		: null;
	return {
		...state,
		lastAlignmentCheck: normalizedAlignment,
		reviewScore: normalizedReviewScore,
		widgetMirror: null,
	};
}

function readBlueprintSessionState() {
	try {
		return JSON.parse(fs.readFileSync(sessionStateFile, "utf-8"));
	} catch {
		return null;
	}
}

function mergeConsultationsIntoState(state) {
	if (!state) return state;
	const saved = readBlueprintSessionState();
	const consults = Array.isArray(saved?.consultations) ? saved.consultations : [];
	const existing = Array.isArray(state.chatHistory) ? state.chatHistory : [];
	const merged = [...existing];
	const seen = new Set(existing.map((item) =>
		[String(item?.timestamp || ""), String(item?.title || ""), String(item?.content || "")].join("|")
	));
	for (const record of consults) {
		const specialist = titleizeSpecialist(record?.specialist);
		const title = `${specialist} (iteration ${record?.iteration ?? "?"})`;
		const content = `${title}\nQ: ${record?.question || ""}\nA: ${record?.response || ""}`;
		const timestamp = new Date(record?.timestamp || Date.now()).toISOString();
		const key = [timestamp, title, content].join("|");
		if (seen.has(key)) continue;
		merged.push({ role: "assistant", timestamp, title, content });
		seen.add(key);
	}
	merged.sort((a, b) => String(a.timestamp || "").localeCompare(String(b.timestamp || "")));
	const specialistNames = Object.keys(SPECIALISTS);
	const reviewScore = state.reviewScore || null;
	const lastBySpec = new Map();
	for (const record of consults) lastBySpec.set(record?.specialist, record);
	const phaseLabel = state.rebuildProgress?.active
		? `Rebuilding GitHub issues — ${state.rebuildProgress.stage} ${state.rebuildProgress.current}/${state.rebuildProgress.total}`
		: state.phase === "idle" ? "Describe what you want to build."
		: state.phase === "interview" ? "Discovery interview in progress..."
		: state.phase === "consulting" ? `Consulting ${titleizeSpecialist(state.activeConsultant)}...`
		: state.phase === "review" ? "Reviewing findings — provide feedback or approve."
		: state.phase === "finalizing" ? "Generating artifacts..."
		: "Requirements discovery complete.";
	const widgetMirror = state.widgetMirror || {
		phaseLabel,
		specialists: specialistNames.map((name) => {
			const spec = SPECIALISTS[name] || { label: titleizeSpecialist(name), color: "accent" };
			const record = lastBySpec.get(name);
			const isRebuildLane = name === "req-analyst" && !!state.rebuildProgress?.active;
			const isActive = state.activeConsultant === name || isRebuildLane;
			const hasConsulted = !!record;
			return {
				id: name,
				label: spec.label,
				color: spec.color,
				statusIcon: isRebuildLane ? "●" : isActive ? "●" : hasConsulted ? "✓" : "○",
				statusTone: isActive ? "active" : hasConsulted ? "done" : "idle",
				statusText: isRebuildLane
					? `${state.rebuildProgress.stage} ${state.rebuildProgress.current}/${state.rebuildProgress.total}`
					: isActive ? "consulting..." : hasConsulted ? `done (iter ${record?.iteration ?? "?"})` : "standby",
				detail: isRebuildLane
					? (state.rebuildProgress?.detail || "Publishing GitHub issues...")
					: cleanSummaryText(record?.response || record?.question || "—"),
				question: record?.question || "",
				response: record?.response || "",
				timestamp: record?.timestamp || null,
				isActive,
				isRebuildLane,
				iteration: record?.iteration ?? null,
			};
		}),
		scoreCard: {
			score: reviewScore?.score ?? 0,
			label: reviewScore?.label ?? `${consults.length}/${specialistNames.length} specialists`,
			tone: (reviewScore?.score ?? 0) > 95 ? "success" : (reviewScore?.score ?? 0) > 85 ? "warning" : "error",
			active: false,
			prdExists: !!state.prdPath,
			checklistExists: !!state.checklistPath,
			gateLabel: reviewScore?.ready ? "Review gate: pass" : "Review needed",
			coverageLabel: `Planning coverage: ${reviewScore?.coverageScore ?? 0}/100`,
			alignmentLabel: reviewScore?.alignmentStatus === "not-run" || reviewScore?.alignmentStatus == null
				? "Artifact alignment: not run"
				: `Artifact alignment: ${reviewScore?.alignmentScore ?? 0}/100 · ${reviewScore.alignmentStatus}`,
			effortLabel: `${reviewScore?.effortKind === "none" ? "Next step" : "Required next step"}: ${reviewScore?.effortTarget || "Continue review"}`,
			revisionRequired: !!state.pendingRevisionPrompt,
			revisionLabel: state.pendingRevisionPrompt ? "Revision required" : "Revision clear",
			revisionSummary: state.pendingRevisionPrompt?.message || "",
			revisionActions: state.pendingRevisionPrompt ? "/blueprint-revise [reason]  ·  /blueprint-dismiss-revision" : "",
			openMode: "tmux+nano",
		},
		alignmentCard: {
			title: "Alignment Review",
			score: state.lastAlignmentCheck?.score ?? 0,
			statusText: state.lastAlignmentCheck?.status === "pass"
				? "Alignment: pass"
				: state.lastAlignmentCheck?.status === "error"
					? "Alignment: error"
					: "Alignment: review needed",
				summary: state.lastAlignmentCheck?.summary || "Run alignment to verify transcript-backed decisions.",
				evidence: state.lastAlignmentCheck?.evidence?.[0] || "No transcript evidence pinned yet.",
				commandLine: "/blueprint-details  ·  /blueprint-check-alignment",
				tone: state.lastAlignmentCheck?.status === "pass" ? "success" : state.lastAlignmentCheck?.status === "error" ? "error" : "warning",
				active: false,
				statusIcon: state.lastAlignmentCheck?.status === "pass" ? "✓" : state.lastAlignmentCheck?.status === "error" ? "✗" : "○",
			},
		assetCard: {
			title: "Local Assets",
			statusText: state.localAssetSync ? `${state.localAssetSync.present}/${state.localAssetSync.required} synced` : "not checked",
			stateText: state.localAssetSync?.status === "ready" ? "Project assets: ready" : state.localAssetSync?.status === "partial" ? "Project assets: partial" : "Project assets: review needed",
			sourceLine: "Repo source: agents/pi-blueprint + skills/pi-blueprint",
			warning: state.localAssetSync?.missingSources?.length ? `Missing repo sources: ${state.localAssetSync.missingSources.join(", ")}` : "no local changes needed",
			commandLine: "/blueprint-details  ·  /blueprint-sync-assets",
			tone: state.localAssetSync?.status === "ready" ? "success" : state.localAssetSync?.status === "partial" ? "warning" : "error",
			active: false,
			statusIcon: state.localAssetSync?.status === "ready" ? "✓" : state.localAssetSync?.status === "partial" ? "!" : "○",
			status: state.localAssetSync?.status || "not-checked",
		},
		consultationCount: consults.length,
		specialistsCovered: new Set(consults.map((c) => c?.specialist)).size,
		totalSpecialists: specialistNames.length,
	};
	return {
		...state,
		phase: saved?.phase || state.phase,
		iteration: saved?.iteration ?? state.iteration,
		activeConsultant: state.activeConsultant || "",
		consultationCount: consults.length || state.consultationCount || 0,
		specialistsCovered: new Set(consults.map((c) => c?.specialist)).size || state.specialistsCovered || 0,
		widgetMirror,
		chatHistory: capWebChatHistory(dedupeConsultationHistory(merged)),
	};
}

function buildDashboardMeta() {
	return {
		projectDir,
		projectName,
		stateFile,
		controlPort,
		liveSessionConnected: registeredAgents.size > 0,
		registeredAgents: [...registeredAgents.keys()],
	};
}

function readState() {
	try {
		const raw = JSON.parse(fs.readFileSync(stateFile, "utf-8"));
		return {
			...mergeConsultationsIntoState(sanitizeDashboardState(raw)),
			dashboardMeta: buildDashboardMeta(),
		};
	} catch {
		return null;
	}
}

function broadcastState() {
	const state = readState();
	if (!state) return;
	const msg = `data: ${JSON.stringify(state)}\n\n`;
	for (const res of sseClients) {
		try {
			res.write(msg);
		} catch {
			sseClients.delete(res);
		}
	}
}

const controlServer = net.createServer((socket) => {
	let buf = "";
	socket.setEncoding("utf-8");
	socket.on("data", (chunk) => {
		buf += chunk;
		let nl;
		while ((nl = buf.indexOf("\n")) !== -1) {
			const line = buf.slice(0, nl).trim();
			buf = buf.slice(nl + 1);
			if (!line) continue;
			try {
				handleControlCommand(JSON.parse(line), socket);
			} catch (error) {
				try {
					socket.write(JSON.stringify({ success: false, error: `parse error: ${error.message}` }) + "\n");
				} catch {}
			}
		}
	});
	socket.on("error", () => {});
	socket.on("close", () => {
		for (const [id, agent] of registeredAgents.entries()) {
			if (agent.socket === socket) registeredAgents.delete(id);
		}
	});
});

function handleControlCommand(cmd, socket) {
	switch (cmd.type) {
		case "register": {
			registeredAgents.set(cmd.agentId, {
				sessionKey: cmd.sessionKey || cmd.agentId,
				socket,
				info: cmd.info || {},
				registeredAt: Date.now(),
			});
			try { socket.write(JSON.stringify({ success: true, command: "register" }) + "\n"); } catch {}
			break;
		}
		case "unregister": {
			registeredAgents.delete(cmd.agentId);
			try { socket.write(JSON.stringify({ success: true, command: "unregister" }) + "\n"); } catch {}
			break;
		}
		case "chat":
		case "steer":
		case "follow_up":
		case "abort": {
			const targets = cmd.agentId
				? [...registeredAgents.entries()].filter(([id]) => id === cmd.agentId)
				: [...registeredAgents.entries()];
			if (targets.length === 0) {
				try { socket.write(JSON.stringify({ success: false, error: "agent not found" }) + "\n"); } catch {}
				return;
			}
			const payload = cmd.type === "abort"
				? { forward: true, type: "abort" }
				: { forward: true, type: cmd.type === "chat" ? "chat" : cmd.type, message: String(cmd.message || "") };
			for (const [, agent] of targets) {
				try { agent.socket.write(JSON.stringify(payload) + "\n"); } catch {}
			}
			try { socket.write(JSON.stringify({ success: true, command: cmd.type }) + "\n"); } catch {}
			break;
		}
		case "list_agents": {
			const agents = [...registeredAgents.entries()].map(([id, agent]) => ({
				agentId: id,
				sessionKey: agent.sessionKey,
				info: agent.info,
				registeredAt: agent.registeredAt,
			}));
			try { socket.write(JSON.stringify({ success: true, command: "list_agents", agents }) + "\n"); } catch {}
			break;
		}
		default:
			try { socket.write(JSON.stringify({ success: false, error: `unknown command: ${cmd.type}` }) + "\n"); } catch {}
	}
}

setInterval(() => {
	try {
		const stat = fs.statSync(stateFile);
		if (stat.mtimeMs !== lastMtime) {
			lastMtime = stat.mtimeMs;
			broadcastState();
		}
	} catch {}
}, 500);

function sendJson(res, status, value) {
	res.writeHead(status, {
		"Content-Type": "application/json",
		"Access-Control-Allow-Origin": "*",
		"Cache-Control": "no-cache",
	});
	res.end(JSON.stringify(value));
}

function sendText(res, status, text, type = "text/plain; charset=utf-8") {
	res.writeHead(status, {
		"Content-Type": type,
		"Access-Control-Allow-Origin": "*",
		"Cache-Control": "no-cache",
	});
	res.end(text);
}

