body.light{background:#f7f7f8;color:#191919}
body.light{color-scheme:light}
a{color:inherit}
button{font:inherit}
code{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace}
.container{max-width:1480px;margin:0 auto;padding:18px 20px 110px}
.nav{display:flex;align-items:center;gap:12px;padding:10px 0 18px;border-bottom:1px solid rgba(255,255,255,.12)}
body.light .nav{border-bottom-color:rgba(0,0,0,.1)}
.nav-brand{font-size:18px;font-weight:800;letter-spacing:.06em}
