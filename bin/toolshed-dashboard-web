function loadLocalLaneItems() {
	try {
		const raw = JSON.parse(localStorage.getItem(LOCAL_LANE_STORAGE_KEY) || '[]');
		if (!Array.isArray(raw)) return [];
		return raw.map(function(item) {
			return {
				id: String(item.id || ''),
				kind: item.kind || 'card',
				title: String(item.title || ''),
				content: String(item.content || ''),
				summary: String(item.summary || ''),
				timestamp: String(item.timestamp || new Date().toISOString()),
				state: 'historical',
				tone: item.tone || 'info',
				exampleId: item.exampleId || undefined,
				example: item.example && typeof item.example === 'object' ? item.example : undefined,
				appRuntime: item.appRuntime && typeof item.appRuntime === 'object' ? item.appRuntime : undefined,
				appState: item.appState && typeof item.appState === 'object' ? item.appState : undefined,
				cardId: item.cardId || undefined,
				meta: item.meta || (item.appRuntime ? 'Generated MCP app' : 'MCP example'),
			};
		}).filter(function(item) { return item.id; });
	} catch {
		return [];
	}
}

function saveLocalLaneItems() {
	try {
		localStorage.setItem(LOCAL_LANE_STORAGE_KEY, JSON.stringify(localLaneItems));
	} catch {}
}

function setGeneratedAppViewportMode(itemId, mode) {
	const nextMode = String(mode || 'inline') === 'fullscreen' ? 'fullscreen' : 'inline';
	viewportGeneratedAppItemId = nextMode === 'fullscreen' ? String(itemId || '') : '';
	applyGeneratedAppViewportState();
}

function applyGeneratedAppViewportState() {
	const items = Array.from(document.querySelectorAll('.lane-item.generated-app[data-generated-app-item]'));
	let matched = false;
	items.forEach(function(node) {
		const itemId = node.getAttribute('data-generated-app-item') || '';
		const isActive = Boolean(viewportGeneratedAppItemId) && itemId === viewportGeneratedAppItemId;
		node.classList.toggle('viewport-expanded', isActive);
		const frame = node.querySelector('iframe.generated-app-frame');
		if (frame && frame.contentWindow) {
			try {
				frame.contentWindow.postMessage({
					type: 'toolshed-generated-app-display-mode-state',
					itemId: itemId,
					mode: isActive ? 'fullscreen' : 'inline',
				}, window.location.origin);
			} catch {}
		}
		if (isActive) matched = true;
	});
	if (!matched) viewportGeneratedAppItemId = '';
	document.body.classList.toggle('generated-app-viewport-open', Boolean(viewportGeneratedAppItemId));
}

function generatedConversationAdapter(item) {
	const runtime = item && item.appRuntime ? item.appRuntime : {};
	if (runtime.adapter === 'calculator') return 'calculator';
	const text = [
		runtime.title || '',
		item && item.title || '',
		runtime.toolName || '',
		runtime.serverId || '',
		runtime.viewFile || '',
	].join(' ').toLowerCase();
	if (/github project kanban board|github.*kanban|kanban board/.test(text)) return 'github-project-kanban';
	return '';
}

function buildInlineAppSyncAction(item) {
	if (!item || !item.appRuntime) return null;
	const adapter = generatedConversationAdapter(item);
	if (!adapter) return null;
	const state = adapter === 'calculator' ? generatedAppState(item) : (item.appState && typeof item.appState === 'object' ? item.appState : {});
	return {
		type: 'sync-inline-app-state',
		itemId: String(item.id || ''),
		cardId: String(item.cardId || ''),
		title: String(item.title || item.appRuntime.title || 'Inline app'),
		adapter: adapter,
		appRuntime: item.appRuntime,
		appState: state,
	};
}

function buildInlineAppClearAction(item) {
	if (!item || !item.appRuntime) return null;
	const adapter = generatedConversationAdapter(item);
	if (!adapter) return null;
	return {
		type: 'clear-inline-app-state',
		itemId: String(item.id || ''),
		cardId: String(item.cardId || ''),
		adapter: adapter,
	};
}

function postBackgroundAction(action) {
	return fetch('/api/action', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify(action || {}),
	}).then(function(res) {
		return res.json();
	}).catch(function(error) {
		return { success: false, error: error && error.message ? error.message : 'Action failed.' };
	});
}

function scheduleInlineAppSync(item, delay) {
	const payload = buildInlineAppSyncAction(item);
	if (!payload || !payload.itemId) return false;
	const timeoutMs = Number.isFinite(delay) ? delay : 60;
	const key = payload.itemId;
	if (inlineSyncTimers.has(key)) clearTimeout(inlineSyncTimers.get(key));
	inlineSyncTimers.set(key, setTimeout(function() {
		inlineSyncTimers.delete(key);
		postBackgroundAction(payload);
	}, timeoutMs));
	return true;
}

function nodeFromMarkup(markup) {
	const template = document.createElement('template');
	template.innerHTML = String(markup || '').trim();
	return template.content.firstElementChild || null;
}

function captureGeneratedAppLaneNodes() {
	const preserved = new Map();
	if (!lane) return preserved;
	Array.from(lane.querySelectorAll('.lane-item.generated-app[data-generated-app-item]')).forEach(function(node) {
		const itemId = node.getAttribute('data-generated-app-item') || '';
		const item = findLocalLaneItem(itemId);
		const version = item && item.appRuntime ? generatedRuntimeVersion(item.appRuntime) : '';
		if (!itemId || !version) return;
		preserved.set(itemId, { node, version });
	});
	return preserved;
}

function buildLaneItemNode(item, preservedGeneratedApps) {
	if (item && item.meta === 'Generated MCP app' && item.appRuntime) {
		const itemId = String(item.id || '').trim();
		const version = generatedRuntimeVersion(item.appRuntime);
		const cached = itemId && preservedGeneratedApps ? preservedGeneratedApps.get(itemId) : null;
		if (cached && cached.node && cached.version === version) return cached.node;
	}
	return nodeFromMarkup(laneItemMarkup(item));
}

function syncInlineAppsNow(itemId) {
	const items = itemId
		? localLaneItems.filter(function(item) { return item && item.id === itemId; })
		: localLaneItems.slice();
	const payloads = items
		.map(buildInlineAppSyncAction)
		.filter(Boolean);
	if (payloads.length === 0) return Promise.resolve([]);
	return Promise.all(payloads.map(function(payload) {
		return postBackgroundAction(payload);
	}));
}

function scheduleInlineAppSyncById(itemId, delay) {
	const item = findLocalLaneItem(itemId);
	if (!item) return false;
	return scheduleInlineAppSync(item, delay);
}

function clearInlineAppSync(item) {
	if (!item || !item.id || !item.appRuntime || item.appRuntime.adapter !== 'calculator') return;
	postBackgroundAction({
		type: 'clear-inline-app-state',
		itemId: String(item.id || ''),
		cardId: String(item.cardId || ''),
	});
}

function syncInlineAppsFromLocalLane() {
	localLaneItems.forEach(function(item) {
		if (item && item.appRuntime && item.appRuntime.adapter === 'calculator') scheduleInlineAppSync(item, 0);
	});
}

function getBuilderExampleById(exampleId) {
	if (!currentState || !Array.isArray(currentState.widgets)) return null;
	const builder = currentState.widgets.find(function(widget) {
		return widget && widget.id === 'component-builder';
	});
	if (!builder || !Array.isArray(builder.builderExamples)) return null;
	return builder.builderExamples.find(function(example) {
		return example && example.id === exampleId;
	}) || null;
}

function getBuilderForm() {
	return document.querySelector('[data-builder-form]');
}

function populateBuilderForm(preset) {
	const form = getBuilderForm();
	if (!form || !preset || typeof preset !== 'object') return false;
	['title', 'description', 'promptTemplate', 'inputPlaceholder'].forEach(function(field) {
		const input = form.querySelector('[data-builder-field="' + field + '"]');
		if (input && 'value' in input) input.value = String(preset[field] || '');
	});
	const builderCard = document.querySelector('[data-card-id="component-builder"]');
	if (builderCard && typeof builderCard.scrollIntoView === 'function') {
		builderCard.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
	}
	const firstField = form.querySelector('[data-builder-field="title"]');
	if (firstField && typeof firstField.focus === 'function') firstField.focus();
	return true;
}

function seedBuilderExampleCardFromUi(exampleId) {
	const example = getBuilderExampleById(exampleId);
	if (!example || !example.preset) {
		return postAction({ type: 'seed-builder-example-card', exampleId: exampleId }, false);
	}
	const existing = currentState && Array.isArray(currentState.widgets)
		? currentState.widgets.find(function(widget) {
			return widget && (widget.id === (example.preset.preferredId || '') || widget.title === example.title);
		})
		: null;
	if (existing) {
		return postAction({ type: 'switch-workspace', workspaceId: 'all-cards' }, false);
	}
	return postAction({
		type: 'create-custom-card',
		persist: 'session',
		title: String(example.preset.title || example.title || '').trim(),
		description: String(example.preset.description || example.summary || '').trim(),
		promptTemplate: String(example.preset.promptTemplate || '').trim(),
		inputPlaceholder: String(example.preset.inputPlaceholder || '').trim(),
		preferredId: String(example.preset.preferredId || '').trim(),
		generatedFrom: String(example.preset.generatedFrom || example.id || '').trim(),
	}, false).then(function(result) {
		if (result && result.success) {
			postAction({ type: 'switch-workspace', workspaceId: 'all-cards' }, false);
		}
		return result;
	});
}

function laneItemsWithLocal() {
	const base = currentState && Array.isArray(currentState.lane) ? currentState.lane.slice() : [];
	return base.concat(localLaneItems).sort(function(a, b) {
		return String(a.timestamp || '').localeCompare(String(b.timestamp || ''));
	});
}

function initialMcpExampleState(exampleId) {
	if (exampleId === 'basic-server-react') {
		return {
			serverTime: new Date().toISOString(),
			messageText: '',
			log: ['ontoolinput → ready', 'ontoolresult → received ISO timestamp'],
		};
	}
	if (exampleId === 'pdf-server') {
		return { currentPage: 1, loadedPages: 2, focused: false };
	}
	if (exampleId === 'map-server') {
		return { selectedLocation: 'san-francisco', query: '', focused: false };
	}
	if (exampleId === 'video-resource-server') {
		return { loaded: false, playing: false, pulse: 0 };
	}
	if (exampleId === 'wiki-explorer-server') {
		return { selectedNode: 'model-context-protocol', expandedNodes: ['model-context-protocol'] };
	}
	return {};
}

function findRuntimeWidget(cardId) {
	if (!currentState || !Array.isArray(currentState.widgets)) return null;
	return currentState.widgets.find(function(widget) {
		return widget && widget.id === cardId && widget.appRuntime;
	}) || null;
}

function generatedRuntimeVersion(runtime) {
	if (!runtime || typeof runtime !== 'object') return '';
	return String(runtime.versionTag || runtime.fingerprint || '').trim();
}

function closeGeneratedAppInstance(cardId, itemId) {
	const safeCardId = String(cardId || '').trim();
	const safeItemId = String(itemId || '').trim();
	if (!safeCardId && !safeItemId) return false;
	fetch('/api/generated-app-close', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({ cardId: safeCardId, itemId: safeItemId }),
	}).catch(function(){});
	return true;
}

function calculatorSessionId(seed) {
	return 'calc-' + String(seed || Date.now()).replace(/[^a-z0-9]+/gi, '').toLowerCase().slice(-12);
}

function createCalculatorState(seed) {
	return {
		sessionId: calculatorSessionId(seed),
		display: '0',
		expression: '',
		accumulator: null,
		pendingOperator: null,
		waitingForOperand: false,
		history: [],
		steps: [],
		updatedAt: new Date().toISOString(),
	};
}

function resetCalculatorState(state) {
	const sessionId = state && state.sessionId ? state.sessionId : calculatorSessionId(Date.now());
	return Object.assign(state || {}, {
		sessionId: sessionId,
		display: '0',
		expression: '',
		accumulator: null,
		pendingOperator: null,
		waitingForOperand: false,
		history: Array.isArray(state && state.history) ? state.history : [],
		steps: Array.isArray(state && state.steps) ? state.steps : [],
		updatedAt: new Date().toISOString(),
	});
}

function rememberCalculatorStep(state, key, label) {
	state.steps = [{
		key: String(key || ''),
		label: String(label || ''),
		display: String(state.display || '0'),
		expression: calculatorVisibleExpression(state) || '',
		timestamp: new Date().toISOString(),
	}].concat(Array.isArray(state.steps) ? state.steps : []).slice(0, 24);
}

function initialGeneratedAppState(appRuntime, seed) {
	if (!appRuntime || typeof appRuntime !== 'object') return {};
	if (appRuntime.adapter === 'calculator') return createCalculatorState(seed);
	return {
		sessionId: 'app-' + String(seed || Date.now()).replace(/[^a-z0-9]+/gi, '').toLowerCase().slice(-12),
		updatedAt: new Date().toISOString(),
	};
}

function generatedAppState(item) {
	return {
		...initialGeneratedAppState(item && item.appRuntime, item && item.id),
		...((item && item.appState && typeof item.appState === 'object') ? item.appState : {}),
	};
}

function syncGeneratedAppLaneItemsFromState() {
	if (!currentState || !Array.isArray(currentState.widgets) || !Array.isArray(localLaneItems) || localLaneItems.length === 0) return false;
	let changed = false;
	localLaneItems = localLaneItems.map(function(item) {
		if (!item || item.meta !== 'Generated MCP app' || !item.cardId) return item;
		const widget = findRuntimeWidget(item.cardId);
		if (!widget || !widget.appRuntime) return item;
		const nextRuntime = widget.appRuntime;
		const previousVersion = generatedRuntimeVersion(item.appRuntime);
		const nextVersion = generatedRuntimeVersion(nextRuntime);
		const runtimeChanged = previousVersion !== nextVersion
			|| String((item.appRuntime && item.appRuntime.ready) ? '1' : '0') !== String(nextRuntime.ready ? '1' : '0')
			|| String((item.appRuntime && item.appRuntime.viewFile) || '') !== String(nextRuntime.viewFile || '')
			|| String((item.appRuntime && item.appRuntime.toolName) || '') !== String(nextRuntime.toolName || '');
		const nextTitle = String(nextRuntime.title || widget.title || item.title || 'Generated MCP app');
		const nextSummary = nextRuntime.ready ? 'Generated MCP app opened inline.' : 'Build the app before opening it inline.';
		if (!runtimeChanged && item.title === nextTitle && item.summary === nextSummary) return item;
		changed = true;
		if (runtimeChanged) closeGeneratedAppInstance(String(item.cardId || ''), String(item.id || ''));
		return {
			...item,
			title: nextTitle,
			summary: nextSummary,
			tone: nextRuntime.ready ? 'success' : 'warning',
			appRuntime: nextRuntime,
			timestamp: item.timestamp,
		};
	});
	if (changed) saveLocalLaneItems();
	return changed;
}

function addGeneratedAppToLocalLane(cardId) {
	const widget = findRuntimeWidget(cardId);
	if (!widget || !widget.appRuntime) return false;
	const runtime = widget.appRuntime;
	const existingId = 'generated-app-' + cardId;
	const existing = findLocalLaneItem(existingId);
	if (existing) {
		const previousVersion = generatedRuntimeVersion(existing.appRuntime);
		const nextVersion = generatedRuntimeVersion(runtime);
		if (previousVersion !== nextVersion) closeGeneratedAppInstance(cardId, existingId);
		updateLocalLaneItem(existingId, function(item) {
			item.title = String(runtime.title || widget.title || item.title || 'Generated MCP app');
			item.summary = runtime.ready ? 'Generated MCP app opened inline.' : 'Build the app before opening it inline.';
			item.tone = runtime.ready ? 'success' : 'warning';
			item.appRuntime = runtime;
		});
		scheduleInlineAppSyncById(existingId, 0);
		renderLane();
		requestAnimationFrame(function(){ window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' }); });
		return true;
	}
	localLaneItems.push({
		id: existingId,
		kind: 'card',
		title: String(runtime.title || widget.title || 'Generated MCP app'),
		content: '',
		summary: runtime.ready ? 'Generated MCP app opened inline.' : 'Build the app before opening it inline.',
		timestamp: new Date().toISOString(),
		state: 'historical',
		tone: runtime.ready ? 'success' : 'warning',
		cardId: cardId,
		meta: 'Generated MCP app',
		appRuntime: runtime,
		appState: initialGeneratedAppState(runtime, existingId),
	});
	saveLocalLaneItems();
	syncInlineAppsFromLocalLane();
	renderLane();
	requestAnimationFrame(function(){ window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' }); });
	return true;
}

function calculatorToNumber(value) {
	const parsed = Number(value);
	return Number.isFinite(parsed) ? parsed : 0;
}

function calculatorFormatNumber(value) {
	if (!Number.isFinite(value)) return 'Error';
	return String(Number(Number(value).toFixed(12)));
}

function calculatorApplyOperator(left, right, operator) {
	if (operator === '+') return left + right;
	if (operator === '-') return left - right;
	if (operator === '×') return left * right;
	if (operator === '÷') return right === 0 ? Number.NaN : left / right;
	return right;
}

function calculatorVisibleExpression(state) {
	if (state.pendingOperator && state.accumulator !== null) {
		return state.waitingForOperand
			? calculatorFormatNumber(state.accumulator) + ' ' + state.pendingOperator
			: calculatorFormatNumber(state.accumulator) + ' ' + state.pendingOperator + ' ' + state.display;
	}
	return state.expression || '';
}

function applyCalculatorKey(state, key) {
	const value = String(key || '').trim();
	if (!value) return state;
	if (/^[0-9]$/.test(value) || value === '.') {
		if (state.waitingForOperand) {
			state.display = value === '.' ? '0.' : value;
			state.waitingForOperand = false;
		} else if (value === '.') {
			if (String(state.display || '').indexOf('.') === -1) state.display = String(state.display || '0') + '.';
		} else {
			state.display = state.display === '0' ? value : String(state.display || '') + value;
		}
		rememberCalculatorStep(state, value, 'Entered ' + value);
		state.updatedAt = new Date().toISOString();
		return state;
	}
	if (value === 'C') {
		resetCalculatorState(state);
		rememberCalculatorStep(state, value, 'Cleared current calculation');
		state.updatedAt = new Date().toISOString();
		return state;
	}
	if (value === '⌫') {
		if (!state.waitingForOperand) {
			const display = String(state.display || '0');
			state.display = display.length > 1 ? display.slice(0, -1) : '0';
		}
		rememberCalculatorStep(state, value, 'Backspaced current entry');
		state.updatedAt = new Date().toISOString();
		return state;
	}
	if (['+', '-', '×', '÷'].includes(value)) {
		if (state.pendingOperator && !state.waitingForOperand) {
			const left = state.accumulator == null ? 0 : state.accumulator;
			const right = calculatorToNumber(state.display);
			state.expression = calculatorFormatNumber(left) + ' ' + state.pendingOperator + ' ' + calculatorFormatNumber(right);
			const result = calculatorApplyOperator(left, right, state.pendingOperator);
			state.display = calculatorFormatNumber(result);
			state.accumulator = Number.isFinite(result) ? result : null;
			rememberCalculatorStep(state, value, 'Applied ' + state.expression + ' = ' + state.display + ', then selected ' + value);
		} else {
			state.accumulator = calculatorToNumber(state.display);
			state.expression = state.display;
			rememberCalculatorStep(state, value, 'Selected ' + value);
		}
		state.pendingOperator = value;
		state.waitingForOperand = true;
		state.updatedAt = new Date().toISOString();
		return state;
	}
	if (value === '=') {
		if (!state.pendingOperator || state.accumulator === null) return state;
		const left = state.accumulator;
		const right = calculatorToNumber(state.display);
		const expression = calculatorFormatNumber(left) + ' ' + state.pendingOperator + ' ' + calculatorFormatNumber(right);
		const result = calculatorApplyOperator(left, right, state.pendingOperator);
		const formatted = calculatorFormatNumber(result);
		state.display = formatted;
		state.expression = expression;
		state.accumulator = Number.isFinite(result) ? result : null;
		state.pendingOperator = null;
		state.waitingForOperand = true;
		state.history = [{ expression: expression, result: formatted, timestamp: new Date().toISOString() }].concat(Array.isArray(state.history) ? state.history : []).slice(0, 8);
		rememberCalculatorStep(state, value, 'Evaluated ' + expression + ' = ' + formatted);
		state.updatedAt = new Date().toISOString();
	}
	return state;
}

function buildCalculatorChatPrompt(item, mode) {
	if (mode === 'recent') {
		return 'Use the active Toolshed inline calculator session to answer: what is the most recent completed calculation and result?';
	}
	return 'Use the active Toolshed inline calculator session to answer: what is the current displayed calculator value?';
}

function findLocalLaneItem(itemId) {
	return localLaneItems.find(function(item) { return item.id === itemId; }) || null;
}

function updateLocalLaneItem(itemId, mutator) {
	let changed = false;
	localLaneItems = localLaneItems.map(function(item) {
		if (item.id !== itemId) return item;
		const next = { ...item, appState: { ...(item.appState || initialMcpExampleState(item.exampleId || '')) } };
		mutator(next);
		changed = true;
		return next;
	});
	if (!changed) return false;
	saveLocalLaneItems();
	scheduleInlineAppSyncById(itemId, 0);
	renderLane();
	return true;
}

function removeLocalLaneItem(itemId) {
	const existing = findLocalLaneItem(itemId);
	const before = localLaneItems.length;
	localLaneItems = localLaneItems.filter(function(item) { return item.id !== itemId; });
	if (localLaneItems.length === before) return false;
	saveLocalLaneItems();
	if (existing) {
		if (viewportGeneratedAppItemId === itemId) viewportGeneratedAppItemId = '';
		clearInlineAppSync(existing);
		const clearPayload = buildInlineAppClearAction(existing);
		if (clearPayload) postBackgroundAction(clearPayload);
		if (existing.cardId && existing.appRuntime) {
			fetch('/api/generated-app-close', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ cardId: String(existing.cardId || ''), itemId: String(existing.id || '') }),
			}).catch(function(){});
		}
	}
	renderLane();
	return true;
}

function addBuilderExampleToLocalLane(exampleId) {
	const example = getBuilderExampleById(exampleId);
	if (!example) return false;
	localLaneItems = localLaneItems.filter(function(item) {
		return item.id !== 'builder-example-' + exampleId;
	});
	localLaneItems.push({
		id: 'builder-example-' + exampleId,
		kind: 'card',
		title: String(example.laneTitle || ('MCP Example · ' + (example.title || 'Example'))),
		content: '',
		summary: String(example.summary || example.laneSummary || ''),
		timestamp: new Date().toISOString(),
		state: 'historical',
		tone: 'info',
		exampleId: example.id,
		example: example,
		appState: initialMcpExampleState(example.id),
		cardId: example.preset && (example.preset.preferredId || example.id),
		meta: 'MCP example',
	});
	saveLocalLaneItems();
	renderLane();
	requestAnimationFrame(function(){ window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' }); });
	return true;
}

function mcpExampleState(item, exampleId) {
	return {
		...initialMcpExampleState(exampleId),
		...((item && item.appState && typeof item.appState === 'object') ? item.appState : {}),
	};
}

function pdfExamplePages() {
	return [
		{ title: 'Architecture Overview', body: 'The UI tool opens the lane app, then private helper calls stream byte ranges into the viewer as the user navigates.' },
		{ title: 'Chunk Loader', body: 'Instead of returning the whole document up front, the app requests more pages as needed and keeps the first lane response lightweight.' },
		{ title: 'Model Context', body: 'When the reader changes page or selection, the View can send a compact summary back to the model with updateModelContext(...).' },
		{ title: 'Display Modes', body: 'The app stays inline by default, but can request fullscreen when the host allows a larger reading surface.' },
		{ title: 'View State', body: 'Per-view state such as page number or zoom can be keyed by viewUUID so the document resumes where the operator left it.' },
	];
}

function mapExampleLocations() {
	return [
		{ id: 'san-francisco', label: 'San Francisco', x: 68, y: 64, detail: 'Focus on a city card, search for a new place, and mirror the visible selection back to the model.' },
		{ id: 'oslo', label: 'Oslo', x: 56, y: 28, detail: 'The View can restore this exact camera state on reload by using a stored viewUUID entry.' },
		{ id: 'tokyo', label: 'Tokyo', x: 86, y: 46, detail: 'Secondary tools like geocoding can be called from inside the app while the lane stays inline.' },
		{ id: 'sao-paulo', label: 'São Paulo', x: 40, y: 74, detail: 'The map remains embedded in the lane until the operator explicitly requests a larger display mode.' },
	];
}

function wikiExampleGraph() {
	return {
		'model-context-protocol': { label: 'Model Context Protocol', excerpt: 'Open protocol for connecting models to tools, resources, and structured application context.', children: ['servers', 'clients', 'resources'] },
		servers: { label: 'Servers', excerpt: 'Servers expose tools, prompts, and resources through a consistent transport layer.', children: ['tools', 'resources'] },
		clients: { label: 'Clients', excerpt: 'Clients host the conversation surface and may render inline apps inside the lane.', children: ['hosts', 'display-modes'] },
		resources: { label: 'Resources', excerpt: 'Resources carry files, blobs, video, and other content that apps can fetch on demand.', children: ['video-resource', 'pdf-bytes'] },
		tools: { label: 'Tools', excerpt: 'UI tools launch lane apps while helper tools can stay private to the embedded experience.', children: [] },
		hosts: { label: 'Hosts', excerpt: 'Hosts decide whether an app stays inline, opens fullscreen, or moves to another mode.', children: [] },
		'display-modes': { label: 'Display Modes', excerpt: 'Inline mode keeps the app in the conversation; fullscreen is optional and host-controlled.', children: [] },
		'video-resource': { label: 'Video Resource', excerpt: 'A tool returns a URI, then the View reads and decodes the resource blob for playback.', children: [] },
		'pdf-bytes': { label: 'PDF Bytes', excerpt: 'Chunked helper tools let the app fetch only the byte ranges needed for the current document view.', children: [] },
	};
}

