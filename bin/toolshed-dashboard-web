#!/usr/bin/env node
// Pi Toolshed Web Workspace — HTTP/SSE lane-first workspace for pi-toolshed
// Usage: toolshed-dashboard-web [project-dir] [--port PORT] [--control-port PORT]

const http = require("node:http");
const net = require("node:net");
const fs = require("node:fs");
const path = require("node:path");
const { spawn } = require("node:child_process");

const args = process.argv.slice(2);
let projectDir = process.cwd();
let port = 3161;
let controlPort = 3162;

for (let i = 0; i < args.length; i++) {
	if (args[i] === "--port" && args[i + 1]) {
		port = parseInt(args[i + 1], 10);
		i++;
	} else if (args[i] === "--control-port" && args[i + 1]) {
		controlPort = parseInt(args[i + 1], 10);
		i++;
	} else if (!String(args[i]).startsWith("-")) {
		projectDir = args[i];
	}
}

const stateFile = path.join(projectDir, ".pi", "pipeline-logs", "toolshed-state.json");
const sessionStateFile = path.join(projectDir, ".pi", "agent-sessions", "pi-toolshed-state.json");
const projectName = path.basename(projectDir) || projectDir;
const SCRIPT_VERSION = String(fs.statSync(__filename).mtimeMs);

const sseClients = new Set();
const registeredAgents = new Map();
const actionLog = [];
const generatedAppInstances = new Map();
let lastMtime = 0;

function escapeHtml(value) {
	return String(value == null ? "" : value)
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;")
		.replace(/\"/g, "&quot;")
		.replace(/'/g, "&#39;");
}

function clipText(value, maxChars) {
	const text = String(value || "").replace(/\r/g, "").trim();
	if (!text) return "";
	if (text.length <= maxChars) return text;
	const clipped = text.slice(0, maxChars - 1).replace(/\s+\S*$/, "").trimEnd();
	return (clipped || text.slice(0, maxChars - 1)).replace(/[,:;.\-–—\s]+$/, "") + "…";
}

function toneClass(tone) {
	if (tone === "success") return "tone-success";
	if (tone === "warning") return "tone-warning";
	if (tone === "error") return "tone-error";
	if (tone === "neutral") return "tone-neutral";
	return "tone-info";
}

function pushActionLog(entry) {
	actionLog.push({
		at: new Date().toISOString(),
		...entry,
	});
	if (actionLog.length > 120) actionLog.shift();
}

function getTargets(agentId) {
	if (agentId && registeredAgents.has(agentId)) return [[agentId, registeredAgents.get(agentId)]];
	if (registeredAgents.has("toolshed-main")) return [["toolshed-main", registeredAgents.get("toolshed-main")]];
	return [...registeredAgents.entries()];
}

function forwardCommand(cmd) {
	const targets = getTargets(cmd.agentId);
	if (targets.length === 0) {
		pushActionLog({ type: cmd.type || "unknown", status: "error", detail: "No live toolshed session is connected." });
		return { success: false, error: "No live Toolshed session is connected." };
	}
	const payload = { forward: true, ...cmd };
	let delivered = 0;
	for (const [, agent] of targets) {
		try {
			agent.socket.write(JSON.stringify(payload) + "\n");
			delivered++;
		} catch {}
	}
	pushActionLog({
		type: cmd.type || "unknown",
		status: delivered > 0 ? "sent" : "error",
		detail: clipText(cmd.message || cmd.text || cmd.command || cmd.title || cmd.exampleId || cmd.cardId || cmd.workspaceId || cmd.widgetId || cmd.packetId || "", 120),
		targets: targets.map(([id]) => id),
	});
	return delivered > 0
		? { success: true, delivered }
		: { success: false, error: "Unable to forward the action to the live Toolshed session." };
}

function readMcpConfig() {
	try {
		const filePath = path.join(projectDir, ".mcp.json");
		if (!fs.existsSync(filePath)) return {};
		const raw = JSON.parse(fs.readFileSync(filePath, "utf-8"));
		return raw && raw.mcpServers && typeof raw.mcpServers === "object" ? raw.mcpServers : {};
	} catch {
		return {};
	}
}

function resolveGeneratedRuntime(cardId) {
	const state = readState();
	const widgets = state && Array.isArray(state.widgets) ? state.widgets : [];
	const widget = widgets.find(function(item) {
		return item && item.id === cardId && item.appRuntime;
	});
	return widget && widget.appRuntime ? widget.appRuntime : null;
}

function expandConfigEnv(value) {
	return String(value == null ? "" : value).replace(/\$\{([^}]+)\}/g, function(_match, name) {
		return process.env[name] == null ? "" : String(process.env[name]);
	});
}

function getGeneratedAppServerConfig(serverId) {
	const servers = readMcpConfig();
	const config = serverId && servers[serverId];
	if (!config || typeof config !== "object") return null;
	return {
		command: String(config.command || "").trim(),
		args: Array.isArray(config.args) ? config.args.map(function(arg) { return String(arg); }) : [],
		env: config.env && typeof config.env === "object"
			? Object.fromEntries(Object.entries(config.env).map(function(entry) {
				return [entry[0], expandConfigEnv(entry[1])];
			}))
			: {},
	};
}

function extractGeneratedAppHtml(viewFile) {
	if (!viewFile) throw new Error("Generated app view file is not configured.");
	const absolute = path.isAbsolute(viewFile) ? viewFile : path.join(projectDir, viewFile);
	if (!fs.existsSync(absolute)) throw new Error("Generated app view file is missing: " + viewFile);
	const source = fs.readFileSync(absolute, "utf-8");
	const marker = "export const html = String.raw`";
	const start = source.indexOf(marker);
	const end = source.lastIndexOf("`;");
	if (start === -1 || end === -1 || end <= start + marker.length) {
		throw new Error("Unable to extract generated app HTML from " + viewFile);
	}
	return source.slice(start + marker.length, end);
}

function generatedAppInstanceKey(cardId, itemId) {
	return String(itemId || cardId || "").trim();
}

function generatedRuntimeVersion(runtime) {
	if (!runtime || typeof runtime !== "object") return "";
	return String(runtime.versionTag || runtime.fingerprint || "").trim();
}

function createJsonRpcClient(serverConfig) {
	const child = spawn(serverConfig.command, serverConfig.args || [], {
		cwd: projectDir,
		env: { ...process.env, ...(serverConfig.env || {}) },
		stdio: ["pipe", "pipe", "pipe"],
	});
	child.stdin.setDefaultEncoding("utf-8");
	child.stdout.setEncoding("utf-8");
	child.stderr.setEncoding("utf-8");

	let buffer = "";
	let nextId = 1;
	let closed = false;
	let stderr = "";
	const pending = new Map();

	function settlePending(error) {
		for (const [, entry] of pending.entries()) {
			clearTimeout(entry.timer);
			entry.reject(error);
		}
		pending.clear();
	}

	child.stdout.on("data", function(chunk) {
		buffer += String(chunk || "");
		let nl = -1;
		while ((nl = buffer.indexOf("\n")) !== -1) {
			const line = buffer.slice(0, nl).trim();
			buffer = buffer.slice(nl + 1);
			if (!line) continue;
			let message = null;
			try {
				message = JSON.parse(line);
			} catch (error) {
				settlePending(new Error("Failed to parse MCP response: " + error.message));
				continue;
			}
			if (Object.prototype.hasOwnProperty.call(message, "id")) {
				const pendingEntry = pending.get(message.id);
				if (!pendingEntry) continue;
				clearTimeout(pendingEntry.timer);
				pending.delete(message.id);
				if (message.error) {
					pendingEntry.reject(new Error(message.error.message || "MCP tool call failed."));
				} else {
					pendingEntry.resolve(message.result);
				}
			}
		}
	});

	child.stderr.on("data", function(chunk) {
		stderr = (stderr + String(chunk || "")).slice(-8000);
	});

	child.on("error", function(error) {
		closed = true;
		settlePending(error);
	});

	child.on("close", function(code) {
		closed = true;
		const suffix = stderr ? " " + stderr.trim() : "";
		settlePending(new Error("Generated app server exited (" + code + ")." + suffix));
	});

	function send(message) {
		if (closed || child.killed) return Promise.reject(new Error("Generated app server is not running."));
		return new Promise(function(resolve, reject) {
			child.stdin.write(JSON.stringify(message) + "\n", function(error) {
				if (error) reject(error);
				else resolve();
			});
		});
	}

	return {
		child,
		getStderr: function() { return stderr; },
		async request(method, params) {
			const id = nextId++;
			return new Promise(function(resolve, reject) {
				const timer = setTimeout(function() {
					pending.delete(id);
					reject(new Error("Timed out waiting for " + method));
				}, 45000);
				pending.set(id, { resolve, reject, timer });
				send({ jsonrpc: "2.0", id, method, params }).catch(function(error) {
					clearTimeout(timer);
					pending.delete(id);
					reject(error);
				});
			});
		},
		async notify(method, params) {
			return send({ jsonrpc: "2.0", method, params });
		},
		close() {
			try { child.kill(); } catch {}
		},
	};
}

async function ensureGeneratedAppInstance(cardId, itemId, runtime) {
	const key = generatedAppInstanceKey(cardId, itemId);
	const existing = generatedAppInstances.get(key);
	if (existing && existing.client && existing.client.child && existing.client.child.exitCode == null && !existing.client.child.killed) {
		const nextVersion = generatedRuntimeVersion(runtime);
		const currentVersion = generatedRuntimeVersion(existing.runtime);
		if ((nextVersion && currentVersion && nextVersion === currentVersion) || (!nextVersion && !currentVersion)) {
			return existing;
		}
	}
	if (existing && existing.client) existing.client.close();
	generatedAppInstances.delete(key);
	if (!runtime || !runtime.serverId) throw new Error("Generated app runtime is missing a server id.");
	const serverConfig = getGeneratedAppServerConfig(runtime.serverId);
	if (!serverConfig || !serverConfig.command) throw new Error("No .mcp.json server config found for " + runtime.serverId);
	const client = createJsonRpcClient(serverConfig);
	await client.request("initialize", {
		protocolVersion: "2025-06-18",
		capabilities: {},
		clientInfo: {
			name: "toolshed-dashboard-web",
			version: String(SCRIPT_VERSION),
		},
	});
	await client.notify("notifications/initialized");
	const instance = {
		key,
		cardId,
		itemId,
		runtime,
		client,
		sessionId: "",
		lastResult: null,
		lastTouchedAt: Date.now(),
	};
	generatedAppInstances.set(key, instance);
	return instance;
}

function closeGeneratedAppInstance(cardId, itemId) {
	const key = generatedAppInstanceKey(cardId, itemId);
	const existing = generatedAppInstances.get(key);
	if (!existing) return false;
	try { existing.client.close(); } catch {}
	generatedAppInstances.delete(key);
	return true;
}

async function callGeneratedAppTool(cardId, itemId, toolName, args) {
	const runtime = resolveGeneratedRuntime(cardId);
	if (!runtime) throw new Error("Unable to resolve generated app runtime for " + cardId);
	const instance = await ensureGeneratedAppInstance(cardId, itemId, runtime);
	const params = {
		name: String(toolName || "").trim(),
		arguments: { ...(args && typeof args === "object" ? args : {}) },
	};
	if (!params.name) throw new Error("Generated app tool name is required.");
	if (!Object.prototype.hasOwnProperty.call(params.arguments, "sessionId") && instance.sessionId) {
		params.arguments.sessionId = instance.sessionId;
	}
	const result = await instance.client.request("tools/call", params);
	instance.lastTouchedAt = Date.now();
	instance.lastResult = result;
	const nextSessionId = result && result.structuredContent && result.structuredContent.sessionId;
	if (nextSessionId) instance.sessionId = String(nextSessionId);
	return { runtime, instance, result };
}

function generatedToolErrorText(result) {
	if (!result || !result.isError) return "";
	if (Array.isArray(result.content)) {
		const text = result.content
			.map(function(item) {
				return item && item.type === "text" ? String(item.text || "") : "";
			})
			.join("\n")
			.trim();
		if (text) return text;
	}
	if (typeof result.text === "string" && result.text.trim()) return result.text.trim();
	return "Generated app tool failed.";
}

function buildGeneratedAppBridgeScript(config) {
	return [
		"<script>",
		"(function(){",
		"const CARD_ID = " + JSON.stringify(String(config.cardId || "")) + ";",
		"const ITEM_ID = " + JSON.stringify(String(config.itemId || "")) + ";",
		"const OPEN_TOOL = " + JSON.stringify(String(config.toolName || "")) + ";",
		"const bridgeFetch = async function(url, body){",
		"  const res = await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body||{})});",
		"  const data = await res.json();",
		"  if (!data || data.success === false) throw new Error((data && data.error) || 'Bridge request failed.');",
		"  return data;",
		"};",
		"const extractText = function(payload){",
		"  if (!payload) return '';",
		"  if (typeof payload.text === 'string') return payload.text;",
		"  if (Array.isArray(payload.content)) return payload.content.map(function(item){ return item && item.type === 'text' ? item.text || '' : ''; }).join('\\n').trim();",
		"  if (typeof payload.content === 'string') return payload.content;",
		"  return '';",
		"};",
		"const notifyDisplayMode = function(mode){",
		"  const nextMode = mode === 'fullscreen' ? 'fullscreen' : 'inline';",
		"  bridge.displayMode = nextMode;",
		"  window.__toolshedDisplayMode = nextMode;",
		"  if (typeof bridge.ondisplaymodechange === 'function') bridge.ondisplaymodechange({ mode: nextMode });",
		"  try { window.dispatchEvent(new CustomEvent('toolshed-display-mode', { detail: { mode: nextMode } })); } catch {}",
		"};",
		"const bridge = {",
		"  ontoolinput: null,",
		"  ontoolresult: null,",
		"  ondisplaymodechange: null,",
		"  displayMode: 'inline',",
		"  async callServerTool(input){",
		"    const data = await bridgeFetch('/api/generated-app-tool',{ cardId:CARD_ID, itemId:ITEM_ID, name:input && input.name, arguments:input && input.arguments || {} });",
		"    const sessionId = data && data.result && data.result.structuredContent && data.result.structuredContent.sessionId;",
		"    if (sessionId) window.__toolshedSessionId = sessionId;",
		"    return data.result;",
		"  },",
		"  async updateModelContext(input){",
		"    try { await bridgeFetch('/api/generated-app-context',{ cardId:CARD_ID, itemId:ITEM_ID, text: input && input.text || '' }); } catch {}",
		"  },",
		"  async sendMessage(message){",
		"    const text = extractText(message);",
		"    if (!text) return { success: false, error: 'No message text provided.' };",
		"    return bridgeFetch('/api/action',{ type:'send-message', text:text, inlineAppItemId: ITEM_ID, cardId: CARD_ID, sessionId: window.__toolshedSessionId || '' });",
		"  },",
		"  async requestDisplayMode(input){",
		"    const mode = input && input.mode ? String(input.mode) : 'inline';",
		"    try {",
		"      if (window.parent && typeof window.parent.postMessage === 'function') {",
		"        window.parent.postMessage({ type:'toolshed-generated-app-display-mode', cardId:CARD_ID, itemId:ITEM_ID, mode:mode }, window.location.origin);",
		"        return { ok: true, mode: mode };",
		"      }",
		"    } catch {}",
		"    return { ok: false, mode: mode };",
		"  },",
		"  async syncToolshedSession(input){",
		"    try {",
		"      if (window.parent && typeof window.parent.postMessage === 'function') {",
		"        window.parent.postMessage({",
		"          type:'toolshed-generated-app-session-sync',",
		"          cardId:CARD_ID,",
		"          itemId:ITEM_ID,",
		"          adapter: input && input.adapter || '',",
		"          title: input && input.title || '',",
		"          sessionId: input && input.sessionId || window.__toolshedSessionId || '',",
		"          appState: input && input.appState && typeof input.appState === 'object' ? input.appState : {},",
		"        }, window.location.origin);",
		"        return { ok: true };",
		"      }",
		"    } catch {}",
		"    return { ok: false };",
		"  },",
		"  async openLink(input){",
		"    if (input && input.url) window.open(input.url, '_blank', 'noopener,noreferrer');",
		"    return { ok: true };",
		"  }",
		"};",
		"window.app = bridge;",
		"window.openai = bridge;",
		"window.mcp = window.mcp || {};",
		"window.mcp.app = bridge;",
		"notifyDisplayMode('inline');",
		"window.addEventListener('message', function(event){",
		"  if (!event || event.origin !== window.location.origin) return;",
		"  const data = event.data;",
		"  if (!data || data.type !== 'toolshed-generated-app-display-mode-state' || String(data.itemId || '') !== ITEM_ID) return;",
		"  notifyDisplayMode(String(data.mode || 'inline'));",
		"});",
		"window.addEventListener('load', function(){",
		"  bridgeFetch('/api/generated-app-open',{ cardId:CARD_ID, itemId:ITEM_ID, toolName: OPEN_TOOL }).then(async function(data){",
		"    const sessionId = data && data.result && data.result.structuredContent && data.result.structuredContent.sessionId;",
		"    if (sessionId) window.__toolshedSessionId = sessionId;",
		"    if (typeof bridge.ontoolinput === 'function') await bridge.ontoolinput(data.result);",
		"    if (typeof bridge.ontoolresult === 'function') await bridge.ontoolresult(data.result);",
		"  }).catch(function(error){",
		"    const status = document.getElementById('status');",
		"    if (status) status.textContent = 'Open failed: ' + (error && error.message ? error.message : String(error));",
		"    console.error(error);",
		"  });",
		"});",
		"})();",
		"</script>",
	].join("");
}

function buildGeneratedAppFrameHtml(cardId, itemId) {
	const runtime = resolveGeneratedRuntime(cardId);
	if (!runtime) throw new Error("Generated app runtime is unavailable for " + cardId);
	const html = extractGeneratedAppHtml(runtime.viewFile || "");
	const bridgeScript = buildGeneratedAppBridgeScript({
		cardId,
		itemId,
		toolName: runtime.toolName || "",
	});
	if (html.includes("</head>")) return html.replace("</head>", bridgeScript + "\n</head>");
	if (html.includes("<body>")) return html.replace("<body>", "<body>\n" + bridgeScript);
	return bridgeScript + html;
}

function readState() {
	try {
		const raw = JSON.parse(fs.readFileSync(stateFile, "utf-8"));
		const meta = raw.dashboardMeta && typeof raw.dashboardMeta === "object" ? raw.dashboardMeta : {};
		return {
			...raw,
			dashboardMeta: {
				...meta,
				projectDir,
				projectName,
				stateFile,
				sessionStateFile,
				controlPort,
				liveSessionConnected: registeredAgents.size > 0,
				registeredAgents: [...registeredAgents.keys()],
				actionLog: actionLog.slice(-16),
			},
		};
	} catch {
		return null;
	}
}

function broadcastState() {
	const state = readState();
	if (!state) return;
	const msg = "data: " + JSON.stringify(state) + "\n\n";
	for (const res of sseClients) {
		try {
			res.write(msg);
		} catch {
			sseClients.delete(res);
		}
	}
}

const controlServer = net.createServer((socket) => {
	let buffer = "";
	socket.setEncoding("utf-8");
	socket.on("data", (chunk) => {
		buffer += chunk;
		let nl = -1;
		while ((nl = buffer.indexOf("\n")) !== -1) {
			const line = buffer.slice(0, nl).trim();
			buffer = buffer.slice(nl + 1);
			if (!line) continue;
			try {
				handleControlCommand(JSON.parse(line), socket);
			} catch (error) {
				try {
					socket.write(JSON.stringify({ success: false, error: "parse error: " + error.message }) + "\n");
				} catch {}
			}
		}
	});
	socket.on("error", () => {});
	socket.on("close", () => {
		for (const [id, agent] of registeredAgents.entries()) {
			if (agent.socket === socket) registeredAgents.delete(id);
		}
		pushActionLog({ type: "disconnect", status: "info", detail: "A Toolshed session disconnected." });
		broadcastState();
	});
});

function handleControlCommand(cmd, socket) {
	switch (cmd.type) {
		case "register": {
			registeredAgents.set(cmd.agentId, {
				sessionKey: cmd.sessionKey || cmd.agentId,
				socket,
				info: cmd.info || {},
				registeredAt: Date.now(),
			});
			pushActionLog({ type: "register", status: "success", detail: cmd.agentId });
			broadcastState();
			try { socket.write(JSON.stringify({ success: true, command: "register" }) + "\n"); } catch {}
			break;
		}
		case "unregister": {
			registeredAgents.delete(cmd.agentId);
			pushActionLog({ type: "unregister", status: "info", detail: cmd.agentId });
			broadcastState();
			try { socket.write(JSON.stringify({ success: true, command: "unregister" }) + "\n"); } catch {}
			break;
		}
		case "list_agents": {
			const agents = [...registeredAgents.entries()].map(([id, agent]) => ({
				agentId: id,
				sessionKey: agent.sessionKey,
				info: agent.info,
				registeredAt: agent.registeredAt,
			}));
			try { socket.write(JSON.stringify({ success: true, command: "list_agents", agents }) + "\n"); } catch {}
			break;
		}
		default: {
			const result = forwardCommand(cmd);
			try { socket.write(JSON.stringify(result) + "\n"); } catch {}
			break;
		}
	}
}

setInterval(() => {
	try {
		const stat = fs.statSync(stateFile);
		if (stat.mtimeMs !== lastMtime) {
			lastMtime = stat.mtimeMs;
			broadcastState();
		}
	} catch {}
}, 500);

function sendJson(res, status, value) {
	res.writeHead(status, {
		"Content-Type": "application/json",
		"Access-Control-Allow-Origin": "*",
		"Cache-Control": "no-cache",
	});
	res.end(JSON.stringify(value));
}

function sendText(res, status, text, type = "text/html; charset=utf-8") {
	res.writeHead(status, {
		"Content-Type": type,
		"Access-Control-Allow-Origin": "*",
		"Cache-Control": "no-cache",
	});
	res.end(text);
}

