const server = http.createServer((req, res) => {
	const requestUrl = new URL(req.url || "/", "http://127.0.0.1");
	if (requestUrl.pathname === "/api/version") return sendJson(res, 200, { version: SCRIPT_VERSION, projectDir, projectName });
	if (requestUrl.pathname === "/api/state") return sendJson(res, 200, readState());
	if (requestUrl.pathname === "/events") {
		res.writeHead(200, {
			"Content-Type": "text/event-stream",
			"Cache-Control": "no-cache, no-transform",
			Connection: "keep-alive",
			"Access-Control-Allow-Origin": "*",
		});
		res.write("\n");
		sseClients.add(res);
		const state = readState();
		if (state) res.write("data: " + JSON.stringify(state) + "\n\n");
		req.on("close", () => sseClients.delete(res));
		return;
	}
	if (requestUrl.pathname === "/api/action" && req.method === "POST") {
		let body = "";
		req.on("data", (chunk) => body += chunk);
		req.on("end", () => {
			try {
				const cmd = JSON.parse(body || "{}");
				if (!cmd || typeof cmd !== "object" || !cmd.type) return sendJson(res, 400, { success: false, error: "Action type is required." });
				return sendJson(res, 200, forwardCommand(cmd));
			} catch (error) {
				return sendJson(res, 400, { success: false, error: error.message });
			}
		});
		return;
	}
		if (requestUrl.pathname === "/api/generated-app-open" && req.method === "POST") {
			let body = "";
			req.on("data", (chunk) => body += chunk);
			req.on("end", async () => {
				try {
				const payload = JSON.parse(body || "{}");
				const cardId = String(payload.cardId || "").trim();
				const itemId = String(payload.itemId || "").trim() || cardId;
				const toolName = String(payload.toolName || "").trim();
					if (!cardId || !toolName) return sendJson(res, 400, { success: false, error: "cardId and toolName are required." });
					const data = await callGeneratedAppTool(cardId, itemId, toolName, { renderInline: true });
					const toolError = generatedToolErrorText(data.result);
					if (toolError) return sendJson(res, 500, { success: false, error: toolError });
					return sendJson(res, 200, {
						success: true,
						sessionId: data.instance.sessionId || "",
						result: data.result,
				});
			} catch (error) {
				return sendJson(res, 500, { success: false, error: error.message });
			}
		});
		return;
	}
		if (requestUrl.pathname === "/api/generated-app-tool" && req.method === "POST") {
			let body = "";
			req.on("data", (chunk) => body += chunk);
			req.on("end", async () => {
				try {
				const payload = JSON.parse(body || "{}");
				const cardId = String(payload.cardId || "").trim();
				const itemId = String(payload.itemId || "").trim() || cardId;
				const name = String(payload.name || "").trim();
					const args = payload.arguments && typeof payload.arguments === "object" ? payload.arguments : {};
					if (!cardId || !name) return sendJson(res, 400, { success: false, error: "cardId and name are required." });
					const data = await callGeneratedAppTool(cardId, itemId, name, args);
					const toolError = generatedToolErrorText(data.result);
					if (toolError) return sendJson(res, 500, { success: false, error: toolError });
					return sendJson(res, 200, {
						success: true,
						sessionId: data.instance.sessionId || "",
						result: data.result,
				});
			} catch (error) {
				return sendJson(res, 500, { success: false, error: error.message });
			}
		});
		return;
	}
	if (requestUrl.pathname === "/api/generated-app-context" && req.method === "POST") {
		let body = "";
		req.on("data", (chunk) => body += chunk);
		req.on("end", () => {
			try {
				const payload = JSON.parse(body || "{}");
				pushActionLog({
					type: "generated-app-context",
					status: "info",
					detail: clipText(payload && payload.text || "", 120),
				});
				return sendJson(res, 200, { success: true });
			} catch (error) {
				return sendJson(res, 400, { success: false, error: error.message });
			}
		});
		return;
	}
	if (requestUrl.pathname === "/api/generated-app-close" && req.method === "POST") {
		let body = "";
		req.on("data", (chunk) => body += chunk);
		req.on("end", () => {
			try {
				const payload = JSON.parse(body || "{}");
				const cardId = String(payload.cardId || "").trim();
				const itemId = String(payload.itemId || "").trim() || cardId;
				return sendJson(res, 200, { success: true, closed: closeGeneratedAppInstance(cardId, itemId) });
			} catch (error) {
				return sendJson(res, 400, { success: false, error: error.message });
			}
		});
		return;
	}
	if (requestUrl.pathname === "/generated-app-frame") {
		try {
			const cardId = String(requestUrl.searchParams.get("cardId") || "").trim();
			const itemId = String(requestUrl.searchParams.get("itemId") || "").trim() || cardId;
			if (!cardId) return sendText(res, 400, "Generated app cardId is required.", "text/plain; charset=utf-8");
			return sendText(res, 200, buildGeneratedAppFrameHtml(cardId, itemId));
		} catch (error) {
			return sendText(res, 500, "<!doctype html><html><body style=\"margin:0;min-height:100vh;background:oklch(0.145 0 0);color:oklch(0.985 0 0);font:14px/1.5 Geist,ui-sans-serif,sans-serif,system-ui;padding:24px\"><div style=\"max-width:720px;margin:0 auto;padding:24px;border:1px solid color-mix(in oklch,oklch(0.985 0 0) 8%,transparent);border-radius:20px;background:color-mix(in oklch,oklch(0.205 0 0) 92%,transparent)\"><h1 style=\"margin:0 0 12px;font-size:20px;line-height:1.2\">Unable to load generated app</h1><pre style=\"margin:0;padding:14px 16px;border:1px solid color-mix(in oklch,oklch(0.985 0 0) 6%,transparent);border-radius:14px;background:color-mix(in oklch,oklch(0.985 0 0) 2%,transparent);white-space:pre-wrap;font:12px/1.6 \\\"IBM Plex Mono\\\",ui-monospace,monospace\">" + escapeHtml(error.message) + "</pre></div></body></html>");
		}
	}
	if (requestUrl.pathname === "/") return sendText(res, 200, renderPage("lane"));
	if (requestUrl.pathname === "/registry") return sendText(res, 200, renderPage("registry"));
	if (requestUrl.pathname === "/favicon.ico") return sendText(res, 204, "", "text/plain");
	return sendJson(res, 404, { success: false, error: "Not found" });
});

server.listen(port, "127.0.0.1", () => {
	console.log("Pi Toolshed listening on http://127.0.0.1:" + port);
	console.log("State file: " + stateFile);
	console.log("Control socket: tcp://127.0.0.1:" + controlPort);
});

controlServer.listen(controlPort, "127.0.0.1", () => {
	console.log("Toolshed control socket listening on port " + controlPort);
});
