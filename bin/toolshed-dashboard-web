window.addEventListener('scroll', function(){
	const footerHeight = composerShell ? composerShell.getBoundingClientRect().height : 0;
	shouldStickToBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - footerHeight - 80;
});

fetchState();
connectEvents();
setTimeout(syncInlineAppsFromLocalLane, 120);
syncHeaderOffset();
syncFooterOffset();
setComposerStatus('Ready.', '');
`;

function renderPage(pageMode = "lane") {
