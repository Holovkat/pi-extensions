function renderPdfServerApp(item) {
	const state = mcpExampleState(item, 'pdf-server');
	const pages = pdfExamplePages();
	const loadedPages = Math.max(1, Math.min(Number(state.loadedPages || 1), pages.length));
	const currentPage = Math.max(1, Math.min(Number(state.currentPage || 1), loadedPages));
	const page = pages[currentPage - 1];
	return [
		'<div class="mcp-app-shell">',
			'<div class="mcp-app-toolbar"><span class="mcp-app-chip">inline reader</span><span class="mcp-app-chip">chunked bytes</span><span class="mcp-app-chip">model context</span></div>',
			'<div class="mcp-app-grid two">',
				'<section class="mcp-panel' + (state.focused ? ' is-focused' : '') + '">',
					'<div class="mcp-panel-label">Chunked reader</div>',
					'<div class="mcp-inline-actions">',
						'<button type="button" class="ghost-btn card-pill-btn" data-mcp-example-action="pdf-prev" data-mcp-example-item="' + escapeHtml(item.id) + '"' + (currentPage <= 1 ? ' disabled' : '') + '>Prev</button>',
						'<button type="button" class="ghost-btn card-pill-btn" data-mcp-example-action="pdf-next" data-mcp-example-item="' + escapeHtml(item.id) + '"' + (currentPage >= loadedPages ? ' disabled' : '') + '>Next</button>',
						'<button type="button" class="btn card-pill-btn" data-mcp-example-action="pdf-load-more" data-mcp-example-item="' + escapeHtml(item.id) + '"' + (loadedPages >= pages.length ? ' disabled' : '') + '>Load next chunk</button>',
					'</div>',
					'<article class="mcp-pdf-page"><div class="mcp-panel-title">' + escapeHtml(page.title) + '</div><div class="mcp-summary-text">' + escapeHtml(page.body) + '</div></article>',
				'</section>',
				'<section class="mcp-panel">',
					'<div class="mcp-panel-label">Reader state</div>',
					'<div class="mcp-metric">Page ' + escapeHtml(String(currentPage)) + ' / ' + escapeHtml(String(pages.length)) + '</div>',
					'<div class="mcp-summary-text">Loaded ' + escapeHtml(String(loadedPages)) + ' of ' + escapeHtml(String(pages.length)) + ' pages. <code>updateModelContext(...)</code> would currently report: “Reader is on page ' + escapeHtml(String(currentPage)) + '.”</div>',
					'<div class="mcp-inline-actions"><button type="button" class="ghost-btn card-pill-btn" data-mcp-example-action="pdf-focus" data-mcp-example-item="' + escapeHtml(item.id) + '">' + escapeHtml(state.focused ? 'Exit focus' : 'Focus view') + '</button></div>',
				'</section>',
			'</div>',
		'</div>'
	].join('');
}

function renderMapServerApp(item) {
	const state = mcpExampleState(item, 'map-server');
	const locations = mapExampleLocations();
	const query = String(state.query || '').trim().toLowerCase();
	const filtered = locations.filter(function(location) {
		return !query || location.label.toLowerCase().indexOf(query) !== -1;
	});
	const selected = locations.find(function(location) { return location.id === state.selectedLocation; }) || filtered[0] || locations[0];
	return [
		'<div class="mcp-app-shell">',
			'<div class="mcp-app-toolbar"><span class="mcp-app-chip">inline map</span><span class="mcp-app-chip">geocode helper</span><span class="mcp-app-chip">viewUUID restore</span></div>',
			'<div class="mcp-app-grid two">',
				'<section class="mcp-panel' + (state.focused ? ' is-focused' : '') + '">',
					'<div class="mcp-panel-label">Map surface</div>',
					'<input class="mcp-input" data-mcp-example-input="query" data-mcp-example-item="' + escapeHtml(item.id) + '" type="text" placeholder="Search location" value="' + escapeHtml(state.query || '') + '">',
					'<div class="mcp-chip-row">' + filtered.map(function(location) {
						return '<button type="button" class="mcp-chip-btn' + (selected && selected.id === location.id ? ' active' : '') + '" data-mcp-example-action="map-select" data-mcp-example-item="' + escapeHtml(item.id) + '" data-mcp-example-value="' + escapeHtml(location.id) + '">' + escapeHtml(location.label) + '</button>';
					}).join('') + '</div>',
					'<div class="mcp-map-canvas">' + locations.map(function(location) {
						return '<button type="button" class="mcp-map-marker' + (selected && selected.id === location.id ? ' active' : '') + '" style="left:' + escapeHtml(String(location.x)) + '%;top:' + escapeHtml(String(location.y)) + '%" data-mcp-example-action="map-select" data-mcp-example-item="' + escapeHtml(item.id) + '" data-mcp-example-value="' + escapeHtml(location.id) + '" title="' + escapeHtml(location.label) + '"></button>';
					}).join('') + '</div>',
				'</section>',
				'<section class="mcp-panel">',
					'<div class="mcp-panel-label">Visible selection</div>',
					'<div class="mcp-panel-title">' + escapeHtml(selected.label) + '</div>',
					'<div class="mcp-summary-text">' + escapeHtml(selected.detail) + '</div>',
					'<div class="mcp-summary-text"><code>updateModelContext(...)</code> would currently publish: “Map focused on ' + escapeHtml(selected.label) + '.”</div>',
					'<div class="mcp-inline-actions"><button type="button" class="ghost-btn card-pill-btn" data-mcp-example-action="map-focus" data-mcp-example-item="' + escapeHtml(item.id) + '">' + escapeHtml(state.focused ? 'Exit focus' : 'Focus map') + '</button></div>',
				'</section>',
			'</div>',
		'</div>'
	].join('');
}

