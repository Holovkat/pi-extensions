	return [
		"<!doctype html>",
		"<html lang=\"en\">",
		"<head>",
		"<meta charset=\"utf-8\">",
		"<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">",
		"<title>Pi Toolshed — " + escapeHtml(projectName) + "</title>",
		"<style>" + PAGE_CSS + "</style>",
		"</head>",
		"<body>",
		"<div class=\"page\">",
			"<header id=\"floatingHeader\" class=\"floating-header\">",
				"<div class=\"header-shell\">",
					"<section class=\"header-card\">",
						"<div class=\"header-row\">",
							"<div class=\"header-balance\"></div>",
							"<div class=\"brand-block\">",
								"<div class=\"brand-eyebrow\">Pi Toolshed</div>",
								"<div id=\"headerTitle\" class=\"brand-title\">Waiting for Pi Toolshed state</div>",
								"<div id=\"headerMeta\" class=\"brand-meta\">" + escapeHtml(projectName) + " · lane-first web workspace</div>",
							"</div>",
							"<div class=\"header-controls\">",
								"<label class=\"sr-only\" for=\"workspaceSelect\">Workspace preset</label>",
								"<select id=\"workspaceSelect\" class=\"select\"><option>Waiting for state…</option></select>",
								"<button id=\"themeBtn\" type=\"button\" class=\"ghost-btn\">Light</button>",
								"<button type=\"button\" class=\"ghost-btn\" data-open-drawer>Session</button>",
								"<span id=\"connectionPill\" class=\"pill tone-info\">Connecting…</span>",
							"</div>",
						"</div>",
						"<nav class=\"page-nav\" aria-label=\"Toolshed views\">",
							"<a class=\"page-nav-link" + (pageMode === "lane" ? " active" : "") + "\" href=\"/\">Lane</a>",
							"<a class=\"page-nav-link" + (pageMode === "registry" ? " active" : "") + "\" href=\"/registry\">Registry</a>",
						"</nav>",
						"<div id=\"headerPills\" class=\"header-pills\"></div>",
					"</section>",
				"</div>",
			"</header>",
			"<main class=\"layout\">",
				"<aside id=\"leftDock\" class=\"dock left-dock\"><div class=\"dock-empty\">Waiting for workspace widgets…</div></aside>",
				"<section class=\"lane-shell\">",
					"<section class=\"hero-card\">",
						"<div class=\"section-label\">Workspace preset</div>",
						"<div id=\"heroTitle\" class=\"hero-title\">Waiting for Pi Toolshed state</div>",
						"<div id=\"heroCopy\" class=\"hero-copy\">Open /toolshed-web in Pi to bind the lane to this browser workspace.</div>",
						"<div id=\"heroMeta\" class=\"hero-meta\">" + escapeHtml(projectDir) + "</div>",
						"<div id=\"heroPills\" class=\"hero-pills\"></div>",
						"<div id=\"quickActions\" class=\"quick-action-grid\"></div>",
						"<div id=\"inlineWidgets\" class=\"inline-widgets\"></div>",
					"</section>",
					"<section id=\"lane\" class=\"lane\"></section>",
					"<section id=\"registryView\" class=\"registry-view\"" + (pageMode === "registry" ? "" : " hidden") + "></section>",
					"<div id=\"floatLayer\" class=\"float-layer\"></div>",
				"</section>",
				"<aside id=\"rightDock\" class=\"dock right-dock\"><div class=\"dock-empty\">Waiting for telemetry widgets…</div></aside>",
			"</main>",
		"</div>",
		"<div id=\"composerShell\" class=\"composer-shell\">",
