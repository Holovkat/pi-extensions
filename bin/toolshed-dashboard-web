function renderWikiExplorerApp(item) {
	const state = mcpExampleState(item, 'wiki-explorer-server');
	const graph = wikiExampleGraph();
	const expanded = Array.isArray(state.expandedNodes) ? state.expandedNodes.slice() : ['model-context-protocol'];
	const visibleIds = ['model-context-protocol'];
	expanded.forEach(function(nodeId) {
		if (visibleIds.indexOf(nodeId) === -1) visibleIds.push(nodeId);
		const node = graph[nodeId];
		if (node && Array.isArray(node.children)) {
			node.children.forEach(function(child) {
				if (visibleIds.indexOf(child) === -1) visibleIds.push(child);
			});
		}
	});
	const selected = graph[state.selectedNode] || graph['model-context-protocol'];
	return [
		'<div class="mcp-app-shell">',
			'<div class="mcp-app-toolbar"><span class="mcp-app-chip">graph explorer</span><span class="mcp-app-chip">structuredContent</span><span class="mcp-app-chip">recursive tool calls</span></div>',
			'<div class="mcp-app-grid two">',
				'<section class="mcp-panel">',
					'<div class="mcp-panel-label">Node graph</div>',
					'<div class="mcp-node-grid">' + visibleIds.map(function(nodeId) {
						const node = graph[nodeId];
						return '<button type="button" class="mcp-node' + ((state.selectedNode || 'model-context-protocol') === nodeId ? ' active' : '') + '" data-mcp-example-action="wiki-select" data-mcp-example-item="' + escapeHtml(item.id) + '" data-mcp-example-value="' + escapeHtml(nodeId) + '">' + escapeHtml(node.label) + '</button>';
					}).join('') + '</div>',
				'</section>',
				'<section class="mcp-panel">',
					'<div class="mcp-panel-label">Selected article</div>',
					'<div class="mcp-panel-title">' + escapeHtml(selected.label) + '</div>',
					'<div class="mcp-summary-text">' + escapeHtml(selected.excerpt) + '</div>',
					'<div class="mcp-inline-actions">',
						'<button type="button" class="btn card-pill-btn" data-mcp-example-action="wiki-expand" data-mcp-example-item="' + escapeHtml(item.id) + '" data-mcp-example-value="' + escapeHtml(state.selectedNode || 'model-context-protocol') + '">Expand links</button>',
						'<a class="mcp-example-link" href="https://en.wikipedia.org/wiki/' + escapeHtml(selected.label.replace(/\s+/g, '_')) + '" target="_blank" rel="noreferrer">Open article</a>',
					'</div>',
				'</section>',
			'</div>',
		'</div>'
	].join('');
}

function renderMcpExampleApp(item, example) {
	if (!example) return '';
	if (example.id === 'basic-server-react') return renderBasicServerReactApp(item);
	if (example.id === 'pdf-server') return renderPdfServerApp(item);
	if (example.id === 'map-server') return renderMapServerApp(item);
	if (example.id === 'video-resource-server') return renderVideoResourceApp(item);
	if (example.id === 'wiki-explorer-server') return renderWikiExplorerApp(item);
	return '';
}
const contextPickerState = {
	slash: { query: '', open: false, selectedIndex: 0, filtered: [] },
	skill: { query: '', open: false, selectedIndex: 0, filtered: [] },
	packet: { query: '', open: false, selectedIndex: 0, filtered: [] },
};

function escapeHtml(value) {
	return String(value == null ? '' : value)
		.replace(/&/g, '&amp;')
		.replace(/</g, '&lt;')
		.replace(/>/g, '&gt;')
		.replace(/\"/g, '&quot;')
		.replace(/'/g, '&#39;');
}

function decodePayload(value) {
	if (!value) return {};
	try { return JSON.parse(decodeURIComponent(value)); }
	catch { return {}; }
}

function encodePayload(value) {
	return encodeURIComponent(JSON.stringify(value || {}));
}

function formatTime(value) {
	const date = new Date(value || Date.now());
	if (Number.isNaN(date.getTime())) return 'unknown';
	return date.toLocaleString();
}

function relativeTime(value) {
	const date = new Date(value || Date.now());
	if (Number.isNaN(date.getTime())) return 'unknown';
	const ms = Date.now() - date.getTime();
	const minutes = Math.round(ms / 60000);
	if (minutes <= 1) return 'just now';
	if (minutes < 60) return minutes + 'm ago';
	const hours = Math.round(minutes / 60);
	if (hours < 24) return hours + 'h ago';
	const days = Math.round(hours / 24);
	return days + 'd ago';
}

function renderMultiline(text) {
	return escapeHtml(String(text || '')).replace(/\n/g, '<br>');
}

function renderInlineMarkdown(text) {
	let html = escapeHtml(String(text || ''));
	html = html.replace(/\x60([^\x60]+)\x60/g, '<code>$1</code>');
	html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
	html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');
	html = html.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g, '<a href="$2" target="_blank" rel="noreferrer">$1</a>');
	return html;
}

function isMarkdownTableRow(line) {
	const trimmed = String(line || '').trim();
	return trimmed.includes('|') && !/^\s*[-*]\s+/.test(trimmed) && !/^\s*\d+\.\s+/.test(trimmed) && !/^\s*>/.test(trimmed);
}

function isMarkdownTableSeparator(line) {
	const trimmed = String(line || '').trim().replace(/^\||\|$/g, '');
	if (!trimmed) return false;
	const cells = trimmed.split('|').map(function(cell) { return cell.trim(); }).filter(Boolean);
	if (cells.length === 0) return false;
	return cells.every(function(cell) { return /^:?-{3,}:?$/.test(cell); });
}

function splitMarkdownTableCells(line) {
	return String(line || '')
		.trim()
		.replace(/^\||\|$/g, '')
		.split('|')
		.map(function(cell) { return cell.trim(); });
}

function renderMarkdownTable(lines) {
	if (!Array.isArray(lines) || lines.length < 2) return '';
	const headerCells = splitMarkdownTableCells(lines[0]);
	if (headerCells.length === 0) return '';
	const bodyRows = lines.slice(2)
		.filter(function(line) { return String(line || '').trim(); })
		.map(function(line) { return splitMarkdownTableCells(line); });
	return '<div class="lane-table-wrap"><table><thead><tr>'
		+ headerCells.map(function(cell) { return '<th>' + renderInlineMarkdown(cell) + '</th>'; }).join('')
		+ '</tr></thead>'
		+ '<tbody>'
		+ bodyRows.map(function(row) {
			return '<tr>' + headerCells.map(function(_cell, index) {
				return '<td>' + renderInlineMarkdown(row[index] || '') + '</td>';
			}).join('') + '</tr>';
		}).join('')
		+ '</tbody></table></div>';
}

function renderMarkdown(text) {
	const source = String(text || '').replace(/\r/g, '');
	if (!source.trim()) return '';
	const fencePattern = /\x60\x60\x60([^\n\x60]*)\n?([\s\S]*?)\x60\x60\x60/g;
	let html = '';
	let lastIndex = 0;
	let match;
	while ((match = fencePattern.exec(source)) !== null) {
		html += renderMarkdownBlocks(source.slice(lastIndex, match.index));
		html += '<pre><code>' + escapeHtml(match[2].replace(/\n$/, '')) + '</code></pre>';
		lastIndex = match.index + match[0].length;
	}
	html += renderMarkdownBlocks(source.slice(lastIndex));
	return html;
}

function renderMarkdownBlocks(text) {
	const source = String(text || '').trim();
	if (!source) return '';
	const blocks = source.split(/\n\s*\n/);
	return blocks.map(function(block) {
		const trimmed = block.trim();
		if (!trimmed) return '';
		const lines = trimmed.split('\n');
		for (let index = 0; index < lines.length - 1; index++) {
			if (!isMarkdownTableRow(lines[index]) || !isMarkdownTableSeparator(lines[index + 1])) continue;
			let end = index + 2;
			while (end < lines.length && isMarkdownTableRow(lines[end])) end++;
			return [
				index > 0 ? renderMarkdownBlocks(lines.slice(0, index).join('\n')) : '',
				renderMarkdownTable(lines.slice(index, end)),
				end < lines.length ? renderMarkdownBlocks(lines.slice(end).join('\n')) : '',
			].join('');
		}
		if (/^(?:[-*]\s.+\n?)+$/.test(trimmed)) {
			return '<ul>' + trimmed.split('\n').map(function(line) {
				return '<li>' + renderInlineMarkdown(line.replace(/^[-*]\s+/, '')) + '</li>';
			}).join('') + '</ul>';
		}
		if (/^(?:\d+\.\s.+\n?)+$/.test(trimmed)) {
			return '<ol>' + trimmed.split('\n').map(function(line) {
				return '<li>' + renderInlineMarkdown(line.replace(/^\d+\.\s+/, '')) + '</li>';
			}).join('') + '</ol>';
		}
		if (/^(?:>\s?.+\n?)+$/.test(trimmed)) {
			return '<blockquote>' + trimmed.split('\n').map(function(line) {
				return renderInlineMarkdown(line.replace(/^>\s?/, ''));
			}).join('<br>') + '</blockquote>';
		}
		return '<p>' + trimmed.split('\n').map(renderInlineMarkdown).join('<br>') + '</p>';
	}).join('');
}

function clipText(text, maxChars) {
	const value = String(text || '').replace(/\r/g, '').trim();
	if (!value) return '';
	if (value.length <= maxChars) return value;
	const clipped = value.slice(0, maxChars - 1).replace(/\s+\S*$/, '').trimEnd();
	return (clipped || value.slice(0, maxChars - 1)).replace(/[,:;.\-–—\s]+$/, '') + '…';
}

function pillMarkup(chip, extra) {
	return '<span class="pill ' + escapeHtml(extra || chip.tone || 'info') + '">' + escapeHtml(chip.label || '') + '</span>';
}

function connectionLabel() {
	if (connectionState === 'connected') return { label: 'Dashboard live', tone: 'success' };
	if (connectionState === 'reconnecting') return { label: 'Reconnecting…', tone: 'warning' };
	if (connectionState === 'offline') return { label: 'Dashboard offline', tone: 'error' };
	return { label: 'Connecting…', tone: 'info' };
}

function setComposerStatus(message, tone) {
	if (!composerStatus) return;
	composerStatus.textContent = message || 'Ready.';
	composerStatus.className = 'toolbar-status composer-status ' + (tone ? 'tone-' + tone : '');
}

function positionContextPicker(kind) {
	const config = contextPickers[kind];
	const state = contextPickerState[kind];
	if (!config || !config.root || !config.input) return;
	config.root.classList.remove('align-start', 'align-end');
	if (!state || !state.open) return;
	const popupWidth = Math.min(340, Math.max(248, window.innerWidth - 32));
	const rect = config.input.getBoundingClientRect();
	const centeredLeft = rect.left + rect.width / 2 - popupWidth / 2;
	const centeredRight = centeredLeft + popupWidth;
	if (centeredLeft < 16) {
		config.root.classList.add('align-start');
		return;
	}
	if (centeredRight > window.innerWidth - 16) config.root.classList.add('align-end');
}

function positionOpenContextPickers() {
	Object.keys(contextPickers).forEach(positionContextPicker);
}

function syncFooterOffset() {
	const height = composerShell ? Math.ceil(composerShell.getBoundingClientRect().height) : 0;
	document.documentElement.style.setProperty('--footer-offset', Math.max(height, 160) + 'px');
}

function syncHeaderOffset() {
	const height = floatingHeader ? Math.ceil(floatingHeader.getBoundingClientRect().height) : 90;
	document.documentElement.style.setProperty('--header-offset', Math.max(height, 64) + 'px');
}

function searchableText(parts) {
	return (parts || []).filter(Boolean).join(' ').toLowerCase();
}

function filterScore(query, haystack) {
	const normalizedQuery = String(query || '').trim().toLowerCase();
	if (!normalizedQuery) return 1;
	const target = String(haystack || '').toLowerCase();
	let score = target.includes(normalizedQuery) ? 200 + normalizedQuery.length : 0;
	const tokens = normalizedQuery.split(/\s+/).filter(Boolean);
	tokens.forEach(function(token) {
		if (target.includes(token)) score += 24 + token.length;
	});
	return score;
}

function contextItems(kind) {
	if (!currentState) return [];
	if (kind === 'slash') {
		return (currentState.slashCommands || []).map(function(command) {
			return {
				key: command.id || command.command,
				label: command.label || command.command,
				copy: command.description || command.command,
				insertText: command.command,
				action: { type: 'submit-slash-command', command: command.command },
				searchable: searchableText([command.label, command.command, command.description]),
			};
		});
	}
	if (kind === 'skill') {
		return (currentState.skills || []).map(function(skill) {
			return {
				key: skill.id,
				label: skill.label,
				copy: skill.description,
				insertText: 'Use the skill "' + skill.label + '" for the current frontier and return a concise summary.',
				action: { type: 'launch-skill', skill: skill.id },
				searchable: searchableText([skill.label, skill.id, skill.description, skill.sourcePath]),
			};
		});
	}
	return (currentState.packets || []).map(function(packet) {
		return {
			key: packet.id,
			label: '[' + packet.status + '] ' + packet.title,
			copy: packet.summary,
			insertText: 'Use the packet "' + packet.title + '" as context: ' + packet.summary,
			action: { type: 'inject-packet', packetId: packet.id },
			searchable: searchableText([packet.title, packet.summary, packet.body, packet.status]),
		};
	});
}

function selectedContextItem(kind) {
	const state = contextPickerState[kind];
	return state && state.filtered.length > 0 && state.selectedIndex >= 0
		? state.filtered[state.selectedIndex]
		: null;
}

function refreshContextPicker(kind) {
	const config = contextPickers[kind];
	const state = contextPickerState[kind];
	if (!config || !state) return;
	const query = String(state.query || '');
	const items = contextItems(kind)
		.map(function(item) { return { ...item, _score: filterScore(query, item.searchable) }; })
		.filter(function(item) { return !query.trim() || item._score > 0; })
		.sort(function(a, b) {
			if (b._score !== a._score) return b._score - a._score;
			return String(a.label || '').localeCompare(String(b.label || ''));
		})
		.slice(0, 8);
	state.filtered = items;
	if (state.selectedIndex >= items.length) state.selectedIndex = items.length > 0 ? 0 : -1;
	if (state.selectedIndex < 0 && items.length > 0) state.selectedIndex = 0;
	config.input.value = query;
	if (config.root) config.root.classList.toggle('open', !!state.open);
	const showList = state.open && items.length > 0;
	config.list.hidden = !showList;
	config.list.innerHTML = showList
		? items.map(function(item, index) {
			return [
				'<button type="button" class="context-option' + (index === state.selectedIndex ? ' active' : '') + '" data-picker-kind="' + escapeHtml(kind) + '" data-picker-index="' + index + '">',
					'<div class="context-option-title">' + escapeHtml(item.label) + '</div>',
					(item.copy ? '<div class="context-option-copy">' + escapeHtml(item.copy) + '</div>' : ''),
				'</button>',
			].join('');
		}).join('')
		: '';
	const selected = selectedContextItem(kind);
	config.hint.textContent = selected
		? 'Enter runs ' + selected.label + ' · Tab inserts it into the prompt.'
		: (query.trim() ? 'No matching items yet.' : config.baseHint);
	positionContextPicker(kind);
	syncFooterOffset();
}

function refreshContextPickers() {
	refreshContextPicker('slash');
	refreshContextPicker('skill');
	refreshContextPicker('packet');
}

function closeContextPicker(kind) {
	const state = contextPickerState[kind];
	if (!state) return;
	state.open = false;
	refreshContextPicker(kind);
}

function closeAllContextPickers(exceptKind) {
	Object.keys(contextPickerState).forEach(function(kind) {
		if (kind === exceptKind) return;
		const state = contextPickerState[kind];
		if (!state) return;
		if (!state.open) return;
		state.open = false;
		refreshContextPicker(kind);
	});
}

function resetContextPicker(kind) {
	const config = contextPickers[kind];
	const state = contextPickerState[kind];
	if (!config || !state) return;
	state.query = '';
	state.open = false;
	state.selectedIndex = 0;
	state.filtered = [];
	config.input.value = '';
	refreshContextPicker(kind);
}

function submitContextPicker(kind) {
	const item = selectedContextItem(kind);
	if (!item) {
		closeContextPicker(kind);
		return;
	}
	postAction(item.action, false);
	resetContextPicker(kind);
}

function insertContextPicker(kind) {
	const item = selectedContextItem(kind);
	if (!item) {
		closeContextPicker(kind);
		return;
	}
	insertIntoComposer(item.insertText || item.label);
	resetContextPicker(kind);
	composerInput.focus();
}

function scrollFrontierIntoView() {
	const frontier = document.querySelector('[data-frontier="true"]');
	if (!frontier) return;
	const footerHeight = composerShell ? composerShell.getBoundingClientRect().height : 0;
	const rect = frontier.getBoundingClientRect();
	const safeBottom = footerHeight + 28;
	const bottomOverflow = rect.bottom - (window.innerHeight - safeBottom);
	if (bottomOverflow > 0) {
		window.scrollBy({ top: bottomOverflow, behavior: 'smooth' });
	}
}

function currentWorkspace() {
	if (!currentState || !Array.isArray(currentState.workspaces)) return null;
	return currentState.workspaces.find(function(workspace){ return workspace.id === currentState.workspaceId; }) || currentState.workspaces[0] || null;
}

function visibleWidgets() {
	if (!currentState || !Array.isArray(currentState.widgets)) return [];
	return currentState.widgets.slice();
}

function sortWidgets(widgets) {
	return widgets.slice();
}

function actionButtonMarkup(action, className) {
	if (!action) return '';
	const tone = action.variant === 'primary' ? 'btn primary' : action.variant === 'ghost' ? 'ghost-btn' : 'btn';
	const hint = action.label || 'Run';
	const pill = action.display === 'pill' || className === 'card-pill-btn';
	if (pill) {
		const pillClass = className && className !== 'card-pill-btn' ? className : tone;
		return '<button type="button" class="' + escapeHtml(pillClass + ' card-pill-btn') + '" data-action-type="' + escapeHtml(action.type || '') + '" data-action-payload="' + encodePayload(action.payload || {}) + '">' + escapeHtml(action.label || 'Run') + '</button>';
	}
	const iconMap = {
		'send-message': '↗',
		'submit-slash-command': '/',
		'launch-skill': '✦',
		'inject-packet': '⎘',
		'freeze-frontier': '◷',
		'switch-workspace': '⌘',
		'open-mcp-tool': '◎',
		'open-blueprint-web': '⌂',
		'run-card': '▶',
		'delete-custom-card': '×',
		'seed-mermaid-card': '◇',
		'abort-run': '■',
		'reset-layout': '↺',
	};
	const icon = iconMap[action.type] || '•';
	return '<button type="button" class="' + escapeHtml((className || tone) + ' widget-icon-btn') + '" data-hint="' + escapeHtml(hint) + '" aria-label="' + escapeHtml(hint) + '" title="' + escapeHtml(hint) + '" data-action-type="' + escapeHtml(action.type || '') + '" data-action-payload="' + encodePayload(action.payload || {}) + '">' + escapeHtml(icon) + '</button>';
}

function widgetIconButton(attrs) {
	return '<button type="button" class="mini-btn widget-icon-btn' + (attrs.active ? ' active' : '') + '" data-hint="' + escapeHtml(attrs.hint || '') + '" aria-label="' + escapeHtml(attrs.hint || '') + '" title="' + escapeHtml(attrs.hint || '') + '"' + attrs.dataAttrs + '>' + escapeHtml(attrs.icon || '•') + '</button>';
}

function widgetChromeMarkup(widget) {
	return [
		'<div class="widget-chrome">',
			widgetIconButton({
				icon: widget.collapsed ? '▸' : '▾',
				hint: widget.collapsed ? 'Expand' : 'Collapse',
				dataAttrs: ' data-widget-collapse="' + escapeHtml(widget.id) + '"',
			}),
			(widget.removable ? widgetIconButton({
				icon: '×',
				hint: 'Remove card',
				dataAttrs: ' data-action-type="delete-custom-card" data-action-payload="' + encodePayload({ cardId: widget.id }) + '"',
			}) : ''),
		'</div>'
	].join('');
}

function metadataMarkup(widget) {
	if (!widget || !Array.isArray(widget.metadata) || widget.metadata.length === 0) return '';
	return '<div class="card-meta">' + widget.metadata.map(function(item){
		return pillMarkup({ label: item.label + ': ' + item.value, tone: 'neutral' });
	}).join('') + '</div>';
}

function parseWidgetFact(line) {
	const text = String(line || '').trim();
	if (!text) return null;
	const match = text.match(/^([^:]{1,32}):\s*(.+)$/);
	return match ? { label: match[1], value: match[2] } : { label: '', value: text };
}

function widgetFactsMarkup(widget) {
	if (!widget || !Array.isArray(widget.lines) || widget.lines.length === 0) return '';
	return '<div class="widget-facts">' + widget.lines.map(function(line) {
		const fact = parseWidgetFact(line);
		if (!fact) return '';
		if (!fact.label) {
			return '<div class="widget-fact full"><div class="widget-fact-value">' + renderMultiline(fact.value) + '</div></div>';
		}
		return '<div class="widget-fact"><div class="widget-fact-label">' + escapeHtml(fact.label) + '</div><div class="widget-fact-value">' + renderMultiline(fact.value) + '</div></div>';
	}).join('') + '</div>';
}

function builderExampleMarkup(example) {
	if (!example) return '';
	const sources = Array.isArray(example.sources) ? example.sources : [];
	const compliance = Array.isArray(example.compliance) ? example.compliance : [];
	const howItWorks = Array.isArray(example.howItWorks) ? example.howItWorks : [];
	const presetPayload = encodePayload(example.preset || {});
	const visibleChips = compliance.slice(0, 2);
	const detailsMarkup = (sources.length > 0 || compliance.length > 0 || howItWorks.length > 0 || example.toolSnippet || example.viewSnippet)
		? [
			'<details class="card-details builder-example-details">',
				'<summary>Pattern notes</summary>',
				'<div class="card-details-body">',
					(howItWorks.length > 0 ? '<div class="builder-example-block"><div class="builder-example-label">How it works</div><ul class="builder-example-list">' + howItWorks.map(function(line) {
						return '<li>' + escapeHtml(line) + '</li>';
					}).join('') + '</ul></div>' : ''),
					(compliance.length > 0 ? '<div class="builder-example-block"><div class="builder-example-label">Checklist</div><div class="builder-example-chips">' + compliance.map(function(label) {
						return pillMarkup({ label: label, tone: 'neutral' });
					}).join('') + '</div></div>' : ''),
					(sources.length > 0 ? '<div class="builder-example-block"><div class="builder-example-label">References</div><div class="builder-example-sources">' + sources.map(function(source) {
						return '<a class="builder-example-source" href="' + escapeHtml(source.url || '#') + '" target="_blank" rel="noreferrer">' + escapeHtml(source.label || source.url || 'Source') + '</a>';
					}).join('') + '</div></div>' : ''),
					(example.toolSnippet ? '<div class="builder-example-block"><div class="builder-example-label">Tool + resource</div><pre class="builder-example-code">' + escapeHtml(example.toolSnippet) + '</pre></div>' : ''),
					(example.viewSnippet ? '<div class="builder-example-block"><div class="builder-example-label">View bridge</div><pre class="builder-example-code">' + escapeHtml(example.viewSnippet) + '</pre></div>' : ''),
				'</div>',
			'</details>',
		].join('')
		: '';
	return [
		'<section class="builder-example">',
			'<div class="builder-example-head">',
				'<div>',
					'<div class="builder-example-kicker">MCP example</div>',
					'<div class="builder-example-title">' + escapeHtml(example.title || 'Starter') + '</div>',
				'</div>',
				'<div class="builder-example-meta">'
					+ (sources.length > 0 ? '<span class="builder-example-meta-chip">' + escapeHtml(String(sources.length)) + ' refs</span>' : '')
					+ (howItWorks.length > 0 ? '<span class="builder-example-meta-chip">' + escapeHtml(String(howItWorks.length)) + ' notes</span>' : '')
				+ '</div>',
			'</div>',
			(example.summary ? '<div class="builder-example-summary">' + escapeHtml(example.summary) + '</div>' : ''),
			(visibleChips.length > 0 ? '<div class="builder-example-chips compact">' + visibleChips.map(function(label) {
				return pillMarkup({ label: label, tone: 'neutral' });
			}).join('') + '</div>' : ''),
			'<div class="card-actions-row">',
				'<button type="button" class="btn card-pill-btn" data-builder-example-fill="' + presetPayload + '">Use template</button>',
				'<button type="button" class="btn primary card-pill-btn" data-builder-example-lane="' + escapeHtml(example.id || '') + '">Add to lane</button>',
				'<button type="button" class="ghost-btn card-pill-btn" data-builder-example-seed="' + escapeHtml(example.id || '') + '">Seed card</button>',
			'</div>',
			detailsMarkup,
		'</section>'
	].join('');
}

