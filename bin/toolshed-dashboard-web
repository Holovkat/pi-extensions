			'</div>',
			'<div class="card-inline-copy">This panel acts as a launcher plus saved-card library. Interview questions and build steps stay in the conversation lane.</div>',
		'</section>',
	].join('');
	const examples = Array.isArray(widget.builderExamples) && widget.builderExamples.length > 0
