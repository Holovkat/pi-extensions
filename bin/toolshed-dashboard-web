					"<div id=\"composerSubtitle\" class=\"composer-subtitle\">Widgets support the lane. They do not replace it.</div>",
				"</div>",
                "<div class=\"composer-frame\">",
                    "<form id=\"composerForm\" class=\"composer-form\">",
                        "<label class=\"sr-only\" for=\"composerInput\">Composer</label>",
                        "<textarea id=\"composerInput\" class=\"composer-input\" placeholder=\"request...\"></textarea>",
                        "<div class=\"quick-action-grid composer-foot\">",
                            "<div class=\"toolbar-left\">",
                                "<button id=\"freezeBtn\" type=\"button\" class=\"ghost-btn\">Freeze</button>",
                                "<button id=\"stopBtn\" type=\"button\" class=\"ghost-btn\">Stop</button>",
