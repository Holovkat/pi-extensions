	refreshContextPickers();
}

function renderDrawer() {
	if (!currentState) {
		drawerBody.innerHTML = '<div class="drawer-card"><div class="empty-state">No state yet.</div></div>';
		return;
	}
	const meta = currentState.dashboardMeta || {};
	const docs = Array.isArray(currentState.documents) ? currentState.documents : [];
	const skills = Array.isArray(currentState.skills) ? currentState.skills : [];
	const mcpServers = currentState.mcp && Array.isArray(currentState.mcp.servers) ? currentState.mcp.servers : [];
	const actionLog = Array.isArray(meta.actionLog) ? meta.actionLog : [];
	const repo = currentState.repository;
	const sections = [];
	sections.push([
		'<section class="drawer-card">',
			'<div class="drawer-title">Session context</div>',
			'<div class="drawer-copy">Runtime binding for the current Toolshed lane.</div>',
			'<div class="drawer-list">',
				'<div class="drawer-item"><div class="drawer-item-title">Project</div><div class="drawer-item-value"><code>' + escapeHtml(meta.projectDir || PROJECT_DIR) + '</code></div></div>',
				'<div class="drawer-item"><div class="drawer-item-title">State file</div><div class="drawer-item-value"><code>' + escapeHtml(meta.stateFile || STATE_FILE) + '</code></div></div>',
				'<div class="drawer-item"><div class="drawer-item-title">Session file</div><div class="drawer-item-value"><code>' + escapeHtml(meta.sessionStateFile || '') + '</code></div></div>',
				'<div class="drawer-item"><div class="drawer-item-title">Web bridge</div><div class="drawer-item-value">' + escapeHtml(String(meta.controlPort || CONTROL_PORT)) + ' · ' + escapeHtml((meta.registeredAgents || []).join(', ') || 'waiting for session') + '</div></div>',
			'</div>',
		'</section>'
	].join(''));
	sections.push([
		'<section class="drawer-card">',
			'<div class="drawer-title">Documents</div>',
			'<div class="drawer-list">',
				(docs.length > 0 ? docs.map(function(doc){
					return '<div class="drawer-item"><div class="drawer-item-title">' + escapeHtml(doc.label) + '</div><div class="drawer-item-value">' + escapeHtml(doc.exists ? doc.path : 'Missing') + '</div></div>';
				}).join('') : '<div class="drawer-item"><div class="drawer-item-value">No documents reported.</div></div>'),
			'</div>',
		'</section>'
	].join(''));
	sections.push([
		'<section class="drawer-card">',
			'<div class="drawer-title">Capabilities</div>',
			'<div class="drawer-list">',
				'<div class="drawer-item"><div class="drawer-item-title">Skills</div><div class="drawer-item-value">' + escapeHtml(skills.length > 0 ? skills.map(function(skill){ return skill.label; }).join(', ') : 'No local skills detected.') + '</div></div>',
				'<div class="drawer-item"><div class="drawer-item-title">MCP</div><div class="drawer-item-value">' + escapeHtml(mcpServers.length > 0 ? mcpServers.map(function(server){ return server.label + ' (' + server.transport + ')'; }).join(', ') : 'No MCP servers configured.') + '</div></div>',
				(repo ? '<div class="drawer-item"><div class="drawer-item-title">Repository</div><div class="drawer-item-value">' + escapeHtml(repo.branch + (repo.dirty ? ' · ' + repo.changed + ' changed' : ' · clean')) + '</div></div>' : ''),
			'</div>',
		'</section>'
	].join(''));
	sections.push([
		'<section class="drawer-card">',
			'<div class="drawer-title">Recent actions</div>',
			'<div class="drawer-list">',
				(actionLog.length > 0 ? actionLog.slice().reverse().map(function(entry){
					return '<div class="drawer-item"><div class="drawer-item-title">' + escapeHtml(entry.type || 'action') + '</div><div class="drawer-item-value">' + escapeHtml((entry.status || 'info') + ' · ' + (entry.detail || '') + ' · ' + relativeTime(entry.at)) + '</div></div>';
				}).join('') : '<div class="drawer-item"><div class="drawer-item-value">No action log yet.</div></div>'),
			'</div>',
		'</section>'
	].join(''));
	drawerBody.innerHTML = sections.join('');
}

function renderState(state) {
	currentState = state;
	syncGeneratedAppLaneItemsFromState();
	renderHeader();
	renderContextFilters();
	renderWidgets();
	if (PAGE_MODE === 'registry') {
		if (lane) lane.hidden = true;
		if (floatLayer) floatLayer.hidden = true;
		if (registryView) registryView.hidden = false;
		renderRegistry();
	} else {
		if (registryView) registryView.hidden = true;
		if (lane) lane.hidden = false;
		if (floatLayer) floatLayer.hidden = false;
		renderLane();
	}
	renderDrawer();
}

async function fetchState() {
	try {
		const res = await fetch('/api/state');
		const state = await res.json();
		if (state) renderState(state);
		connectionState = 'connected';
		renderHeader();
	} catch {
		connectionState = 'offline';
		renderHeader();
	}
}

async function postAction(action, clearComposer) {
	setComposerStatus('Sending action…', 'info');
	try {
		const res = await fetch('/api/action', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(action || {}),
		});
		const data = await res.json();
		if (!data.success) {
			setComposerStatus(data.error || 'Action failed.', 'error');
			return { success: false, data: data };
		}
		if (clearComposer) composerInput.value = '';
		setComposerStatus('Action sent.', 'success');
		if (action && ['send-message', 'run-card', 'create-custom-card', 'create-mcp-app-card', 'add-builder-example-to-lane', 'submit-slash-command', 'launch-skill'].includes(action.type) && shouldStickToBottom) {
			requestAnimationFrame(function(){ window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' }); });
		}
		setTimeout(function(){ if (composerStatus.textContent === 'Action sent.') setComposerStatus('Ready.', ''); }, 1400);
		return { success: true, data: data };
	} catch (error) {
		setComposerStatus((error && error.message) || 'Action failed.', 'error');
		return { success: false, error: error };
	}
}

function insertIntoComposer(text) {
	if (!text) return;
	composerInput.value = composerInput.value ? composerInput.value + '\n' + text : text;
	composerInput.focus();
	setComposerStatus('Inserted into composer.', 'info');
}

function openDrawer() {
	drawer.classList.add('open');
	drawer.setAttribute('aria-hidden', 'false');
	drawerScrim.hidden = false;
	requestAnimationFrame(function(){ drawerScrim.classList.add('open'); });
}

function closeDrawer() {
	drawer.classList.remove('open');
	drawer.setAttribute('aria-hidden', 'true');
	drawerScrim.classList.remove('open');
	setTimeout(function(){ if (!drawer.classList.contains('open')) drawerScrim.hidden = true; }, 180);
}

function connectEvents() {
	if (eventSource) {
		try { eventSource.close(); } catch {}
		eventSource = null;
	}
	connectionState = 'connecting';
	renderHeader();
	eventSource = new EventSource('/events');
	eventSource.onopen = function() {
		connectionState = 'connected';
		renderHeader();
	};
	eventSource.onmessage = function(event) {
		try {
			const state = JSON.parse(event.data);
			renderState(state);
			connectionState = 'connected';
			renderHeader();
		} catch {}
	};
	eventSource.onerror = function() {
		connectionState = 'reconnecting';
		renderHeader();
		try { eventSource.close(); } catch {}
		eventSource = null;
		if (reconnectTimer) clearTimeout(reconnectTimer);
		reconnectTimer = setTimeout(connectEvents, 2000);
	};
}

function handleMcpExampleAction(action, itemId, value) {
	if (!action || !itemId) return false;
	if (action === 'refresh-time') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.serverTime = new Date().toISOString();
			item.appState.log = ['callServerTool(get-time) → ' + item.appState.serverTime].concat(Array.isArray(item.appState.log) ? item.appState.log : []).slice(0, 4);
		});
	}
	if (action === 'send-message') {
		return updateLocalLaneItem(itemId, function(item) {
			const text = String(item.appState.messageText || '').trim();
			if (!text) return;
			item.appState.log = ['sendMessage(user) → ' + text].concat(Array.isArray(item.appState.log) ? item.appState.log : []).slice(0, 4);
			item.appState.messageText = '';
		});
	}
	if (action === 'pdf-prev') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.currentPage = Math.max(1, Number(item.appState.currentPage || 1) - 1);
		});
	}
	if (action === 'pdf-next') {
		return updateLocalLaneItem(itemId, function(item) {
			const loadedPages = Math.max(1, Number(item.appState.loadedPages || 1));
			item.appState.currentPage = Math.min(loadedPages, Number(item.appState.currentPage || 1) + 1);
		});
	}
	if (action === 'pdf-load-more') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.loadedPages = Math.min(pdfExamplePages().length, Math.max(1, Number(item.appState.loadedPages || 1) + 1));
		});
	}
	if (action === 'pdf-focus') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.focused = !item.appState.focused;
		});
	}
	if (action === 'map-select') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.selectedLocation = value;
		});
	}
	if (action === 'map-focus') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.focused = !item.appState.focused;
		});
	}
	if (action === 'video-load') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.loaded = true;
			item.appState.playing = false;
			item.appState.pulse = Number(item.appState.pulse || 0) + 1;
		});
	}
	if (action === 'video-toggle') {
		return updateLocalLaneItem(itemId, function(item) {
			if (!item.appState.loaded) return;
			item.appState.playing = !item.appState.playing;
			item.appState.pulse = Number(item.appState.pulse || 0) + 1;
		});
	}
	if (action === 'wiki-select') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState.selectedNode = value;
		});
	}
	if (action === 'wiki-expand') {
		return updateLocalLaneItem(itemId, function(item) {
			const expanded = Array.isArray(item.appState.expandedNodes) ? item.appState.expandedNodes.slice() : [];
			if (expanded.indexOf(value) === -1) expanded.push(value);
			item.appState.expandedNodes = expanded;
			item.appState.selectedNode = value;
		});
	}
	return false;
}

function handleGeneratedAppAction(action, itemId, value) {
	if (!action || !itemId) return false;
	if (action === 'calc-key') {
		return updateLocalLaneItem(itemId, function(item) {
			item.appState = generatedAppState(item);
			applyCalculatorKey(item.appState, value);
		});
	}
	if (action === 'calc-ask-current' || action === 'calc-ask-recent') {
		const item = findLocalLaneItem(itemId);
		if (!item) return false;
		syncInlineAppsNow(itemId).finally(function() {
			postAction({
				type: 'send-message',
				text: buildCalculatorChatPrompt(item, action === 'calc-ask-recent' ? 'recent' : 'current'),
				inlineAppItemId: itemId,
				cardId: item.cardId || '',
				sessionId: generatedAppState(item).sessionId || '',
			}, false);
		});
		return true;
	}
	return false;
}

document.addEventListener('click', function(event) {
	const laneExampleFillButton = event.target.closest('[data-lane-example-fill]');
	if (laneExampleFillButton) {
		populateBuilderForm(decodePayload(laneExampleFillButton.getAttribute('data-lane-example-fill')));
		return;
	}
	const laneExampleSeedButton = event.target.closest('[data-lane-example-seed]');
	if (laneExampleSeedButton) {
		seedBuilderExampleCardFromUi(laneExampleSeedButton.getAttribute('data-lane-example-seed') || '');
		return;
	}
	const laneExampleDismissButton = event.target.closest('[data-lane-example-dismiss]');
	if (laneExampleDismissButton) {
		const itemId = laneExampleDismissButton.getAttribute('data-lane-example-dismiss') || '';
		removeLocalLaneItem(itemId);
		return;
	}
	const mcpExampleButton = event.target.closest('[data-mcp-example-action]');
	if (mcpExampleButton) {
		handleMcpExampleAction(
			mcpExampleButton.getAttribute('data-mcp-example-action') || '',
			mcpExampleButton.getAttribute('data-mcp-example-item') || '',
			mcpExampleButton.getAttribute('data-mcp-example-value') || '',
		);
		return;
	}
	const generatedAppButton = event.target.closest('[data-generated-app-action]');
	if (generatedAppButton) {
		handleGeneratedAppAction(
			generatedAppButton.getAttribute('data-generated-app-action') || '',
			generatedAppButton.getAttribute('data-generated-app-item') || '',
			generatedAppButton.getAttribute('data-generated-app-value') || '',
		);
		return;
	}
	const generatedAppViewButton = event.target.closest('[data-generated-app-view][data-generated-app-item]');
	if (generatedAppViewButton) {
		setGeneratedAppViewportMode(
			generatedAppViewButton.getAttribute('data-generated-app-item') || '',
			generatedAppViewButton.getAttribute('data-generated-app-view') || 'inline',
		);
		return;
	}
	const fillBuilderExampleButton = event.target.closest('[data-builder-example-fill]');
	if (fillBuilderExampleButton) {
		const preset = decodePayload(fillBuilderExampleButton.getAttribute('data-builder-example-fill'));
		populateBuilderForm(preset);
		return;
	}
	const laneBuilderExampleButton = event.target.closest('[data-builder-example-lane]');
	if (laneBuilderExampleButton) {
		const exampleId = laneBuilderExampleButton.getAttribute('data-builder-example-lane') || '';
		if (!addBuilderExampleToLocalLane(exampleId)) {
			postAction({ type: 'add-builder-example-to-lane', exampleId: exampleId }, false);
		}
		return;
	}
	const seedBuilderExampleButton = event.target.closest('[data-builder-example-seed]');
	if (seedBuilderExampleButton) {
		seedBuilderExampleCardFromUi(seedBuilderExampleButton.getAttribute('data-builder-example-seed') || '');
		return;
	}
	const startAppSkillButton = event.target.closest('[data-start-app-skill]');
	if (startAppSkillButton) {
		postAction({
			type: 'launch-skill',
			skill: startAppSkillButton.getAttribute('data-start-app-skill') || 'toolshed-app-builder',
			prompt: 'Use the skill "toolshed-app-builder". Help me define a new tracked Toolshed MCP app. Ask one question at a time, keep the first version small, ask your questions directly in this conversation lane, and do not use terminal UI prompts or command wizards for the interview. When the plan is sharp enough, summarize it, include the exact /toolshed-app <brief> command, then ask "Is that okay?" and wait for my approval. After I approve, move straight into the build.',
		}, false);
		return;
	}
	const insertComposerButton = event.target.closest('[data-insert-composer]');
	if (insertComposerButton) {
		insertIntoComposer(insertComposerButton.getAttribute('data-insert-composer') || '');
		return;
	}
	const openInlineAppButton = event.target.closest('[data-open-inline-app]');
	if (openInlineAppButton) {
		addGeneratedAppToLocalLane(openInlineAppButton.getAttribute('data-open-inline-app') || '');
		if (PAGE_MODE === 'registry') window.location.href = '/';
		return;
	}
	const registryActionButton = event.target.closest('[data-registry-action][data-card-id]');
	if (registryActionButton) {
		postAction({
			type: registryActionButton.getAttribute('data-registry-action') || '',
			cardId: registryActionButton.getAttribute('data-card-id') || '',
		}, false);
		return;
	}
	const createCardButton = event.target.closest('[data-create-card]');
	if (createCardButton) {
		const form = createCardButton.closest('[data-builder-form]');
		if (!form) return;
		const title = (form.querySelector('[data-builder-field="title"]') || {}).value || '';
		const description = (form.querySelector('[data-builder-field="description"]') || {}).value || '';
		const promptTemplate = (form.querySelector('[data-builder-field="promptTemplate"]') || {}).value || '';
		const inputPlaceholder = (form.querySelector('[data-builder-field="inputPlaceholder"]') || {}).value || '';
		postAction({
			type: 'create-custom-card',
			persist: createCardButton.getAttribute('data-create-card') || 'session',
			title: String(title || '').trim(),
			description: String(description || '').trim(),
			promptTemplate: String(promptTemplate || '').trim(),
			inputPlaceholder: String(inputPlaceholder || '').trim(),
			generatedFrom: 'builder',
		}, false).then(function(result) {
			if (result && result.success) {
				Array.from(form.querySelectorAll('[data-builder-field]')).forEach(function(input) { input.value = ''; });
			}
		});
		return;
	}
	const seedMermaidButton = event.target.closest('[data-seed-mermaid]');
	if (seedMermaidButton) {
		postAction({ type: 'seed-mermaid-card' }, false);
		return;
	}
	const runCardButton = event.target.closest('[data-run-card]');
	if (runCardButton) {
		const cardId = runCardButton.getAttribute('data-run-card');
		const cardRoot = runCardButton.closest('[data-card-id]');
		const input = cardRoot ? cardRoot.querySelector('[data-card-input]') : null;
		const inputText = input && typeof input.value === 'string' ? input.value : '';
		postAction({ type: 'run-card', cardId: cardId, inputText: String(inputText || '').trim() }, false).then(function(result) {
			if (result && result.success && input) input.value = '';
		});
		return;
	}
	const pickerOption = event.target.closest('[data-picker-kind][data-picker-index]');
	if (pickerOption) {
		const kind = pickerOption.getAttribute('data-picker-kind');
		const index = parseInt(pickerOption.getAttribute('data-picker-index') || '-1', 10);
		if (contextPickerState[kind]) contextPickerState[kind].selectedIndex = index;
		submitContextPicker(kind);
		return;
	}
	if (!event.target.closest('.context-filter')) closeAllContextPickers();
	const actionButton = event.target.closest('[data-action-type]');
	if (actionButton) {
		const payload = decodePayload(actionButton.getAttribute('data-action-payload'));
		postAction({ type: actionButton.getAttribute('data-action-type'), ...payload }, false);
		return;
	}
	const expandButton = event.target.closest('[data-lane-expand]');
	if (expandButton) {
		const id = expandButton.getAttribute('data-lane-expand');
		if (expandedLaneItems.has(id)) expandedLaneItems.delete(id);
		else expandedLaneItems.add(id);
		renderLane();
		return;
	}
	const collapseButton = event.target.closest('[data-widget-collapse]');
	if (collapseButton) {
		const widgetId = collapseButton.getAttribute('data-widget-collapse');
		const widget = visibleWidgets().find(function(item){ return item.id === widgetId; });
		postAction({ type: widget && widget.collapsed ? 'expand-widget' : 'collapse-widget', widgetId: widgetId }, false);
		return;
	}
	if (event.target.closest('[data-open-drawer]')) {
		openDrawer();
		return;
	}
	if (event.target.closest('[data-close-drawer]')) {
		closeDrawer();
		return;
	}
});

document.addEventListener('input', function(event) {
	const field = event.target.getAttribute && event.target.getAttribute('data-mcp-example-input');
	if (!field) return;
	const itemId = event.target.getAttribute('data-mcp-example-item') || '';
	const nextValue = typeof event.target.value === 'string' ? event.target.value : '';
	const selectionStart = typeof event.target.selectionStart === 'number' ? event.target.selectionStart : nextValue.length;
	localLaneItems = localLaneItems.map(function(item) {
		if (item.id !== itemId) return item;
		return {
			...item,
			appState: {
				...(item.appState || initialMcpExampleState(item.exampleId || '')),
				[field]: nextValue,
			},
		};
	});
	saveLocalLaneItems();
	if (field === 'query') {
		renderLane();
		const refreshed = laneEl.querySelector('[data-mcp-example-input="query"][data-mcp-example-item="' + itemId + '"]');
		if (refreshed) {
			refreshed.focus();
			if (typeof refreshed.setSelectionRange === 'function') refreshed.setSelectionRange(selectionStart, selectionStart);
		}
	}
});

window.addEventListener('message', function(event) {
	if (!event || event.origin !== window.location.origin) return;
	const data = event.data;
	if (!data) return;
	if (data.type === 'toolshed-generated-app-display-mode') {
		setGeneratedAppViewportMode(String(data.itemId || ''), String(data.mode || 'inline'));
		return;
	}
	if (data.type === 'toolshed-generated-app-session-sync') {
		const itemId = String(data.itemId || '').trim();
		const item = findLocalLaneItem(itemId);
		if (!item || !item.appRuntime) return;
		if (data.appState && typeof data.appState === 'object') {
			localLaneItems = localLaneItems.map(function(entry) {
				if (entry.id !== itemId) return entry;
				return {
					...entry,
					appState: data.appState,
				};
			});
			saveLocalLaneItems();
		}
		postBackgroundAction({
			type: 'sync-inline-app-state',
			itemId: itemId,
			cardId: String(data.cardId || item.cardId || ''),
			title: String(data.title || item.title || item.appRuntime.title || 'Inline app'),
			adapter: String(data.adapter || generatedConversationAdapter(item) || ''),
			appRuntime: item.appRuntime,
			appState: data.appState && typeof data.appState === 'object' ? data.appState : {},
			sessionId: String(data.sessionId || ''),
		});
	}
});

document.addEventListener('keydown', function(event) {
	if (event.key !== 'Escape' || !viewportGeneratedAppItemId) return;
	setGeneratedAppViewportMode(viewportGeneratedAppItemId, 'inline');
});

