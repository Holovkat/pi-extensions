function workflowFormMarkup(widget) {
	const variableHint = widget.cardKind === 'mcp-app'
		? 'Variables: {{input}} · {{appBrief}} · {{starterTitle}} · {{artifactDir}} · {{serverFile}} · {{viewFile}} · {{resourceUri}} · {{serverId}} · {{toolName}}'
		: 'Variables: {{input}} · {{frontier}} · {{latestUser}} · {{projectDir}} · {{projectName}}';
	const showTemplatePreview = widget.cardKind !== 'mcp-app' && widget.promptTemplate;
	const inlineAction = widget.cardKind === 'mcp-app' && widget.appRuntime
		? '<button type="button" class="btn card-pill-btn" data-open-inline-app="' + escapeHtml(widget.id) + '"' + (widget.appRuntime.ready ? '' : ' disabled') + '>' + escapeHtml(widget.appRuntime.ready ? 'Open inline' : 'Build first') + '</button>'
		: '';
	return [
		'<div class="card-form" data-card-form="true" data-card-id="' + escapeHtml(widget.id) + '">',
			'<label class="card-field"><span class="card-field-label">' + escapeHtml(widget.cardKind === 'mcp-app' ? 'Add to app' : 'Run request') + '</span><textarea class="card-textarea compact" data-card-input placeholder="' + escapeHtml(widget.inputPlaceholder || 'What should this card do right now?') + '"></textarea></label>',
			(showTemplatePreview ? '<details class="card-details"><summary>Template preview</summary><div class="card-details-body"><pre class="workflow-template">' + escapeHtml(widget.promptTemplate) + '</pre><div class="card-inline-copy">' + escapeHtml(variableHint) + '</div></div></details>' : ''),
			'<div class="card-actions-row">',
				'<button type="button" class="btn primary card-pill-btn" data-run-card="' + escapeHtml(widget.id) + '">' + escapeHtml(widget.runLabel || 'Run in lane') + '</button>',
				inlineAction,
				(widget.removable ? '<button type="button" class="ghost-btn card-pill-btn" data-action-type="delete-custom-card" data-action-payload="' + encodePayload({ cardId: widget.id }) + '">Remove</button>' : ''),
			'</div>',
		'</div>'
	].join('');
}

function extensionCardMarkup(widget) {
	return '<div class="card-actions-row">' + (Array.isArray(widget.actions) ? widget.actions.map(function(action){ return actionButtonMarkup(action, 'card-pill-btn'); }).join('') : '') + '</div>';
}

function widgetMarkup(widget) {
	const narrative = [
		(widget.summary ? '<div class="widget-summary">' + renderMultiline(widget.summary || '') + '</div>' : ''),
		widgetFactsMarkup(widget),
		metadataMarkup(widget),
		(widget.footer ? '<div class="widget-footer">' + renderMultiline(widget.footer) + '</div>' : ''),
	].join('');
	let body = '';
	if (!widget.collapsed) {
		body = narrative;
		if (widget.renderMode === 'builder') body += builderFormMarkup(widget);
		else if (widget.renderMode === 'workflow') body += workflowFormMarkup(widget);
		else body += extensionCardMarkup(widget);
	}
	return [
		'<section class="widget-card ' + escapeHtml((widget.renderMode || 'workflow') + '-card tone-' + (widget.tone || 'info')) + '" data-card-id="' + escapeHtml(widget.id || '') + '">',
			'<div class="widget-head">',
				'<div class="widget-topline">',
					'<div class="widget-title-block">',
						'<div class="widget-title">' + escapeHtml(widget.title || 'Card') + '</div>',
						((widget.badge || widget.statusLabel) ? '<div class="widget-meta-row">'
							+ (widget.badge ? '<span class="widget-badge ' + escapeHtml('tone-' + (widget.tone || 'info')) + '">' + escapeHtml(widget.badge) + '</span>' : '')
							+ (widget.statusLabel ? '<span class="widget-status">' + escapeHtml(widget.statusLabel) + '</span>' : '')
						+ '</div>' : ''),
						(widget.purpose ? '<div class="widget-purpose">' + escapeHtml(widget.purpose || '') + '</div>' : ''),
					'</div>',
					widgetChromeMarkup(widget),
				'</div>',
			'</div>',
			body,
		'</section>'
	].join('');
}

function renderWidgets() {
	if (PAGE_MODE === 'registry') {
		inlineWidgets.innerHTML = '';
		leftDock.innerHTML = '';
		rightDock.innerHTML = '';
		floatLayer.innerHTML = '';
		return;
	}
	const widgets = sortWidgets(visibleWidgets());
	inlineWidgets.innerHTML = '';
	leftDock.innerHTML = '';
	rightDock.innerHTML = '';
	floatLayer.innerHTML = widgets.length > 0 ? widgets.map(widgetMarkup).join('') : '<div class="dock-empty">No cards in this deck yet.</div>';
}

function mcpExampleLaneMarkup(item) {
	const example = item && (item.example || getBuilderExampleById(item.exampleId || item.cardId || ''));
	if (!example) return '';
	const sources = Array.isArray(example.sources) ? example.sources : [];
	const presetPayload = encodePayload(example.preset || {});
	return [
		'<article class="lane-item card mcp-example" data-lane-item-id="' + escapeHtml(item.id || '') + '">',
			'<div class="lane-card mcp-example-card ' + (item.state === 'active' ? 'frontier ' : '') + escapeHtml('tone-' + (item.tone || 'info')) + '"' + (item.state === 'active' ? ' data-frontier="true"' : '') + '>',
				'<div class="lane-head">',
					'<div>',
						'<div class="mcp-example-kicker">MCP example</div>',
						'<div class="lane-title">' + escapeHtml(item.title || example.title || 'MCP example') + '</div>',
						'<div class="lane-meta">Historical item · ' + escapeHtml(formatTime(item.timestamp || Date.now())) + '</div>',
					'</div>',
					'<div class="lane-meta">App running inline</div>',
				'</div>',
				(example.summary ? '<div class="mcp-example-summary">' + escapeHtml(example.summary) + '</div>' : ''),
				renderMcpExampleApp(item, example),
				(sources.length > 0 ? '<div class="mcp-example-links">' + sources.map(function(source) {
					return '<a class="mcp-example-link" href="' + escapeHtml(source.url || '#') + '" target="_blank" rel="noreferrer">' + escapeHtml(source.label || source.url || 'Source') + '</a>';
				}).join('') + '</div>' : ''),
				'<div class="lane-tools mcp-example-actions">',
					'<button type="button" class="btn card-pill-btn" data-lane-example-fill="' + presetPayload + '">Use template</button>',
					'<button type="button" class="btn primary card-pill-btn" data-lane-example-seed="' + escapeHtml(example.id || '') + '">Seed card</button>',
					'<button type="button" class="ghost-btn card-pill-btn" data-lane-example-dismiss="' + escapeHtml(item.id || '') + '">Dismiss</button>',
				'</div>',
			'</div>',
		'</article>'
		].join('');
}

function renderGeneratedCalculatorApp(item) {
	const runtime = item && item.appRuntime ? item.appRuntime : {};
	const state = generatedAppState(item);
	const history = Array.isArray(state.history) ? state.history : [];
	const steps = Array.isArray(state.steps) ? state.steps : [];
	const latest = history[0] || null;
	const latestStep = steps[0] || null;
	const keys = [
		['C', '⌫', '÷', '×'],
		['7', '8', '9', '-'],
		['4', '5', '6', '+'],
		['1', '2', '3', '='],
		['0', '.'],
	];
	return [
		'<div class="mcp-app-shell">',
			'<div class="mcp-app-toolbar"><span class="mcp-app-chip">execute inline</span><span class="mcp-app-chip">toolbox + lane</span><span class="mcp-app-chip">session-only state</span></div>',
			'<div class="calc-stage">',
				'<section class="mcp-panel calc-panel">',
					'<div class="mcp-panel-label">Calculator</div>',
					'<div class="calc-screen">',
						'<div class="calc-expression">' + escapeHtml(calculatorVisibleExpression(state) || '') + '</div>',
						'<div class="calc-display">' + escapeHtml(state.display || '0') + '</div>',
						'<div class="calc-subdisplay">' + escapeHtml(state.updatedAt ? ('Updated ' + new Date(state.updatedAt).toLocaleTimeString()) : 'Ready') + '</div>',
					'</div>',
					'<div class="calc-keypad">' + keys.map(function(row) {
						return row.map(function(key) {
							const lower = String(key || '');
							const classes = ['calc-key'];
							if (['+', '-', '×', '÷', '='].includes(lower)) classes.push('operator');
							if (['C', '⌫'].includes(lower)) classes.push('action');
							if (lower === '=') classes.push('equals');
							if (lower === '0') classes.push('zero');
							return '<button type="button" class="' + escapeHtml(classes.join(' ')) + '" data-generated-app-action="calc-key" data-generated-app-item="' + escapeHtml(item.id) + '" data-generated-app-value="' + escapeHtml(lower) + '">' + escapeHtml(lower === '-' ? '−' : lower) + '</button>';
						}).join('');
					}).join('') + '</div>',
				'</section>',
				'<aside class="mcp-panel calc-panel">',
					'<div class="mcp-panel-label">Session</div>',
					'<div class="mcp-summary-text">Inline runtime for <strong>' + escapeHtml(runtime.title || item.title || 'Generated app') + '</strong>.</div>',
					'<div class="mcp-metric">Session: <span class="mcp-value mono">' + escapeHtml(state.sessionId || 'pending') + '</span></div>',
					'<div class="mcp-summary-text">' + escapeHtml(latest ? ('Recent calculation: ' + latest.expression + ' = ' + latest.result) : 'No completed calculations yet.') + '</div>',
					'<div class="mcp-summary-text">' + escapeHtml(latestStep ? ('Latest step: ' + latestStep.label) : 'No step memory yet.') + '</div>',
					'<div class="mcp-inline-actions">',
						'<button type="button" class="btn primary card-pill-btn" data-generated-app-action="calc-ask-current" data-generated-app-item="' + escapeHtml(item.id) + '">Ask chat about current value</button>',
						'<button type="button" class="btn card-pill-btn" data-generated-app-action="calc-ask-recent" data-generated-app-item="' + escapeHtml(item.id) + '">Ask chat about recent result</button>',
					'</div>',
					'<div class="mcp-panel-label">Step memory</div>',
					(steps.length > 0
						? '<div class="calc-history">' + steps.map(function(entry) {
							return '<div class="calc-history-item"><strong>' + escapeHtml(entry.label || entry.key || '') + '</strong><div>' + escapeHtml(entry.expression || entry.display || '') + '</div><div>= ' + escapeHtml(entry.display || '') + '</div></div>';
						}).join('') + '</div>'
						: '<div class="calc-history-empty">No calculation steps yet.</div>'),
					'<div class="mcp-panel-label">Recent history</div>',
					(history.length > 0
						? '<div class="calc-history">' + history.map(function(entry) {
							return '<div class="calc-history-item"><strong>' + escapeHtml(entry.expression || '') + '</strong><div>= ' + escapeHtml(entry.result || '') + '</div></div>';
						}).join('') + '</div>'
						: '<div class="calc-history-empty">No completed calculations yet.</div>'),
				'</aside>',
			'</div>',
		'</div>',
	].join('');
}

function renderGeneratedGenericApp(item) {
	const runtime = item && item.appRuntime ? item.appRuntime : {};
	const frameTheme = document.body.classList.contains('light') ? 'light' : 'dark';
	const frameVersion = generatedRuntimeVersion(runtime);
	const frameSrc = '/generated-app-frame?cardId=' + encodeURIComponent(String(item.cardId || runtime.cardId || '')) + '&itemId=' + encodeURIComponent(String(item.id || '')) + '&theme=' + encodeURIComponent(frameTheme) + (frameVersion ? '&v=' + encodeURIComponent(frameVersion) : '');
	return [
		'<div class="generated-app-stage">',
			'<div class="generated-app-frame-wrap">',
				'<iframe class="generated-app-frame" src="' + escapeHtml(frameSrc) + '" title="' + escapeHtml(runtime.title || item.title || 'Generated MCP app') + '" loading="lazy" allowfullscreen></iframe>',
			'</div>',
		'</div>',
	].join('');
}

function generatedAppLaneMarkup(item) {
	const runtime = item && item.appRuntime ? item.appRuntime : null;
	if (!runtime) return '';
	const body = runtime.adapter === 'calculator'
		? renderGeneratedCalculatorApp(item)
		: renderGeneratedGenericApp(item);
	const runtimeVersion = generatedRuntimeVersion(runtime);
	return [
		'<article class="lane-item card generated-app" data-lane-item-id="' + escapeHtml(item.id || '') + '" data-generated-app-item="' + escapeHtml(item.id || '') + '"' + (runtimeVersion ? ' data-generated-app-version="' + escapeHtml(runtimeVersion) + '"' : '') + '>',
			'<div class="lane-card generated-app-card ' + (item.state === 'active' ? 'frontier ' : '') + escapeHtml('tone-' + (item.tone || 'info')) + '"' + (item.state === 'active' ? ' data-frontier="true"' : '') + '>',
				body,
				'<div class="lane-tools mcp-example-actions generated-app-lane-actions"><button type="button" class="ghost-btn card-pill-btn" data-lane-example-dismiss="' + escapeHtml(item.id || '') + '">Dismiss</button></div>',
			'</div>',
		'</article>',
	].join('');
}

function laneItemMarkup(item) {
	const laneItemId = escapeHtml(item.id || '');
	const text = String(item.content || '');
	const summary = String(item.summary || '');
	const simplified = item.kind === 'user' || item.kind === 'assistant' || item.kind === 'system';
	const collapsibleTool = item.kind === 'tool' || item.kind === 'packet';
	if (item && item.meta === 'Generated MCP app' && item.appRuntime) {
		const generatedMarkup = generatedAppLaneMarkup(item);
		if (generatedMarkup) return generatedMarkup;
	}
	if (item && item.meta === 'MCP example' && (item.example || item.exampleId || item.cardId)) {
		const exampleMarkup = mcpExampleLaneMarkup(item);
		if (exampleMarkup) return exampleMarkup;
	}
	const primary = item.kind === 'system'
		? (summary.trim() || text.trim())
		: (text.trim() || summary.trim());
	const expanded = expandedLaneItems.has(item.id);
	const targetText = simplified ? primary : text;
	const long = targetText.length > 560 || (targetText.match(/\n/g) || []).length > 8;
	const visible = !long || expanded ? targetText : clipText(targetText, 520) + '\n\n[…expand for the full detail]';
	const tools = [];
	if (long && !collapsibleTool) {
		tools.push('<button type="button" class="mini-btn" data-lane-expand="' + escapeHtml(item.id) + '">' + escapeHtml(expanded ? 'Collapse' : 'Expand') + '</button>');
	}
	if (item.packetId) {
		tools.push('<button type="button" class="mini-btn" data-action-type="inject-packet" data-action-payload="' + encodePayload({ packetId: item.packetId }) + '">Inject packet</button>');
	}
	if (collapsibleTool) {
		const detailText = [item.toolRequest, item.title || (item.kind === 'packet' ? 'Packet result' : 'Tool result'), text].filter(Boolean).join('\n\n');
		const collapsedSummary = clipText(detailText.replace(/\s+/g, ' ').trim(), 120);
		return [
			'<article class="lane-item ' + escapeHtml(item.kind || 'system') + '" data-lane-item-id="' + laneItemId + '">',
				'<div class="lane-card ' + (item.state === 'active' ? 'frontier' : '') + ' ' + escapeHtml('tone-' + (item.tone || 'info')) + '"' + (item.state === 'active' ? ' data-frontier="true"' : '') + '>',
					'<button type="button" class="lane-toggle" data-lane-expand="' + escapeHtml(item.id) + '" aria-expanded="' + escapeHtml(String(expanded)) + '">',
						'<span class="lane-toggle-kind">' + escapeHtml(item.kind === 'packet' ? 'Packet' : 'Tool') + '</span>',
						'<span class="lane-toggle-summary">' + escapeHtml(collapsedSummary) + '</span>',
						'<span class="lane-toggle-chevron" aria-hidden="true">' + escapeHtml(expanded ? '▾' : '▸') + '</span>',
					'</button>',
					(expanded
						? [
							'<div class="lane-detail">',
								(detailText ? '<div class="lane-content">' + renderMultiline(detailText) + '</div>' : ''),
								(tools.length > 0 ? '<div class="lane-tools">' + tools.join('') + '</div>' : ''),
							'</div>'
						].join('')
						: ''),
				'</div>',
			'</article>'
		].join('');
	}
	if (simplified) {
		return [
			'<article class="lane-item ' + escapeHtml(item.kind || 'system') + '" data-lane-item-id="' + laneItemId + '">',
				'<div class="lane-card ' + (item.state === 'active' ? 'frontier' : '') + ' ' + escapeHtml('tone-' + (item.tone || 'info')) + '"' + (item.state === 'active' ? ' data-frontier="true"' : '') + '>',
					(primary ? '<div class="lane-summary">' + renderMarkdown(visible) + '</div>' : '<div class="empty-state">No lane content yet.</div>'),
					(tools.length > 0 ? '<div class="lane-tools">' + tools.join('') + '</div>' : ''),
				'</div>',
			'</article>'
		].join('');
	}
	return [
		'<article class="lane-item ' + escapeHtml(item.kind || 'system') + '" data-lane-item-id="' + laneItemId + '">',
			'<div class="lane-card ' + (item.state === 'active' ? 'frontier' : '') + ' ' + escapeHtml('tone-' + (item.tone || 'info')) + '"' + (item.state === 'active' ? ' data-frontier="true"' : '') + '>',
				'<div class="lane-head">',
					'<div>',
						'<div class="lane-title">' + escapeHtml(item.title || 'Lane item') + '</div>',
						'<div class="lane-meta">' + escapeHtml((item.state === 'active' ? 'Active frontier' : item.state === 'frozen' ? 'Frozen packet' : 'Historical item') + ' · ' + formatTime(item.timestamp || Date.now())) + '</div>',
					'</div>',
					(item.meta ? '<div class="lane-meta">' + escapeHtml(item.meta) + '</div>' : ''),
				'</div>',
				'<div class="lane-summary">' + renderMarkdown(summary || '') + '</div>',
				(text ? '<div class="lane-content">' + renderMarkdown(visible) + '</div>' : ''),
				(tools.length > 0 ? '<div class="lane-tools">' + tools.join('') + '</div>' : ''),
			'</div>',
		'</article>'
	].join('');
}

function mergeToolRequestLaneItems(items) {
	const merged = [];
	for (let i = 0; i < items.length; i++) {
		const item = items[i];
		const next = items[i + 1];
		const requestText = String(item && item.content || '').trim();
		const isToolRequest = item && item.kind === 'assistant' && /^Tool:\s/.test(requestText);
		const nextIsToolResult = next && (next.kind === 'tool' || next.kind === 'packet');
		if (isToolRequest && nextIsToolResult) {
			merged.push({ ...next, toolRequest: requestText });
			i++;
			continue;
		}
		merged.push(item);
	}
	return merged;
}

function renderLane() {
	const items = laneItemsWithLocal();
	if (items.length === 0) {
		viewportGeneratedAppItemId = '';
		applyGeneratedAppViewportState();
		const emptyNode = nodeFromMarkup('<div class="lane-card"><div class="empty-state">Waiting for Toolshed lane items…</div></div>');
		lane.replaceChildren(emptyNode || document.createTextNode(''));
		return;
	}
	const mergedItems = mergeToolRequestLaneItems(items);
	const desiredIds = new Set(mergedItems.map(function(item) { return String(item && item.id || '').trim(); }).filter(Boolean));
	const preservedGeneratedApps = captureGeneratedAppLaneNodes();
	const existingById = new Map();
	Array.from(lane.children).forEach(function(node) {
		if (!node || node.nodeType !== 1 || !node.getAttribute) return;
		const itemId = String(node.getAttribute('data-lane-item-id') || '').trim();
		if (itemId) existingById.set(itemId, node);
	});
	let cursor = lane.firstElementChild;
	mergedItems.forEach(function(item) {
		const itemId = String(item && item.id || '').trim();
		const currentNode = cursor && cursor.nodeType === 1 ? cursor : null;
		const currentId = currentNode && currentNode.getAttribute ? String(currentNode.getAttribute('data-lane-item-id') || '').trim() : '';
		const existing = itemId ? existingById.get(itemId) : null;
		const node = buildLaneItemNode(item, preservedGeneratedApps);
		if (!node) return;
		if (existing && existing !== currentNode && existing !== node && existing.parentNode === lane) existing.remove();
		if (node === currentNode) {
			cursor = node.nextElementSibling;
			return;
		}
		if (currentNode && currentId === itemId) {
			lane.replaceChild(node, currentNode);
		} else {
			lane.insertBefore(node, currentNode || null);
		}
		cursor = node.nextElementSibling;
	});
	Array.from(lane.children).forEach(function(node) {
		if (!node || node.nodeType !== 1 || !node.getAttribute) return;
		const itemId = String(node.getAttribute('data-lane-item-id') || '').trim();
		if (!itemId || !desiredIds.has(itemId)) node.remove();
	});
	applyGeneratedAppViewportState();
	if (shouldStickToBottom) {
		requestAnimationFrame(scrollFrontierIntoView);
	}
}

function registryTone(statusKind, value) {
	if ((statusKind === 'tracked' && value === 'ready') || (statusKind === 'live' && value === 'live') || (statusKind === 'published' && value === 'published')) return 'success';
	if ((statusKind === 'tracked' && value === 'building') || (statusKind === 'live' && value === 'stale')) return 'warning';
	if (statusKind === 'tracked' && value === 'failed') return 'error';
	return 'neutral';
}

function registryEntryMarkup(entry) {
	const openInlineButton = entry.verificationStatus === 'passed'
		? '<button type="button" class="btn card-pill-btn" data-open-inline-app="' + escapeHtml(entry.cardId) + '">Open inline</button>'
		: '';
	return [
		'<article class="registry-card">',
			'<div class="registry-head">',
				'<div class="registry-title-block">',
					'<div class="registry-title">' + escapeHtml(entry.title || 'Tracked app') + '</div>',
					'<div class="registry-brief">' + escapeHtml(entry.brief || 'No saved brief yet.') + '</div>',
				'</div>',
				'<div class="registry-statuses">',
					pillMarkup({ label: 'Tracked · ' + (entry.trackedLabel || 'Draft'), tone: registryTone('tracked', entry.trackedStatus) }),
					pillMarkup({ label: 'Live · ' + (entry.liveLabel || 'Not live'), tone: registryTone('live', entry.liveStatus) }),
					pillMarkup({ label: 'Published · ' + (entry.publishedLabel || 'Not published'), tone: registryTone('published', entry.publishedStatus) }),
				'</div>',
			'</div>',
			'<div class="registry-grid">',
				'<div class="registry-cell"><div class="registry-cell-label">Tracked</div><div class="registry-cell-value">' + renderMultiline(entry.trackedSummary || 'No tracked summary yet.') + '</div></div>',
				'<div class="registry-cell"><div class="registry-cell-label">Live</div><div class="registry-cell-value">' + renderMultiline(entry.liveSummary || 'Not deployed live yet.') + '</div></div>',
				'<div class="registry-cell"><div class="registry-cell-label">Published</div><div class="registry-cell-value">' + renderMultiline(entry.publishedSummary || 'No publish state yet.') + '</div></div>',
			'</div>',
			'<div class="registry-meta">'
				+ (entry.starterTitle ? pillMarkup({ label: 'Starter: ' + entry.starterTitle, tone: 'neutral' }) : '')
				+ (entry.serverId ? pillMarkup({ label: 'Server: ' + entry.serverId, tone: 'neutral' }) : '')
				+ (entry.toolName ? pillMarkup({ label: 'Tool: ' + entry.toolName, tone: 'neutral' }) : '')
				+ (entry.liveDeployedAt ? pillMarkup({ label: 'Live ' + relativeTime(entry.liveDeployedAt), tone: 'info' }) : '')
				+ (entry.verificationUpdatedAt ? pillMarkup({ label: 'Verified ' + relativeTime(entry.verificationUpdatedAt), tone: 'info' }) : ''),
			'</div>',
			'<div class="registry-actions">',
				'<button type="button" class="btn primary card-pill-btn" data-registry-action="rebuild-mcp-app" data-card-id="' + escapeHtml(entry.cardId || '') + '">Rebuild</button>',
				'<button type="button" class="btn card-pill-btn" data-registry-action="redeploy-mcp-app" data-card-id="' + escapeHtml(entry.cardId || '') + '">Redeploy live</button>',
				'<button type="button" class="ghost-btn card-pill-btn" data-registry-action="refresh-mcp-app" data-card-id="' + escapeHtml(entry.cardId || '') + '">Refresh</button>',
				openInlineButton,
			'</div>',
		'</article>',
	].join('');
}

function renderRegistry() {
	if (!registryView) return;
	if (!currentState || !currentState.registry) {
		registryView.innerHTML = '<div class="registry-empty">Waiting for Toolshed registry state…</div>';
		return;
	}
	const registry = currentState.registry || {};
	const entries = Array.isArray(registry.entries) ? registry.entries : [];
	registryView.innerHTML = [
		'<section class="registry-summary">',
			'<div class="section-label">Tools Registry</div>',
			'<div class="widget-title">Tracked, live, and published app state</div>',
			'<div class="registry-summary-copy">' + escapeHtml(registry.summary || 'No tracked MCP apps yet.') + '</div>',
			'<div class="registry-meta">'
				+ pillMarkup({ label: String(registry.liveCount || 0) + ' live', tone: (registry.liveCount || 0) > 0 ? 'success' : 'neutral' })
				+ pillMarkup({ label: String(registry.staleCount || 0) + ' stale', tone: (registry.staleCount || 0) > 0 ? 'warning' : 'neutral' })
				+ pillMarkup({ label: String(registry.publishedCount || 0) + ' published', tone: (registry.publishedCount || 0) > 0 ? 'info' : 'neutral' }),
			'</div>',
			'<div class="registry-summary-copy">Use rebuild to ask Pi for a new tracked build, refresh to rerun verification, and redeploy live to make the verified version the current Toolshed catalog entry for the lane.</div>',
		'</section>',
		'<section class="registry-list">' + (entries.length > 0 ? entries.map(registryEntryMarkup).join('') : '<div class="registry-empty">No tracked MCP apps are in the registry yet.</div>') + '</section>',
	].join('');
}

function renderHeader() {
	const workspace = currentWorkspace();
	const connection = connectionLabel();
	connectionPill.className = 'pill tone-' + connection.tone;
	connectionPill.textContent = connection.label;
	if (!currentState) {
		if (headerTitle) headerTitle.textContent = 'Waiting for Pi Toolshed state';
		if (headerMeta) headerMeta.textContent = PROJECT_NAME + ' · open /toolshed-web inside Pi to connect this lane.';
		heroTitle.textContent = PAGE_MODE === 'registry' ? 'Tools Registry' : 'Hi, I’m Pi Toolshed';
		heroCopy.textContent = PAGE_MODE === 'registry'
			? 'Open /toolshed-web inside Pi to connect the registry, verify tracked apps, and see what is actually live in the current Toolshed catalog.'
			: 'Open /toolshed-web inside Pi to bind this browser, keep the live lane centered, and run cards from the right rail without replacing the conversation.';
		heroMeta.textContent = PROJECT_NAME + ' · ' + PROJECT_DIR;
		headerPills.innerHTML = '';
		heroPills.innerHTML = '';
		quickActions.innerHTML = '';
		return;
	}
	workspaceSelect.innerHTML = (currentState.workspaces || []).map(function(item){
		return '<option value="' + escapeHtml(item.id) + '">' + escapeHtml(item.title) + '</option>';
	}).join('');
	workspaceSelect.value = currentState.workspaceId || '';
	const repo = currentState.repository;
	const headerChips = [];
	(currentState.status && currentState.status.chips || []).forEach(function(chip){ headerChips.push(pillMarkup(chip)); });
	if (repo) headerChips.push(pillMarkup({ label: repo.branch + (repo.dirty ? ' · ' + repo.changed + ' dirty' : ' · clean'), tone: repo.dirty ? 'warning' : 'success' }));
	if (currentState.status && currentState.status.provider && currentState.status.model) headerChips.push(pillMarkup({ label: currentState.status.provider + '/' + currentState.status.model, tone: 'neutral' }));
	headerPills.innerHTML = PAGE_MODE === 'registry' ? headerChips.join('') : '';
	if (headerTitle) headerTitle.textContent = workspace ? workspace.title : 'Pi Toolshed';
	if (workspace) {
		heroTitle.textContent = PAGE_MODE === 'registry' ? 'Tools Registry' : workspace.title;
		heroCopy.textContent = PAGE_MODE === 'registry'
			? 'Rebuild, redeploy, and verify tracked MCP apps here. When you go back to the lane, the live Toolshed catalog reflects what this page marked as live.'
			: workspace.description;
			if (PAGE_MODE === 'registry') {
				const registry = currentState.registry || {};
				heroPills.innerHTML = [
					pillMarkup({ label: String((registry.entries || []).length) + ' tracked', tone: 'neutral' }),
					pillMarkup({ label: String(registry.liveCount || 0) + ' live', tone: (registry.liveCount || 0) > 0 ? 'success' : 'neutral' }),
					pillMarkup({ label: String(registry.staleCount || 0) + ' stale', tone: (registry.staleCount || 0) > 0 ? 'warning' : 'neutral' }),
				].join('');
				quickActions.innerHTML = '<a class="btn card-pill-btn" href="/">Back to lane</a>';
			} else {
				heroPills.innerHTML = '';
				quickActions.innerHTML = (workspace.quickActions || []).map(function(action){ return actionButtonMarkup(action); }).join('');
			}
		}
	const updated = currentState.updatedAt ? 'Updated ' + relativeTime(currentState.updatedAt) : 'No timestamp';
	const frontier = currentState.frontier && currentState.frontier.summary ? currentState.frontier.summary : 'No frontier yet.';
		if (headerMeta) headerMeta.textContent = PROJECT_NAME + ' · ' + updated;
		heroMeta.textContent = PROJECT_NAME + ' · ' + updated + ' · Frontier: ' + frontier;
		if (composerTitle) composerTitle.textContent = PAGE_MODE === 'registry' ? 'Registry actions' : (workspace ? workspace.title + ' deck' : 'Toolshed cards');
		if (composerSubtitle) composerSubtitle.textContent = PAGE_MODE === 'registry'
			? 'Use registry actions above to rebuild or redeploy tracked apps. Return to the lane when you want to use the live catalog.'
			: 'The composer stays primary. Cards mirror and extend the lane; they do not replace it.';
}

