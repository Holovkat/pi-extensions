Object.keys(contextPickers).forEach(function(kind) {
	const config = contextPickers[kind];
	const state = contextPickerState[kind];
	if (!config || !config.input) return;
	config.input.addEventListener('focus', function() {
		closeAllContextPickers(kind);
		state.open = true;
		refreshContextPicker(kind);
	});
	config.input.addEventListener('input', function() {
		closeAllContextPickers(kind);
		state.query = config.input.value;
		state.selectedIndex = 0;
		state.open = true;
		refreshContextPicker(kind);
	});
	config.input.addEventListener('keydown', function(event) {
		const filtered = state.filtered || [];
		if (event.key === 'ArrowDown') {
			event.preventDefault();
			if (filtered.length > 0) state.selectedIndex = Math.min(filtered.length - 1, Math.max(0, state.selectedIndex + 1));
			state.open = true;
			refreshContextPicker(kind);
			return;
		}
		if (event.key === 'ArrowUp') {
			event.preventDefault();
			if (filtered.length > 0) state.selectedIndex = Math.max(0, state.selectedIndex - 1);
			state.open = true;
			refreshContextPicker(kind);
			return;
		}
		if (event.key === 'Enter') {
			event.preventDefault();
			submitContextPicker(kind);
			return;
		}
		if (event.key === 'Tab') {
			if (selectedContextItem(kind)) {
				event.preventDefault();
				insertContextPicker(kind);
			} else {
				closeContextPicker(kind);
			}
			return;
		}
		if (event.key === 'Escape') {
			closeContextPicker(kind);
		}
	});
	config.input.addEventListener('blur', function() {
		setTimeout(function() {
			if (!document.activeElement || !document.activeElement.closest('.context-filter')) {
				state.open = false;
				refreshContextPicker(kind);
			}
		}, 120);
	});
	config.list.addEventListener('mousedown', function(event) {
		event.preventDefault();
	});
});
